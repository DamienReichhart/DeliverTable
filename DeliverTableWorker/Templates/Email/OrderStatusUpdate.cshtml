@model DeliverTableInfrastructure.TemplateData.OrderStatusUpdateData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #333;">Mise à jour de votre commande</h2>
    <p>Votre commande <strong>#@Model.OrderId</strong> chez <strong>@Model.RestaurantName</strong> a un nouveau statut :</p>
