@model DeliverTableInfrastructure.TemplateData.OrderConfirmationData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #333;">Confirmation de commande</h2>
    <p>Votre commande <strong>#@Model.OrderId</strong> chez <strong>@Model.RestaurantName</strong> a bien été enregistrée.</p>

    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <thead>
            <tr style="background-color: #f5f5f5;">
                <th style="padding: 10px; text-align: left; border-bottom: 1px solid #ddd;">Article</th>
                <th style="padding: 10px; text-align: center; border-bottom: 1px solid #ddd;">Qté</th>
                <th style="padding: 10px; text-align: right; border-bottom: 1px solid #ddd;">Prix</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td style="padding: 10px; border-bottom: 1px solid #eee;">@item.DishName</td>
                    <td style="padding: 10px; text-align: center; border-bottom: 1px solid #eee;">@item.Quantity</td>
                    <td style="padding: 10px; text-align: right; border-bottom: 1px solid #eee;">@item.UnitPrice.ToString("0.00") €</td>
                </tr>
            }
        </tbody>
    </table>

    <p style="font-size: 18px; font-weight: bold;">Total : @Model.TotalPrice.ToString("0.00") €</p>
    <p style="color: #666; font-size: 12px;">Merci pour votre commande sur DeliverTable.</p>
</body>
</html>
