@model DeliverTableInfrastructure.TemplateData.DisputeEmailData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #27ae60;">Litige gagné</h2>
    <p>Bonne nouvelle : le litige ouvert sur la commande <strong>#@Model.OrderId</strong> a été résolu en notre faveur.</p>
    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr><td style="padding: 8px; color: #666;">Montant restitué :</td><td style="padding: 8px;"><strong>@Model.Amount @Model.Currency</strong></td></tr>
    </table>
    <p>Le montant a été automatiquement recrédité sur votre compte restaurateur. Vous pouvez consulter la transaction correspondante dans votre espace compte.</p>
    <p style="color: #666; font-size: 12px;">— L'équipe DeliverTable</p>
</body>
</html>
