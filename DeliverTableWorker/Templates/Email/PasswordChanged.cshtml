@model DeliverTableInfrastructure.TemplateData.PasswordChangedData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #333;">Mot de passe modifié</h2>
    <p>Bonjour @Model.UserName,</p>
    <p>Votre mot de passe a été modifié avec succès.</p>
    <p>Si vous n'êtes pas à l'origine de cette modification, veuillez contacter notre support immédiatement.</p>
    <p style="color: #666; font-size: 12px;">L'équipe DeliverTable</p>
</body>
</html>
