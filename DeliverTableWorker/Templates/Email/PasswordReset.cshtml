@model DeliverTableInfrastructure.TemplateData.PasswordResetData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #333;">Réinitialisation de mot de passe</h2>
    <p>Bonjour @Model.UserName,</p>
    <p>Vous avez demandé la réinitialisation de votre mot de passe. Cliquez sur le lien ci-dessous :</p>
    <p style="margin: 20px 0;">
        <a href="@Model.ResetLink" style="background-color: #4CAF50; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px;">Réinitialiser mon mot de passe</a>
    </p>
    <p style="color: #666; font-size: 12px;">Si vous n'avez pas fait cette demande, ignorez cet email.</p>
</body>
</html>
