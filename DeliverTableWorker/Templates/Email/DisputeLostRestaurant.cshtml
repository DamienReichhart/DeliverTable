@model DeliverTableInfrastructure.TemplateData.DisputeEmailData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #c0392b;">Litige perdu</h2>
    <p>Bonjour,</p>
    <p>Le litige ouvert sur la commande <strong>#@Model.OrderId</strong> a été résolu en faveur du client.</p>
    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr><td style="padding: 8px; color: #666;">Montant :</td><td style="padding: 8px;"><strong>@Model.Amount @Model.Currency</strong></td></tr>
    </table>
    <p>Le montant retenu lors de l'ouverture du litige n'est pas restitué. Si vous le souhaitez, contactez le support pour plus d'informations.</p>
    <p style="color: #666; font-size: 12px;">— L'équipe DeliverTable</p>
</body>
</html>
