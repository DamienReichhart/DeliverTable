@model DeliverTableInfrastructure.TemplateData.CommissionStatementCreditNoteData

<!DOCTYPE html>
<html>
<head><meta charset="utf-8" /></head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h2 style="color: #333;">Avoir sur commissions disponible</h2>
    <p>Bonjour,</p>
    <p>Veuillez trouver ci-joint l'avoir sur commissions <strong>@Model.StatementNumber</strong> pour la commande <strong>#@Model.OrderNumber</strong>.</p>
    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr>
            <td style="padding: 8px; color: #666;">Date d'émission :</td>
            <td style="padding: 8px;"><strong>@Model.IssuedAt</strong></td>
        </tr>
        <tr>
            <td style="padding: 8px; color: #666;">Montant TTC :</td>
            <td style="padding: 8px;"><strong>@Model.TotalTtc @Model.Currency</strong></td>
        </tr>
    </table>
    <p style="color: #666; font-size: 12px;">Vous pouvez consulter et télécharger cet avoir depuis votre espace restaurateur sur DeliverTable.</p>
    <p>Cordialement,<br />L'équipe DeliverTable</p>
</body>
</html>
