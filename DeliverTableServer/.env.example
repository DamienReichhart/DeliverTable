# DeliverTable Server – environment variables
# Copy this file to .env and set values for your environment.
# Do not commit .env (it is in .gitignore). Use .env.example as the template.
#
# Naming: for nested config keys use double underscore (e.g. OpenApi__EnableDocumentation).

# -----------------------------------------------------------------------------
# ASP.NET Core (standard)
# -----------------------------------------------------------------------------
# Environment name: Development, Staging, Production, etc.
ASPNETCORE_ENVIRONMENT=Development

# URLs the server listens on (comma-separated). Leave empty to use default.
# Example: http://localhost:5268 or https://localhost:7067;http://localhost:5268
ASPNETCORE_URLS=http://localhost:5268

# -----------------------------------------------------------------------------
# OpenAPI / Swagger
# -----------------------------------------------------------------------------
# Set to true to expose API documentation in non-Development environments.
# When false (default), documentation is only enabled in Development.
OpenApi__EnableDocumentation=false

# -----------------------------------------------------------------------------
# Logging (optional overrides)
# -----------------------------------------------------------------------------
# Log level: Trace, Debug, Information, Warning, Error, Critical, None
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning
