# DeliverTable – Docker Development Environment
# Copy to .env and adjust values as needed.
# Do NOT commit .env (it is in .gitignore).

# ─────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────
POSTGRES_DB=delivertable
POSTGRES_USER=delivertable
POSTGRES_PASSWORD=delivertable_dev

# ─────────────────────────────────────────────────
# Connection Strings
# ─────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=192.168.60.20;Port=5432;Database=delivertable;Username=delivertable;Password=delivertable_dev

# ─────────────────────────────────────────────────
# Exposed Host Ports
# ─────────────────────────────────────────────────
PROXY_PORT=8080
DB_PORT=5432

# ─────────────────────────────────────────────────
# Utils (docker-utils.yaml)
# ─────────────────────────────────────────────────
COVERAGE_THRESHOLD=80
