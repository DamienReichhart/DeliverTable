# DeliverTable Environment Variables
# Copy to .env and adjust values as needed.
# Do NOT commit .env (it is in .gitignore).

# ═════════════════════════════════════════════════
# Infrastructure
# ═════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────
POSTGRES_DB=delivertable
POSTGRES_USER=delivertable
POSTGRES_PASSWORD=delivertable_dev

# ─────────────────────────────────────────────────
# Object Storage (Garage S3)
# ─────────────────────────────────────────────────
# RPC secret shared between Garage nodes (generate with: openssl rand -hex 32)
GARAGE_RPC_SECRET=ae1b38e8a165c165c47e2a4acba2dc5ab96e2e66e8c7e5d3b2f3b0b6e4d7a1c9
# Admin API bearer token (generate with: openssl rand -base64 32)
GARAGE_ADMIN_TOKEN=devadmintoken
# S3 credentials used by the application
# Access key: GK + 24 hex chars | Secret key: 64 hex chars
GARAGE_S3_ACCESS_KEY=GK31c2f218a7e47e02a1b2c3d4
GARAGE_S3_SECRET_KEY=a3c5e7091b2d4f6081a3c5e7091b2d4f6081a3c5e7091b2d4f6081a3c5e70910
GARAGE_BUCKET_NAME=delivertable

# ─────────────────────────────────────────────────
# Redis (in-memory cache)
# ─────────────────────────────────────────────────
# Password used in production (generate with: openssl rand -base64 32)
REDIS_PASSWORD=redis_dev_password

# ═════════════════════════════════════════════════
# Server (DeliverTableServer)
# ═════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# ASP.NET Core
# ─────────────────────────────────────────────────
# Environment name: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Development
# URLs the server listens on (comma-separated). Leave empty to use default.
ASPNETCORE_URLS=http://0.0.0.0:5268

# ─────────────────────────────────────────────────
# Connection Strings
# ─────────────────────────────────────────────────
CONNECTION_STRING_DATABASE=Host=192.168.60.20;Port=5432;Database=delivertable;Username=delivertable;Password=delivertable_dev
CONNECTION_STRING_REDIS=192.168.60.50:6379

# ─────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────
# Generate key with: openssl rand -base64 64
JWT_KEY=XGrJ8LTaQ02yN9fZ+mKvBnE4pRsUwH7cFjAi5Dq1Yo3dVlOxCW6kSbMhPeIuZtN
JWT_ISSUER=DeliverTable
JWT_AUDIENCE=DeliverTable
JWT_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────────
# Object Storage (S3-compatible, backed by Garage in dev/prod)
# ─────────────────────────────────────────────────
OBJECT_STORAGE_SERVICE_URL=http://192.168.60.30:3900
OBJECT_STORAGE_ACCESS_KEY=GK31c2f218a7e47e02a1b2c3d4
OBJECT_STORAGE_SECRET_KEY=a3c5e7091b2d4f6081a3c5e7091b2d4f6081a3c5e7091b2d4f6081a3c5e70910
OBJECT_STORAGE_BUCKET_NAME=delivertable
OBJECT_STORAGE_FORCE_PATH_STYLE=true
# S3 signing region — must match s3_region in garage.toml (default: "garage")
OBJECT_STORAGE_REGION=garage

# ─────────────────────────────────────────────────
# Upload Limits
# ─────────────────────────────────────────────────
# Maximum file upload size in megabytes (default: 5)
UPLOAD_MAX_SIZE_MB=5

# ─────────────────────────────────────────────────
# OpenAPI / Swagger
# ─────────────────────────────────────────────────
# Set to true to expose API documentation in non-Development environments.
# When false (default), documentation is only enabled in Development.
OPENAPI_ENABLE_DOCUMENTATION=false

# ═════════════════════════════════════════════════
# Development only
# ═════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# Exposed Host Ports
# ─────────────────────────────────────────────────
PROXY_PORT=8080
DB_PORT=5432
GARAGE_API_PORT=3900
REDIS_PORT=6379
S3_MANAGER_PORT=8888

# ─────────────────────────────────────────────────
# Utils (docker-utils.yaml)
# ─────────────────────────────────────────────────
COVERAGE_THRESHOLD=80

# ═════════════════════════════════════════════════
# Production only
# ═════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# Cloudflare Tunnel
# ─────────────────────────────────────────────────
# Obtain from: Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
# Configure the tunnel ingress to route traffic to http://172.30.0.10:80 (proxy on dt-public-net)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
