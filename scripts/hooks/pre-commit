#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════
#  DeliverTable – Git Pre-Commit Hook
# ═══════════════════════════════════════════════════════════════════
#
#  Two-stage validation before every commit:
#
#    Stage 1 – Fast local checks (no Docker)
#      • Merge conflict markers
#      • Trailing whitespace
#      • Final newline in text files
#      • File size limit (1 MB)
#      • Hardcoded secret patterns
#
#    Stage 2 – Docker-based quality gates (C#/Razor/project files only)
#      • Code formatting     (make format-check)
#      • Release build       (make build-release)
#      • Test suite           (make test)
#
#  Override with environment variables:
#    SKIP_DOCKER_CHECKS=1   Skip all Docker-based checks
#    SKIP_TESTS=1            Skip tests but keep format + build checks
#
#  Bypass entirely (not recommended):
#    git commit --no-verify
# ═══════════════════════════════════════════════════════════════════

set -euo pipefail

readonly MAX_FILE_SIZE=1048576  # 1 MB

# ── Terminal colours ────────────────────────────────────────────

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly DIM='\033[2m'
readonly RESET='\033[0m'

ERRORS=0

header()  { printf '\n%b%b══ %s%b\n' "$BOLD" "$CYAN" "$1" "$RESET"; }
step()    { printf '%b  ▸ %s%b\n' "$CYAN" "$1" "$RESET"; }
pass()    { printf '%b    ✔ %s%b\n' "$GREEN" "$1" "$RESET"; }
fail()    { printf '%b    ✘ %s%b\n' "$RED" "$1" "$RESET"; ERRORS=$((ERRORS + 1)); }
warn()    { printf '%b    ⚠ %s%b\n' "$YELLOW" "$1" "$RESET"; }
detail()  { printf '%b      %s%b\n' "$DIM" "$1" "$RESET"; }

# ── Collect staged files ────────────────────────────────────────

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)

if [[ ${#STAGED[@]} -eq 0 ]]; then
    printf '%b✔ No staged files — nothing to check.%b\n' "$GREEN" "$RESET"
    exit 0
fi

printf '\n%bPre-commit · %d staged file(s)%b\n' "$BOLD" "${#STAGED[@]}" "$RESET"

# Binary extensions to skip in text-oriented checks
is_binary() {
    case "$1" in
        *.png|*.jpg|*.jpeg|*.gif|*.bmp|*.ico|*.webp|*.svg|\
        *.woff|*.woff2|*.ttf|*.eot|*.otf|\
        *.pdf|*.zip|*.gz|*.tar|*.7z|*.rar|\
        *.dll|*.exe|*.bin|*.so|*.dylib|*.pdb|\
        *.mp3|*.mp4|*.wav|*.avi|*.mov) return 0 ;;
        *) return 1 ;;
    esac
}

# ── Stage 1 — Fast local checks ────────────────────────────────

header "Local checks"

# 1. Merge conflict markers
step "Merge conflict markers"
CONFLICT_FILES=()
for file in "${STAGED[@]}"; do
    is_binary "$file" && continue
    if git show ":$file" 2>/dev/null | grep -Eq '^(<{7}|={7}|>{7})'; then
        CONFLICT_FILES+=("$file")
    fi
done
if [[ ${#CONFLICT_FILES[@]} -eq 0 ]]; then
    pass "None found"
else
    fail "Conflict markers detected"
    for f in "${CONFLICT_FILES[@]}"; do detail "$f"; done
fi

# 2. Trailing whitespace (git's built-in check)
step "Trailing whitespace"
if git diff --cached --check > /dev/null 2>&1; then
    pass "Clean"
else
    fail "Trailing whitespace detected (run 'git diff --cached --check' for details)"
fi

# 3. Final newline
step "Final newline"
MISSING_NL=()
for file in "${STAGED[@]}"; do
    is_binary "$file" && continue
    blob_size=$(git cat-file -s ":$file" 2>/dev/null) || continue
    [[ "$blob_size" -eq 0 ]] && continue
    if [[ "$(git show ":$file" | tail -c 1 | wc -l)" -eq 0 ]]; then
        MISSING_NL+=("$file")
    fi
done
if [[ ${#MISSING_NL[@]} -eq 0 ]]; then
    pass "All text files end with newline"
else
    fail "Missing final newline"
    for f in "${MISSING_NL[@]}"; do detail "$f"; done
fi

# 4. Large files
step "File size (max 1 MB)"
LARGE=()
for file in "${STAGED[@]}"; do
    blob_size=$(git cat-file -s ":$file" 2>/dev/null) || continue
    if [[ "$blob_size" -gt "$MAX_FILE_SIZE" ]]; then
        human=$(numfmt --to=iec-i --suffix=B "$blob_size" 2>/dev/null || echo "${blob_size} bytes")
        LARGE+=("$file ($human)")
    fi
done
if [[ ${#LARGE[@]} -eq 0 ]]; then
    pass "No oversized files"
else
    fail "Files exceed 1 MB limit"
    for f in "${LARGE[@]}"; do detail "$f"; done
fi

# 5. Hardcoded secrets
step "Hardcoded secrets"
SECRET_PATTERN='(?i)(password|secret|api[_-]?key|access[_-]?token|private[_-]?key)\s*[:=]\s*["'"'"'][^"'"'"'\s]{8,}'
SECRETS=()
for file in "${STAGED[@]}"; do
    is_binary "$file" && continue
    case "$file" in
        *.example|*.template|*.md|*.lock) continue ;;
    esac
    if git show ":$file" 2>/dev/null | grep -Pq "$SECRET_PATTERN"; then
        SECRETS+=("$file")
    fi
done
if [[ ${#SECRETS[@]} -eq 0 ]]; then
    pass "No hardcoded secrets detected"
else
    fail "Potential secrets found — review before committing"
    for f in "${SECRETS[@]}"; do detail "$f"; done
fi

# ── Stage 2 — Docker-based quality gates ───────────────────────

has_dotnet_files=false
for file in "${STAGED[@]}"; do
    case "$file" in
        *.cs|*.csproj|*.sln|*.razor) has_dotnet_files=true; break ;;
    esac
done

run_docker_check() {
    local target="$1"
    local pass_msg="$2"
    local fail_msg="$3"
    local tmpfile
    tmpfile=$(mktemp)

    if make "$target" > "$tmpfile" 2>&1; then
        pass "$pass_msg"
    else
        fail "$fail_msg"
        detail "─── output (last 30 lines) ───"
        tail -30 "$tmpfile" | while IFS= read -r line; do
            detail "│ $line"
        done
        detail "──────────────────────────────"
    fi

    rm -f "$tmpfile"
}

if [[ "$has_dotnet_files" == false ]]; then
    printf '\n%bNo .NET files staged — skipping Docker-based checks.%b\n' "$DIM" "$RESET"
elif [[ "${SKIP_DOCKER_CHECKS:-0}" == "1" ]]; then
    printf '\n%bSKIP_DOCKER_CHECKS=1 — Docker-based checks skipped.%b\n' "$YELLOW" "$RESET"
else
    header "Docker-based quality gates"

    step "Code formatting (make format-check)"
    run_docker_check "format-check" \
        "Formatting is correct" \
        "Formatting violations (run 'make format-fix' to auto-fix)"

    step "Release build (make build-release)"
    run_docker_check "build-release" \
        "Build succeeded (warnings treated as errors)" \
        "Release build failed or produced warnings"

    if [[ "${SKIP_TESTS:-0}" != "1" ]]; then
        step "Test suite (make test)"
        run_docker_check "test" \
            "All tests passed" \
            "Test suite failed"
    else
        warn "SKIP_TESTS=1 — test suite skipped"
    fi

fi

# ── Summary ─────────────────────────────────────────────────────

printf '\n'
if [[ "$ERRORS" -gt 0 ]]; then
    printf '%b%b✘ Pre-commit failed (%d error(s))%b\n' "$BOLD" "$RED" "$ERRORS" "$RESET"
    printf '%bFix the issues above, then stage and commit again.%b\n' "$YELLOW" "$RESET"
    printf '%bBypass (not recommended): git commit --no-verify%b\n' "$DIM" "$RESET"
    exit 1
fi

printf '%b%b✔ All pre-commit checks passed%b\n' "$BOLD" "$GREEN" "$RESET"
