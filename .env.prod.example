# DeliverTable – Docker Production Environment
# Copy to .env and set values appropriate for production.
# Do NOT commit .env (it is in .gitignore).

# ─────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────
POSTGRES_DB=delivertable
POSTGRES_USER=delivertable
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD

# ─────────────────────────────────────────────────
# Connection String
# ─────────────────────────────────────────────────
# Host is the database static IP on dt-backend-net (172.32.0.0/24)
ConnectionStrings__DefaultConnection=Host=172.32.0.20;Port=5432;Database=delivertable;Username=delivertable;Password=CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD

# ─────────────────────────────────────────────────
# Cloudflare Tunnel
# ─────────────────────────────────────────────────
# Obtain from: Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
# Configure the tunnel ingress to route traffic to http://172.30.0.10:80 (proxy on dt-public-net)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
