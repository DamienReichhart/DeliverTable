@inject AuthService AuthService
@inject NavigationManager Nav

<div class="app-nav-top">
    <a class="app-nav-brand" href="/">
        <svg class="app-nav-brand-logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="15" fill="#E85D34"/>
            <text x="16" y="21" text-anchor="middle" font-family="'DM Serif Display', serif" font-size="18" font-weight="bold" fill="white">D</text>
        </svg>
        <span>DeliverTable</span>
    </a>
    <button type="button" title="Navigation menu" class="app-nav-toggler" @onclick="ToggleNavMenu"
            aria-label="Toggle navigation menu">
        <span class="app-nav-toggler-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="app-nav-scrollable @NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="app-nav-list" aria-label="Main navigation">

        <div class="app-nav-item">
            <NavLink href="/" Match="NavLinkMatch.All" class="app-nav-link">
                <Blazicon Svg="Lucide.House" class="app-nav-icon" />&nbsp;Accueil
            </NavLink>
        </div>

        <AuthorizeView Context="auth">
            <Authorized>
                <div class="app-nav-item">
                    <NavLink href="/profil" class="app-nav-link">
                        <Blazicon Svg="Lucide.User" class="app-nav-icon" />&nbsp;Mon Profil
                    </NavLink>
                </div>

                <AuthorizeView Roles="RestaurantOwner" Context="ownerCtx">
                    <div class="app-nav-item">
                        <NavLink href="/mes-restaurants" class="app-nav-link">
                            <Blazicon Svg="Lucide.UtensilsCrossed" class="app-nav-icon" />&nbsp;Mes Restaurants
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="app-nav-item">
                    <button class="app-nav-link btn-logout" @onclick="HandleLogout">
                        <Blazicon Svg="Lucide.LogOut" class="app-nav-icon" />&nbsp;Déconnexion
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="app-nav-item">
                    <NavLink href="/login" class="app-nav-link">
                        <Blazicon Svg="Lucide.LogIn" class="app-nav-icon" />&nbsp;Se connecter
                    </NavLink>
                </div>
                <div class="app-nav-item">
                    <NavLink href="/register" class="app-nav-link">
                        <Blazicon Svg="Lucide.UserPlus" class="app-nav-icon" />&nbsp;Créer son compte
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private bool _collapseNavMenu = true;
    private string? NavMenuCssClass => _collapseNavMenu ? "app-nav-collapse" : null;

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Nav.NavigateTo("/");
    }
}
