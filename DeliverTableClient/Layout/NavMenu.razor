@using System.Security.Claims
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="sidebar-header">
    <a class="sidebar-brand" href="/">
        <svg class="sidebar-brand-logo" viewBox="0 0 53 53" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path opacity="0.15" d="M26.4 48.3999C38.5503 48.3999 48.4 38.5502 48.4 26.3999C48.4 14.2496 38.5503 4.3999 26.4 4.3999C14.2498 4.3999 4.40002 14.2496 4.40002 26.3999C4.40002 38.5502 14.2498 48.3999 26.4 48.3999Z" stroke="#1A1A2E" stroke-width="0.88"/>
            <path d="M15.3998 29.9201C15.3998 21.1201 19.0665 15.8401 26.3998 14.0801C33.7332 15.8401 37.3998 21.1201 37.3998 29.9201" stroke="#E85D3A" stroke-width="1.1" stroke-linecap="round"/>
            <path d="M13.2 29.9199H39.6" stroke="#E85D3A" stroke-width="1.1" stroke-linecap="round"/>
            <path opacity="0.4" d="M21.9999 12.32C22.5865 10.56 22.5865 8.80004 21.9999 7.04004" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
            <path opacity="0.4" d="M26.4 11.4397C26.9866 9.67967 26.9866 7.91967 26.4 6.15967" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
            <path opacity="0.4" d="M30.8 12.32C31.3867 10.56 31.3867 8.80004 30.8 7.04004" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
            <path opacity="0.6" d="M26.4001 36.9599C27.3721 36.9599 28.1601 36.172 28.1601 35.1999C28.1601 34.2279 27.3721 33.4399 26.4001 33.4399C25.4281 33.4399 24.6401 34.2279 24.6401 35.1999C24.6401 36.172 25.4281 36.9599 26.4001 36.9599Z" fill="#E85D3A"/>
        </svg>
        <span class="sidebar-brand-text">Deliver<em>Table</em></span>
    </a>
    <button type="button" title="Navigation menu" class="sidebar-toggler"
            @onclick="ToggleNavMenu" aria-label="Toggle navigation menu">
        <span class="sidebar-toggler-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="sidebar-body sticky-top @NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="sidebar-nav">
        <span class="nav-section-label">Navigation</span>

        <div class="nav-item">
            <NavLink href="/" class="nav-link">
                <Blazicon Svg="Lucide.Search" class="nav-icon" />
                <span>Restaurants</span>
            </NavLink>
        </div>

        <AuthorizeView Context="auth">
            <Authorized>
                <div class="nav-item">
                    <NavLink href="/profil" class="nav-link">
                        <Blazicon Svg="Lucide.User" class="nav-icon" />
                        <span>Mon Profil</span>
                    </NavLink>
                </div>

                <AuthorizeView Roles="@nameof(UserRole.Customer)" Context="customerCtx">
                    <span class="nav-section-label">Commander</span>
                    <div class="nav-item">
                        <NavLink href="/mes-commandes" class="nav-link">
                            <Blazicon Svg="Lucide.ShoppingBag" class="nav-icon" />
                            <span>Mes Commandes</span>
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="@nameof(UserRole.RestaurantOwner)" Context="ownerCtx">
                    <div class="nav-item">
                        <NavLink href="/mes-restaurants" class="nav-link">
                            <Blazicon Svg="Lucide.UtensilsCrossed" class="nav-icon" />
                            <span>Mes Restaurants</span>
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink href="/mes-reclamations" class="nav-link">
                            <Blazicon Svg="Lucide.TriangleAlert" class="nav-icon" />
                            <span>Réclamations</span>
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="@nameof(UserRole.Administrator)" Context="adminCtx">
                    <span class="nav-section-label">Administration</span>
                    <div class="nav-group" @onmouseenter="() => OpenAdminSection(AdminSection.General)"
                         @onmouseleave="() => CloseAdminSection(AdminSection.General)">
                        <button type="button" class="nav-section-toggle"
                                @onclick="() => ToggleAdminSection(AdminSection.General)">
                            <Blazicon Svg="Lucide.Shield" class="nav-icon" />
                            <span>Général</span>
                            <Blazicon Svg="Lucide.ChevronDown"
                                       class="@($"nav-section-chevron {(IsAdminSectionOpen(AdminSection.General) ? "nav-section-chevron--open" : "")}")" />
                        </button>
                        <div class="nav-group-items @(IsAdminSectionOpen(AdminSection.General) ? "nav-group-items--open" : "")">
                            <div class="nav-group-inner">
                                <div class="nav-item">
                                    <NavLink href="/admin" Match="NavLinkMatch.All" class="nav-link">
                                        <Blazicon Svg="Lucide.LayoutDashboard" class="nav-icon" />
                                        <span>Tableau de bord</span>
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="nav-group" @onmouseenter="() => OpenAdminSection(AdminSection.Gestion)"
                         @onmouseleave="() => CloseAdminSection(AdminSection.Gestion)">
                        <button type="button" class="nav-section-toggle"
                                @onclick="() => ToggleAdminSection(AdminSection.Gestion)">
                            <Blazicon Svg="Lucide.Settings" class="nav-icon" />
                            <span>Gestion</span>
                            <Blazicon Svg="Lucide.ChevronDown"
                                       class="@($"nav-section-chevron {(IsAdminSectionOpen(AdminSection.Gestion) ? "nav-section-chevron--open" : "")}")" />
                        </button>
                        <div class="nav-group-items @(IsAdminSectionOpen(AdminSection.Gestion) ? "nav-group-items--open" : "")">
                            <div class="nav-group-inner">
                                <div class="nav-item">
                                    <NavLink href="/admin/users" class="nav-link">
                                        <Blazicon Svg="Lucide.Users" class="nav-icon" />
                                        <span>Utilisateurs</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/restaurants" class="nav-link">
                                        <Blazicon Svg="Lucide.UtensilsCrossed" class="nav-icon" />
                                        <span>Restaurants</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/dishes" class="nav-link">
                                        <Blazicon Svg="Lucide.ChefHat" class="nav-icon" />
                                        <span>Plats</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/orders" class="nav-link">
                                        <Blazicon Svg="Lucide.ShoppingBag" class="nav-icon" />
                                        <span>Commandes</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/promotions" class="nav-link">
                                        <Blazicon Svg="Lucide.Tag" class="nav-icon" />
                                        <span>Promotions</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/discount-codes" class="nav-link">
                                        <Blazicon Svg="Lucide.Ticket" class="nav-icon" />
                                        <span>Codes promo</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/loyalty" class="nav-link">
                                        <Blazicon Svg="Lucide.Heart" class="nav-icon" />
                                        <span>Fidélité</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/events" class="nav-link">
                                        <Blazicon Svg="Lucide.CalendarDays" class="nav-icon" />
                                        <span>Événements</span>
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="nav-group" @onmouseenter="() => OpenAdminSection(AdminSection.Finances)"
                         @onmouseleave="() => CloseAdminSection(AdminSection.Finances)">
                        <button type="button" class="nav-section-toggle"
                                @onclick="() => ToggleAdminSection(AdminSection.Finances)">
                            <Blazicon Svg="Lucide.Wallet" class="nav-icon" />
                            <span>Finances</span>
                            <Blazicon Svg="Lucide.ChevronDown"
                                       class="@($"nav-section-chevron {(IsAdminSectionOpen(AdminSection.Finances) ? "nav-section-chevron--open" : "")}")" />
                        </button>
                        <div class="nav-group-items @(IsAdminSectionOpen(AdminSection.Finances) ? "nav-group-items--open" : "")">
                            <div class="nav-group-inner">
                                <div class="nav-item">
                                    <NavLink href="/admin/transactions" class="nav-link">
                                        <Blazicon Svg="Lucide.ArrowLeftRight" class="nav-icon" />
                                        <span>Transactions</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/commission-statements" class="nav-link">
                                        <Blazicon Svg="Lucide.FileText" class="nav-icon" />
                                        <span>Relevés de commissions</span>
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="nav-group" @onmouseenter="() => OpenAdminSection(AdminSection.Supervision)"
                         @onmouseleave="() => CloseAdminSection(AdminSection.Supervision)">
                        <button type="button" class="nav-section-toggle"
                                @onclick="() => ToggleAdminSection(AdminSection.Supervision)">
                            <Blazicon Svg="Lucide.Eye" class="nav-icon" />
                            <span>Supervision</span>
                            <Blazicon Svg="Lucide.ChevronDown"
                                       class="@($"nav-section-chevron {(IsAdminSectionOpen(AdminSection.Supervision) ? "nav-section-chevron--open" : "")}")" />
                        </button>
                        <div class="nav-group-items @(IsAdminSectionOpen(AdminSection.Supervision) ? "nav-group-items--open" : "")">
                            <div class="nav-group-inner">
                                <div class="nav-item">
                                    <NavLink href="/admin/ratings" class="nav-link">
                                        <Blazicon Svg="Lucide.Star" class="nav-icon" />
                                        <span>Avis</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/reclamations" class="nav-link">
                                        <Blazicon Svg="Lucide.TriangleAlert" class="nav-icon" />
                                        <span>Réclamations</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/notifications" class="nav-link">
                                        <Blazicon Svg="Lucide.Bell" class="nav-icon" />
                                        <span>Notifications</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/moderation" class="nav-link">
                                        <Blazicon Svg="Lucide.ShieldAlert" class="nav-icon" />
                                        <span>Modération</span>
                                    </NavLink>
                                </div>
                                <div class="nav-item">
                                    <NavLink href="/admin/order-config" class="nav-link">
                                        <Blazicon Svg="Lucide.Settings" class="nav-icon" />
                                        <span>Configuration</span>
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>
                </AuthorizeView>
            
                <AuthorizeView Roles="@nameof(UserRole.RestaurantOwner)">
                    <div class="nav-item">
                        <NavLink href="/live" class="nav-link-live">
                            <Blazicon Svg="Lucide.Radio" class="nav-icon" />
                            <span>Service en direct</span>
                        </NavLink>
                    </div>
                </AuthorizeView>

                <span class="nav-section-label">Compte</span>

                <div class="nav-item">
                    <button class="nav-link nav-link-logout" @onclick="HandleLogout">
                        <Blazicon Svg="Lucide.LogOut" class="nav-icon" />
                        <span>Déconnexion</span>
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <span class="nav-section-label">Compte</span>

                <div class="nav-item">
                    <NavLink href="/login" class="nav-link">
                        <Blazicon Svg="Lucide.LogIn" class="nav-icon" />
                        <span>Se connecter</span>
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink href="/register" class="nav-link">
                        <Blazicon Svg="Lucide.UserPlus" class="nav-icon" />
                        <span>Créer son compte</span>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool _collapseNavMenu = true;
    private string? NavMenuCssClass => _collapseNavMenu ? "sidebar-collapse" : null;

    private enum AdminSection { General, Gestion, Finances, Supervision }

    private readonly HashSet<AdminSection> _openSections = new();

    private bool IsAdminSectionOpen(AdminSection section) => _openSections.Contains(section);

    private void ToggleAdminSection(AdminSection section)
    {
        if (!_openSections.Remove(section))
            _openSections.Add(section);
    }

    private void OpenAdminSection(AdminSection section) => _openSections.Add(section);

    private void CloseAdminSection(AdminSection section) => _openSections.Remove(section);

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Nav.NavigateTo("/");
    }
}
