<div class="reclamation-form">
    @if (_isReclamationSend)
    {
        <div class="empty-state">
            <p>Votre réclamation a bien été envoyée. Notre équipe va l'examiner rapidement.</p>
            <button type="button" class="app-btn app-btn--primary" @onclick="GoToOrders">
                Retour à mes commandes
            </button>
        </div>
    }
    else
    {
        <EditForm Model="@Reclamation" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="error-message">
                    <p>@_errorMessage</p>
                </div>
            }

            <div class="form-group">
                <label class="form-label" for="reclamation_type">Type de réclamation</label>
                <InputSelect id="reclamation_type" class="form-control" @bind-Value="Reclamation.Type">
                    @foreach ((string Name, string Value) type in _reclamationTypes)
                    {
                        <option value="@type.Value">@type.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label class="form-label" for="reclamation_description">Décrivez le problème rencontré</label>
                <InputTextArea
                    id="reclamation_description"
                    class="form-control"
                    rows="6"
                    @bind-Value="Reclamation.Description" />
                <ValidationMessage For="() => Reclamation.Description" />
            </div>

            <div class="reclamation-form__items">
                <p class="reclamation-form__hint">
                    Vous pouvez joindre une photo pour les articles concernés.
                </p>

                @foreach (OrderItemDto orderItemDto in Order.Items)
                {
                    <ReclamationItemFileUploader OrderItem="orderItemDto" OnItemChanged="HandleItemChanges" />
                }
            </div>

            <button type="submit" class="app-btn app-btn--primary" disabled="@_isSubmitting">
                @(_isSubmitting ? "Envoi en cours..." : "Envoyer la réclamation")
            </button>
        </EditForm>
    }
</div>
