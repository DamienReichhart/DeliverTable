@using DeliverTableSharedLibrary.Dtos.Restaurant
@inject NavigationManager Nav
@inject IRestaurantService RestaurantService

<EditForm Model="@_creationDto" OnValidSubmit="HandleCreation" class="restaurant-creation">
    <DataAnnotationsValidator/>
    <div class="col gap-1 mb-1">
        <label for="restaurant-name">Nom du restaurant</label>
        <InputText id="restaurant-name" @bind-Value="_creationDto.Name" class="app-input" placeholder="Nom du restaurant"/>
        <ValidationMessage For="@(() => _creationDto.Name)" class="validation-message" />
    </div>
    
    <div class="col gap-1 mb-1">
        <label for="restaurant-description">Description</label>
        <InputTextArea rows="5" id="restaurant-description" @bind-Value="_creationDto.Description" class="app-input" placeholder="Description du restaurant"/>
        <ValidationMessage For="@(() => _creationDto.Description)" class="validation-message" />
    </div>

    
    <div class="col gap-1 mb-1">
        <label for="restaurant-address1">Adresse du restaurant</label>
        <InputText id="restaurant-address1" @bind-Value="_creationDto.AdressLine1" class="app-input" placeholder="Adresse du restaurant"/>
        <ValidationMessage For="@(() => _creationDto.AdressLine1)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-address2">Complément d'adresse</label>
        <InputText id="restaurant-address2" @bind-Value="_creationDto.AdressLine2" class="app-input" placeholder="Complément d'adresse"/>
        <ValidationMessage For="@(() => _creationDto.AdressLine2)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-city">Ville</label>
        <InputText id="restaurant-city" @bind-Value="_creationDto.City" class="app-input" placeholder="Ville"/>
        <ValidationMessage For="@(() => _creationDto.City)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-ZipCode">Code Postal</label>
        <InputText id="restaurant-ZipCode" @bind-Value="_creationDto.ZipCode" class="app-input" placeholder="Code Postal"/>
        <ValidationMessage For="@(() => _creationDto.ZipCode)" class="validation-message"/>
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-Country">Pays</label>
        <InputSelect id="restaurant-Country" @bind-Value="_creationDto.Country" class="app-input">
        <option value="">-- Sélectionnez un type --</option>
        @foreach (AvailableCountries country in Enum.GetValues<AvailableCountries>())
        {
            <option value="@country">@country.ToString()</option>
        }
        </InputSelect>
        <ValidationMessage For="@(() => _creationDto.Country)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-type">Type de restaurant</label>
        <InputSelect id="restaurant-type" @bind-Value="_creationDto.Type" class="app-input">
        <option value="">-- Sélectionnez un type de restauration --</option>
        @foreach (RestaurantType type in Enum.GetValues<RestaurantType>())
        {
            <option value="@type">@type.ToString()</option>
        }
        </InputSelect>
        <ValidationMessage For="@(() => _creationDto.Type)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-siret">Numéro SIRET</label>
        <InputText id="restaurant-siret" @bind-Value="_creationDto.Siret" class="app-input" placeholder="14 chiffres" maxlength="14" />
        <ValidationMessage For="@(() => _creationDto.Siret)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-legal-name">Raison sociale</label>
        <InputText id="restaurant-legal-name" @bind-Value="_creationDto.LegalName" class="app-input" placeholder="Raison sociale" />
        <ValidationMessage For="@(() => _creationDto.LegalName)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-legal-address">Adresse légale</label>
        <InputText id="restaurant-legal-address" @bind-Value="_creationDto.LegalAddress" class="app-input" placeholder="Adresse légale" />
        <ValidationMessage For="@(() => _creationDto.LegalAddress)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label for="restaurant-legal-form">Forme juridique</label>
        <InputSelect id="restaurant-legal-form" @bind-Value="_creationDto.LegalForm" class="app-input">
            <option value="">-- Sélectionnez une forme juridique --</option>
            <option value="SAS">SAS</option>
            <option value="SARL">SARL</option>
            <option value="EURL">EURL</option>
            <option value="EI">EI</option>
            <option value="SA">SA</option>
        </InputSelect>
        <ValidationMessage For="@(() => _creationDto.LegalForm)" class="validation-message" />
    </div>

    <div class="col gap-1 mb-1">
        <label class="row gap-1">
            <InputCheckbox @bind-Value="_creationDto.IsVatRegistered" id="restaurant-vat-registered" />
            <span>TVA applicable</span>
        </label>
    </div>

    @if (_creationDto.IsVatRegistered)
    {
        <div class="col gap-1 mb-1">
            <label for="restaurant-vat-number">Numéro de TVA</label>
            <InputText id="restaurant-vat-number" @bind-Value="_creationDto.VatNumber" class="app-input" placeholder="FR12345678901" maxlength="20" />
            <ValidationMessage For="@(() => _creationDto.VatNumber)" class="validation-message" />
        </div>
    }

    <button type="submit" class="app-btn mx-auto flex mt-1" disabled="@_isSubmitting">
        @if (_isSubmitting)
        {
            <span class="spinner-border spinner-border-sm"></span> <span> Vérification des informations ...</span>
        }
        else
        {
            <span>Création</span>
        }
    </button>
</EditForm>
@code
{
    private CreateRestaurantDto _creationDto = new CreateRestaurantDto ();
    private string? _errorMessage;
    private bool _isSubmitting = false;

    private async Task HandleCreation()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var (success, error) = await RestaurantService.CreateRestaurant(_creationDto);
            if (success)
            {
                Nav.NavigateTo(uri: "/profil");
                return;
            }

            _errorMessage = error?.Error ?? "Une erreur est survenue lors de la création du restaurant.";
        }
        catch
        {
            _errorMessage = "Une erreur est survenue lors de la création du restaurant.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}