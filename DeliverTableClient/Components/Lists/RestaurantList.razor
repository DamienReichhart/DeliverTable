@using DeliverTableSharedLibrary.Dtos.Restaurant
@inject IRestaurantService RestaurantService

<ul class="restaurant-list">
    @if (_restaurants == null && !_loading)
    {
        <li class="empty-state">Aucun restaurant trouvé.</li>
    }
    else if (_loading)
    {
        <li class="loading-state">Chargement...</li>
    }
    else if (_error is not null)
    {
        <li><AppAlert>@_error</AppAlert></li>
    }
    else
    {
        @foreach (var restaurant in _restaurants!)
        {
            <li class="restaurant-card">
                <div class="restaurant-card-content">
                    <h3>@restaurant.Name</h3>
                    <p>@restaurant.ZipCode @restaurant.City</p>
                </div>

                <AppDropdown Label="Gérer">
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/commandes")" Icon="Lucide.ShoppingBag">
                        Commandes
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/promotions")" Icon="Lucide.Tag">
                        Promotions
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/evenements")" Icon="Lucide.CalendarDays">
                        Évènements
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/codes-promo")" Icon="Lucide.Ticket">
                        Codes promo
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/fidelite")" Icon="Lucide.Heart">
                        Fidélité
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/creneau")" Icon="Lucide.CalendarX2">
                        Créneaux
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/{restaurant.Id}/compte")" Icon="Lucide.Wallet">
                        Compte
                    </AppDropdownItem>
                    <AppDropdownItem Href="@($"/restaurant/update/{restaurant.Id}")" Icon="Lucide.Pencil">
                        Modifier
                    </AppDropdownItem>
                    <AppDropdownSeparator />
                    <AppDropdownItem Icon="Lucide.Trash2" Danger="true"
                                     OnClick="@(() => DeleteRestaurant(restaurant.Id))">
                        Supprimer
                    </AppDropdownItem>
                </AppDropdown>
            </li>
        }
    }
</ul>

@code {
    private List<RestaurantDto>? _restaurants;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var (result, errorObject) = await RestaurantService.GetConnectedUserRestaurants();

            if (errorObject != null)
                _error = errorObject.Error;
            else
                _restaurants = result?.Items.ToList();
        }
        catch
        {
            _error = "Une erreur est survenue";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteRestaurant(int id)
    {
        _error = null;

        try
        {
            var (success, error) = await RestaurantService.DeleteRestaurant(id);

            if (success)
                _restaurants?.RemoveAll(r => r.Id == id);
            else
                _error = error?.Error ?? "Erreur lors de la suppression du restaurant";
        }
        catch
        {
            _error = "Erreur lors de la suppression du restaurant";
        }
    }
}
