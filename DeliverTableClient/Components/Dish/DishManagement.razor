@using DeliverTableClient.Components.Modales
@using DeliverTableSharedLibrary.Dtos.Dish
@using DeliverTableSharedLibrary.Dtos
@using DeliverTableSharedLibrary.Enums
@using DeliverTableClient.Services.Interfaces
@inject IDishService DishService

<div class="dish-management-container mt-5">
    <h3>Gestion des Plats</h3>

    @if (loading)
    {
        <p>Chargement des plats...</p>
    }
    else if (error != null)
    {
        <div class="alert alert-danger">@error</div>
    }
    else
    {
        @if (dishes != null && dishes.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Prix</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dish in dishes)
                        {
                            <tr>
                                <td>@dish.Name</td>
                                <td>@dish.BasePrice.ToString("C")</td>
                                <td>
                                    @if(dish.IsDishOfTheDay) { <span class="badge bg-success me-1">Plat du jour</span> }
                                    @if(dish.IsVegetarian) { <span class="badge bg-success me-1">Végétarien</span> }
                                    @if(dish.IsVegan) { <span class="badge bg-success me-1">Vegan</span> }
                                    @if(dish.IsGlutenFree) { <span class="badge bg-info me-1">Sans gluten</span> }
                                    @if(!dish.IsActive) { <span class="badge bg-secondary">Inactif</span> }
                                </td>
                                <td>
                                    <button class="app-btn btn-sm btn-primary me-2" @onclick="() => EditDish(dish)">Modifier</button>
                                    <button class="app-btn btn-sm btn-danger" @onclick="() => DeleteDish(dish.Id)">Supprimer</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p>Aucun plat n'a été ajouté pour ce restaurant.</p>
        }

        <button class="app-btn mt-1" @onclick="ShowAddForm" disabled="@isFormVisible">
            Ajouter un plat
        </button>

        @if (isFormVisible)
        {
            <StandardModale Title="@(isEditing ? "Modifier le plat" : "Nouveau plat")">
            <div class="card mt-4">
                <div class="card-body">
                    <EditForm Model="currentDish" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="form-group mb-3">
                            <label>Nom du plat</label>
                            <InputText class="form-control" @bind-Value="currentDish.Name" />
                            <ValidationMessage For="@(() => currentDish.Name)" />
                        </div>
                        
                        <div class="form-group mb-3">
                            <label>Description</label>
                            <InputTextArea class="form-control" @bind-Value="currentDish.Description" rows="3"/>
                        </div>
                        
                        <div>
                            <div class="mb-3">
                                <label>Prix de base (€)</label>
                                <InputNumber class="form-control" @bind-Value="currentDish.BasePrice" step="0.01" />
                                <ValidationMessage For="@(() => currentDish.BasePrice)" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="currentDish.IsVegetarian" id="isVegetarian" />
                                    <label class="form-check-label" for="isVegetarian">Végétarien</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="currentDish.IsVegan" id="isVegan" />
                                    <label class="form-check-label" for="isVegan">Vegan</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="currentDish.IsGlutenFree" id="isGlutenFree" />
                                    <label class="form-check-label" for="isGlutenFree">Sans gluten</label>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="currentDish.IsAllergenHazard" id="isAllergenHazard" />
                                    <label class="form-check-label" for="isAllergenHazard">Risque d'allergène</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="currentDish.IsDishOfTheDay" id="isDishOfTheDay" />
                                    <label class="form-check-label" for="isDishOfTheDay">Plat du jour</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-field">
                            <label for="vat-rate">Taux de TVA</label>
                            <select id="vat-rate" class="form-control mb-3" @bind="currentDish.VatRate">
                                <option value="@VatRate.Zero">0 % (Zéro)</option>
                                <option value="@VatRate.Special2_1">2,1 % (Spécial)</option>
                                <option value="@VatRate.Reduced5_5">5,5 % (Réduit)</option>
                                <option value="@VatRate.Intermediate10">10 % (Intermédiaire)</option>
                                <option value="@VatRate.Normal20">20 % (Normal)</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label>Image du plat (Optionnel)</label>
                            <InputFile class="form-control" OnChange="HandleImageSelected" accept="image/*" />
                        </div>

                        @if (formError != null)
                        {
                            <div class="alert alert-danger">@formError</div>
                        }

                        <div class="mt-3">
                            <button type="submit" class="app-btn me-2" disabled="@isSubmitting">
                                @(isSubmitting ? "Enregistrement..." : "Enregistrer")
                            </button>
                            <button type="button" class="app-btn bg-secondary" @onclick="CancelForm" disabled="@isSubmitting">
                                Annuler
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
            </StandardModale>
        }
    }
</div>
