        </NavLink>

        <span class="adm-sidebar-section">Finances</span>

        <NavLink href="/admin/transactions" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.ArrowLeftRight" class="adm-sidebar-icon" />
