@inject NavigationManager Nav

<aside class="adm-sidebar">
    <div class="adm-sidebar-header">
        <a href="/admin" class="adm-sidebar-brand">
            <Blazicon Svg="Lucide.Shield" class="adm-sidebar-brand-icon" />
            <span class="adm-sidebar-brand-text">Administration</span>
        </a>
    </div>

    <nav class="adm-sidebar-nav">
        <span class="adm-sidebar-section">Général</span>

        <NavLink href="/admin" Match="NavLinkMatch.All" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.LayoutDashboard" class="adm-sidebar-icon" />
            <span>Tableau de bord</span>
        </NavLink>

        <span class="adm-sidebar-section">Gestion</span>

        <NavLink href="/admin/users" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.Users" class="adm-sidebar-icon" />
            <span>Utilisateurs</span>
        </NavLink>

        <NavLink href="/admin/restaurants" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.UtensilsCrossed" class="adm-sidebar-icon" />
            <span>Restaurants</span>
        </NavLink>

        <NavLink href="/admin/dishes" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.ChefHat" class="adm-sidebar-icon" />
