        </NavLink>

        <NavLink href="/admin/orders" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.ShoppingBag" class="adm-sidebar-icon" />
            <span>Commandes</span>
        </NavLink>

        <NavLink href="/admin/promotions" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.Tag" class="adm-sidebar-icon" />
