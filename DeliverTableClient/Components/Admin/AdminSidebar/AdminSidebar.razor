        </NavLink>

        <NavLink href="/admin/order-config" class="adm-sidebar-link">
            <Blazicon Svg="Lucide.Settings" class="adm-sidebar-icon" />
            <span>Configuration</span>
        </NavLink>
    </nav>

    <div class="adm-sidebar-footer">
        <a href="/" class="adm-sidebar-link adm-sidebar-link--back">
            <Blazicon Svg="Lucide.ArrowLeft" class="adm-sidebar-icon" />
            <span>Retour au site</span>
        </a>
