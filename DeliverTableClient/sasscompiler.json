{
  "Source": "Styles",
  "Target": "wwwroot/css",
  "Arguments": "--error-css",
  "GenerateScopedCss": true,
  "ScopedCssFolders": ["Pages", "Layout", "Components", "Shared"],
  "IncludePaths": [],
  "Configurations": {
    "Debug": {
      "Arguments": "--style=expanded --error-css"
    },
    "Release": {
      "Arguments": "--style=compressed --error-css"
    }
  }
}
