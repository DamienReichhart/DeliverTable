@page "/restaurants"
@inject IRestaurantService RestaurantService
@inject NavigationManager Nav
@inject IJSRuntime Js
@using DeliverTableSharedLibrary.Dtos.Restaurant
@using DeliverTableClient.Pages.Explore.Restaurants.RestaurantMap

<PageTitle>Restaurants — DeliverTable</PageTitle>

<div class="restaurants-page">
    <h1>Découvrir les restaurants</h1>

    <div class="restaurants-filters">
        <div class="filter-row">
            <input type="text" placeholder="Rechercher un restaurant..." @bind="_query.Name" @bind:event="oninput"
                   @onkeydown="HandleKeyDown" class="filter-input" />
            <select @bind="_query.Type" class="filter-select">
                <option value="">Tous les types</option>
                @foreach (var type in Enum.GetValues<RestaurantType>())
                {
                    <option value="@type.ToString()">@type</option>
                }
            </select>
            @if (!_showMap)
            {
                <button type="button" class="app-btn app-btn--primary" @onclick="SearchRestaurants">
                    Rechercher
                </button>
            }
            else
            {
                <button type="button" class="app-btn app-btn--primary" @onclick="OnFiltersSearchClicked">
                    Rechercher
                </button>
            }
            <button type="button" class="app-btn app-btn--secondary map-toggle-btn" @onclick="ToggleMapView">
                @(_showMap ? "Liste" : "Carte")
            </button>
        </div>
    </div>

    @if (_showMap)
    {
        <RestaurantMap @ref="_mapRef" NameFilter="@_query.Name" TypeFilter="@_query.Type" />
    }
    else
    {
        @if (_loading)
        {
            <div class="loading-container">
                <p>Chargement des restaurants...</p>
            </div>
        }
        else if (_error is not null)
        {
            <div class="error-message">
                <p>@_error</p>
            </div>
        }
        else if (_restaurants is null || _restaurants.Items.Count == 0)
        {
            <div class="empty-state">
                <p>Aucun restaurant trouvé.</p>
            </div>
        }
        else
        {
            <div class="restaurants-grid">
                @foreach (var restaurant in _restaurants.Items)
                {
                    <div class="restaurant-card" @onclick="() => NavigateToRestaurant(restaurant.Id)">
                        <div class="restaurant-card-header">
                            <h3>@restaurant.Name</h3>
                            <span class="restaurant-type-badge">@restaurant.Type</span>
                        </div>
                        <div class="restaurant-card-body">
                            <p class="restaurant-location">@restaurant.City, @restaurant.ZipCode</p>
                        </div>
                    </div>
                }
            </div>

            @if (_restaurants.HasNextPage)
            {
                <div class="pagination">
                    @if (_query.PageNumber > 1)
                    {
                        <button type="button" class="app-btn app-btn--secondary" @onclick="PreviousPage">Précédent</button>
                    }
                    <span class="page-info">Page @_query.PageNumber</span>
                    <button type="button" class="app-btn app-btn--secondary" @onclick="NextPage">Suivant</button>
                </div>
            }
            else if (_query.PageNumber > 1)
            {
                <div class="pagination">
                    <button type="button" class="app-btn app-btn--secondary" @onclick="PreviousPage">Précédent</button>
                    <span class="page-info">Page @_query.PageNumber</span>
                </div>
            }
        }
    }
</div>

@code {
    private PaginatedResult<RestaurantDto>? _restaurants;
    private RestaurantQuery _query = new() { PageSize = 12 };
    private bool _loading = true;
    private string? _error;
    private bool _showMap;
    private RestaurantMap? _mapRef;

    protected override async Task OnInitializedAsync()
    {
        await SearchRestaurants();
    }

    private void ToggleMapView()
    {
        _showMap = !_showMap;
    }

    private void OnFiltersSearchClicked()
    {
        _mapRef?.OnFiltersChanged();
    }

    private async Task SearchRestaurants()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var (result, err) = await RestaurantService.GetAllRestaurants(_query);
            if (err is not null)
            {
                _error = err.Error;
            }
            else
            {
                _restaurants = result;
            }
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _query.PageNumber = 1;
            if (_showMap)
                _mapRef?.OnFiltersChanged();
            else
                await SearchRestaurants();
        }
    }

    private async Task NextPage()
    {
        _query.PageNumber++;
        await SearchRestaurants();
    }

    private async Task PreviousPage()
    {
        if (_query.PageNumber > 1)
        {
            _query.PageNumber--;
            await SearchRestaurants();
        }
    }

    private void NavigateToRestaurant(int id)
    {
        Nav.NavigateTo($"/restaurant/{id}");
    }
}
