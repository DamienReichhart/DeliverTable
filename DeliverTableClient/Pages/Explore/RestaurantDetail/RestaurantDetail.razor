@page "/restaurant/{Id:int}"
@inject IRestaurantService RestaurantService
@inject IRestaurantEventService EventService
@inject IDishService DishService
@inject ICartService CartService
@inject NavigationManager Nav
@inject IJSRuntime Js
@implements IAsyncDisposable
@using DeliverTableSharedLibrary.Dtos.Restaurant
@using DeliverTableSharedLibrary.Dtos.Dish
@using DeliverTableSharedLibrary.Dtos.Cart
@using DeliverTableSharedLibrary.Dtos.Event

<PageTitle>@(_restaurant?.Name ?? "Restaurant") — DeliverTable</PageTitle>

<div class="restaurant-detail-page">
    @if (_loading)
    {
        <div class="loading-container centered">
            <p>Chargement du restaurant...</p>
        </div>
    }
    else if (_error is not null)
    {
        <div class="error-message centered">
            <Blazicon Svg="Lucide.BadgeAlert" class="app-icon" />
            <p>@_error</p>
        </div>
    }
    else if (_restaurant is not null)
    {
        <div class="restaurant-header">
            <div class="restaurant-header-info">
                <span class="restaurant-type-badge">@_restaurant.Type</span>
                <h1>@_restaurant.Name</h1>
                <p class="restaurant-description">@_restaurant.Description</p>
                <p class="restaurant-address">
                    <Blazicon Svg="Lucide.MapPin" class="app-icon" />
                    <span>
                        @_restaurant.AdressLine1
                        @if (!string.IsNullOrWhiteSpace(_restaurant.AdressLine2))
                        {
                            <br />@_restaurant.AdressLine2
                        }
                        <br />@_restaurant.ZipCode @_restaurant.City
                    </span>
                </p>
            </div>

            <AuthorizeView Roles="@nameof(UserRole.Customer)">
                <div class="cart-summary-bar">
                    @if (_cart is not null && _cart.TotalItems > 0)
                    {
                        <div class="cart-mini">
                            <div class="cart-info">
                                <span>Votre panier</span>
                                <strong>@_cart.TotalItems article(s) — @_cart.TotalAmount.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))</strong>
                            </div>
                            <button type="button" class="app-btn app-btn--primary" @onclick="GoToCart">
                                <Blazicon Svg="Lucide.ShoppingBag" /> Voir le panier
                            </button>
                        </div>
                    }
                </div>
            </AuthorizeView>
        </div>

        @if (_restaurant.Latitude != 0 || _restaurant.Longitude != 0)
        {
            <div class="restaurant-location-map">
                <div id="restaurant-detail-map" class="restaurant-detail-map-element"></div>
            </div>
        }

        <div class="dishes-section">
            <h2>La carte</h2>

            <div class="dishes-filters">
                <div class="filter-search">
                    <Blazicon Svg="Lucide.Search" class="search-icon" />
                    <input type="text" placeholder="Rechercher un plat..." @bind="_dishQuery.Name" @bind:event="oninput"
                           @onkeydown="HandleDishKeyDown" class="filter-input" />
                </div>
                <div class="filter-group">
                    <label class="filter-checkbox">
                        <input type="checkbox" @bind="_filterVegetarian" @bind:after="FilterDishes" />
                        <span>Végétarien</span>
                    </label>
                    <label class="filter-checkbox">
                        <input type="checkbox" @bind="_filterVegan" @bind:after="FilterDishes" />
                        <span>Végan</span>
                    </label>
                    <label class="filter-checkbox">
                        <input type="checkbox" @bind="_filterGlutenFree" @bind:after="FilterDishes" />
                        <span>Sans gluten</span>
                    </label>
                </div>
            </div>

            @foreach (var evt in _events)
            {
                <section class="special-dishes-section event-section">
                    <div class="special-dishes-header">
                        <span class="special-dishes-kicker">Évènement</span>
                        <h2>@evt.Name</h2>
                        <p class="event-period">
                            <Blazicon Svg="Lucide.CalendarDays" class="app-icon" />
                            <span>Du @evt.StartsAt.ToString("dd/MM/yyyy") au @evt.EndsAt.ToString("dd/MM/yyyy")</span>
                        </p>
                        @if (!string.IsNullOrWhiteSpace(evt.Description))
                        {
                            <p>@evt.Description</p>
                        }
                    </div>

                    @if (evt.MenuItems.Count > 0)
                    {
                        <div class="dishes-grid dishes-grid--special">
                            @foreach (var item in evt.MenuItems)
                            {
                                var dish = item.Dish;
                                var price = item.OverridePrice ?? dish.BasePrice;
                                <div class="dish-card dish-card--special">
                                    <div class="dish-card-img">
                                        @if (!string.IsNullOrEmpty(dish.Image))
                                        {
                                            <img src="@dish.Image" alt="@dish.Name" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="dish-placeholder">
                                                <Blazicon Svg="Lucide.CameraOff" />
                                            </div>
                                        }
                                    </div>

                                    <div class="dish-card-body">
                                        <span class="special-dish-pill">@evt.Name</span>
                                        <h3>@dish.Name</h3>
                                        <p class="dish-description">@dish.Description</p>
                                        <div class="dish-tags">
                                            @if (dish.IsVegetarian)
                                            {
                                                <span class="tag tag--green">Végétarien</span>
                                            }
                                            @if (dish.IsVegan)
                                            {
                                                <span class="tag tag--green">Végan</span>
                                            }
                                            @if (dish.IsGlutenFree)
                                            {
                                                <span class="tag tag--blue">Sans gluten</span>
                                            }
                                            @if (dish.IsAllergenHazard)
                                            {
                                                <span class="tag tag--red">Allergènes</span>
                                            }
                                        </div>
                                        <div class="dish-card-footer">
                                            <span class="dish-price">
                                                @price.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))
                                                @if (item.OverridePrice.HasValue && item.OverridePrice.Value != dish.BasePrice)
                                                {
                                                    <span class="dish-price-original">@dish.BasePrice.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))</span>
                                                }
                                            </span>

                                            <AuthorizeView Roles="@nameof(UserRole.Customer)">
                                                <div class="add-to-cart-controls">
                                                    <div class="quantity-selector">
                                                        <button type="button" class="qty-btn" @onclick="() => DecrementQuantity(dish.Id)">−</button>
                                                        <span class="qty-value">@GetQuantity(dish.Id)</span>
                                                        <button type="button" class="qty-btn" @onclick="() => IncrementQuantity(dish.Id)">+</button>
                                                    </div>
                                                    <button type="button" class="app-btn app-btn--primary app-btn--sm"
                                                            @onclick="() => AddToCart(dish)" disabled="@_addingToCart">
                                                        <Blazicon Svg="Lucide.Plus" />
                                                    </button>
                                                </div>
                                            </AuthorizeView>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>
            }

            @if (_dishesLoading)
            {
                <div class="loading-container centered">
                    <p>Chargement des délices...</p>
                </div>
            }
            else if (_dishes is null || VisibleDishes.Count == 0)
            {
                <div class="empty-state centered">
                    <Blazicon Svg="Lucide.Utensils" class="app-icon" />
                    <p>@(_events.Count > 0 ? "Aucun autre plat disponible dans la carte pour le moment." : "Aucun plat disponible pour le moment.")</p>
                </div>
            }
            else
            {
                <div class="dishes-grid">
                    @foreach (var dish in VisibleDishes)
                    {
                        <div class="dish-card">
                            <div class="dish-card-img">
                                @if (!string.IsNullOrEmpty(dish.Image))
                                {
                                    <img src="@dish.Image" alt="@dish.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="dish-placeholder">
                                        <Blazicon Svg="Lucide.CameraOff" />
                                    </div>
                                }
                            </div>
                            <div class="dish-card-body">
                                <h3>@dish.Name</h3>
                                <p class="dish-description">@dish.Description</p>
                                <div class="dish-tags">
                                    @if (dish.IsVegetarian) { <span class="tag tag--green">Végétarien</span> }
                                    @if (dish.IsVegan) { <span class="tag tag--green">Végan</span> }
                                    @if (dish.IsGlutenFree) { <span class="tag tag--blue">Sans gluten</span> }
                                    @if (dish.IsAllergenHazard) { <span class="tag tag--red">Allergènes</span> }
                                    @if (dish.IsDishOfTheDay) { <span class="tag tag--orange">Plat du jour</span> }
                                </div>
                                <div class="dish-card-footer">
                                    <span class="dish-price">@dish.BasePrice.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))</span>

                                    <AuthorizeView Roles="@nameof(UserRole.Customer)">
                                        <div class="add-to-cart-controls">
                                            <div class="quantity-selector">
                                                <button type="button" class="qty-btn" @onclick="() => DecrementQuantity(dish.Id)">−</button>
                                                <span class="qty-value">@GetQuantity(dish.Id)</span>
                                                <button type="button" class="qty-btn" @onclick="() => IncrementQuantity(dish.Id)">+</button>
                                            </div>
                                            <button type="button" class="app-btn app-btn--primary app-btn--sm"
                                                    @onclick="() => AddToCart(dish)" disabled="@_addingToCart">
                                                <Blazicon Svg="Lucide.Plus" />
                                            </button>
                                        </div>
                                    </AuthorizeView>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (_dishes.HasNextPage || _dishQuery.PageNumber > 1)
                {
                    <div class="pagination">
                        @if (_dishQuery.PageNumber > 1)
                        {
                            <button type="button" class="app-btn app-btn--secondary" @onclick="PreviousDishPage">Précédent</button>
                        }
                        <span class="page-info">Page @_dishQuery.PageNumber</span>
                        @if (_dishes.HasNextPage)
                        {
                            <button type="button" class="app-btn app-btn--secondary" @onclick="NextDishPage">Suivant</button>
                        }
                    </div>
                }
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(_cartMessage))
        {
            <div class="toast-message @(_cartMessageIsError ? "toast--error" : "toast--success")">
                @_cartMessage
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private DetailedRestaurantDto? _restaurant;
    private PaginatedResult<DishDto>? _dishes;
    private CartDto? _cart;
    private DishQuery _dishQuery = new() { PageSize = 50 };
    private bool _loading = true;
    private bool _dishesLoading = true;
    private bool _addingToCart;
    private string? _error;
    private string? _cartMessage;
    private bool _cartMessageIsError;
    private bool _filterVegetarian;
    private bool _filterVegan;
    private bool _filterGlutenFree;
    private List<RestaurantEventResponse> _events = [];
    private HashSet<int> _eventDishIds = [];
    private Dictionary<int, int> _quantities = new();
    private bool _mapInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_mapInitialized && _restaurant is not null
            && (_restaurant.Latitude != 0 || _restaurant.Longitude != 0))
        {
            _mapInitialized = true;
            await Js.InvokeVoidAsync("restaurantDetailMap.init", "restaurant-detail-map",
                _restaurant.Latitude, _restaurant.Longitude, _restaurant.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRestaurant();
        await LoadEvents();
        await Task.WhenAll(LoadDishes(), LoadCart());
    }

    private async Task LoadRestaurant()
    {
        _loading = true;
        var (restaurant, error) = await RestaurantService.GetRestaurantById(Id);
        if (error is not null)
        {
            _error = error.Error;
        }
        else
        {
            _restaurant = restaurant;
        }
        _loading = false;
    }

    private async Task LoadEvents()
    {
        try
        {
            var (events, _) = await EventService.GetActiveByRestaurantAsync(Id);
            _events = events ?? [];

            // Avoid showing event dishes twice (once in the event section, once in the full menu).
            _eventDishIds = _events
                .SelectMany(e => e.MenuItems.Select(mi => mi.DishId))
                .ToHashSet();
        }
        catch
        {
            _events = [];
            _eventDishIds = [];
        }
    }

    private IReadOnlyList<DishDto> VisibleDishes => _dishes is null
        ? []
        : _dishes.Items.Where(dish => !_eventDishIds.Contains(dish.Id)).ToList();

    private async Task LoadDishes()
    {
        _dishesLoading = true;
        StateHasChanged();

        _dishQuery.IsVegetarian = _filterVegetarian ? true : null;
        _dishQuery.IsVegan = _filterVegan ? true : null;
        _dishQuery.IsGlutenFree = _filterGlutenFree ? true : null;

        var (dishes, err) = await DishService.GetDishesByRestaurantId(Id, _dishQuery);
        if (err is null)
        {
            _dishes = dishes;
        }
        _dishesLoading = false;
        StateHasChanged();
    }

    private async Task LoadCart()
    {
        try
        {
            var (cart, _) = await CartService.GetCartAsync(Id);
            _cart = cart;
        }
        catch
        {
            // Cart might not exist yet, that's fine
        }
        StateHasChanged();
    }

    private int GetQuantity(int dishId)
    {
        return _quantities.TryGetValue(dishId, out var qty) ? qty : 1;
    }

    private void IncrementQuantity(int dishId)
    {
        if (!_quantities.ContainsKey(dishId))
            _quantities[dishId] = 1;
        if (_quantities[dishId] < 99)
            _quantities[dishId]++;
    }

    private void DecrementQuantity(int dishId)
    {
        if (!_quantities.ContainsKey(dishId))
            _quantities[dishId] = 1;
        if (_quantities[dishId] > 1)
            _quantities[dishId]--;
    }

    private async Task AddToCart(DishDto dish)
    {
        _addingToCart = true;
        _cartMessage = null;
        StateHasChanged();

        var request = new AddToCartRequest
        {
            RestaurantId = Id,
            DishId = dish.Id,
            Quantity = GetQuantity(dish.Id)
        };

        var (cart, error) = await CartService.AddItemAsync(request);
        if (error is not null)
        {
            _cartMessage = error.Error;
            _cartMessageIsError = true;
        }
        else
        {
            _cart = cart;
            _cartMessage = $"{dish.Name} ajouté au panier";
            _cartMessageIsError = false;
            _quantities[dish.Id] = 1;
        }

        _addingToCart = false;
        StateHasChanged();

        // Auto-dismiss toast
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            _cartMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task FilterDishes()
    {
        _dishQuery.PageNumber = 1;
        await LoadDishes();
    }

    private async Task HandleDishKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _dishQuery.PageNumber = 1;
            await LoadDishes();
        }
    }

    private async Task NextDishPage()
    {
        _dishQuery.PageNumber++;
        await LoadDishes();
    }

    private async Task PreviousDishPage()
    {
        if (_dishQuery.PageNumber > 1)
        {
            _dishQuery.PageNumber--;
            await LoadDishes();
        }
    }

    private void GoToCart()
    {
        Nav.NavigateTo($"/panier/{Id}");
    }

    public async ValueTask DisposeAsync()
    {
        if (_mapInitialized)
        {
            try
            {
                await Js.InvokeVoidAsync("restaurantDetailMap.dispose");
            }
            catch (JSDisconnectedException) { }
        }
    }
}
