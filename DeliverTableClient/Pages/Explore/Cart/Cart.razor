@page "/panier/{RestaurantId:int}"
@inject ICartService CartService
@inject IRestaurantService RestaurantService
@inject IRestaurantOrderConfigClientService RestaurantOrderConfigService
@inject IPromotionService PromotionService
@inject IDiscountCodeClientService DiscountCodeService
@inject ILoyaltyClientService LoyaltyService
@inject NavigationManager Nav
@inject DeliverTableClient.State.CheckoutState CheckoutState
@attribute [Authorize(Roles = nameof(UserRole.Customer))]
@using DeliverTableSharedLibrary.Dtos.Cart
@using DeliverTableSharedLibrary.Dtos.Restaurant

<PageTitle>Panier — DeliverTable</PageTitle>

<div class="cart-page">
    <h1>Mon panier</h1>

    @if (_loading)
    {
        <p>Chargement du panier...</p>
    }
    else if (_error is not null)
    {
        <div class="error-message">
            <p>@_error</p>
        </div>
    }
    else if (_cart is null || _cart.Items.Count == 0)
    {
        <div class="empty-state">
            <p>Votre panier est vide.</p>
            <button type="button" class="app-btn app-btn--primary" @onclick="GoToRestaurant">
                Retour au restaurant
            </button>
        </div>
    }
    else
    {
        <header class="cart-restaurant-info">
            <div class="cart-restaurant-info__heading">
                <span class="cart-restaurant-info__badge">Commande chez</span>
                <h2>@_cart.RestaurantName</h2>
            </div>
            <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="GoToRestaurant">
                Continuer les achats
            </button>
        </header>

        @* ── Cart items ── *@
        <div class="cart-items">
            @foreach (var item in _cart.Items)
            {
                <div class="cart-item">
                    <div class="cart-item-img">
                        <img src="@item.DishImage" alt="@item.DishName" loading="lazy"
                             onerror="this.style.display='none'" />
                    </div>
                    <div class="cart-item-info">
                        <h3>@item.DishName</h3>
                        <p class="cart-item-price">@item.UnitPrice.ToString("C", _frCulture) / unité</p>
                        @if (!string.IsNullOrWhiteSpace(item.SpecialInstructions))
                        {
                            <p class="cart-item-instructions">@item.SpecialInstructions</p>
                        }
                    </div>
                    <div class="cart-item-actions">
                        <div class="quantity-selector">
                            <button type="button" class="qty-btn" @onclick="() => UpdateQuantity(item, item.Quantity - 1)"
                                    disabled="@(item.Quantity <= 1)">−</button>
                            <span class="qty-value">@item.Quantity</span>
                            <button type="button" class="qty-btn" @onclick="() => UpdateQuantity(item, item.Quantity + 1)"
                                    disabled="@(item.Quantity >= 99)">+</button>
                        </div>
                        <span class="cart-item-subtotal">@item.Subtotal.ToString("C", _frCulture)</span>
                        <button type="button" class="app-btn app-btn--danger app-btn--sm" @onclick="() => RemoveItem(item.Id)">
                            Supprimer
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="cart-summary">

            @* ── Active promotions banner ── *@
            @if (_activePromotions is not null && _activePromotions.Count > 0)
            {
                <div class="promotions-banner">
                    <h3>Promotions actives</h3>
                    @foreach (var promo in _activePromotions)
                    {
                        <div class="promo-badge">
                            <span class="promo-badge-icon">%</span>
                            <div class="promo-badge-content">
                                <strong>@promo.Name</strong>
                                <span>@FormatPromoDescription(promo)</span>
                            </div>
                            <span class="promo-badge-value">-@FormatDiscount(promo.DiscountType, promo.DiscountValue)</span>
                        </div>
                    }
                </div>
            }

            @* ── Order type & details ── *@
            <div class="checkout-form">
                <h3>Type de commande</h3>
                <div class="order-type-selector">
                    <button type="button"
                            class="order-type-btn @(_orderType == "Delivery" ? "order-type-btn--active" : "")"
                            @onclick="() => SelectOrderType(OrderTypeValue.Delivery)">
                        Livraison
                    </button>
                    <button type="button"
                            class="order-type-btn @(_orderType == "DineIn" ? "order-type-btn--active" : "")"
                            @onclick="() => SelectOrderType(OrderTypeValue.DineIn)">
                        Sur place
                    </button>
                </div>

                @if (_orderType == "Delivery")
                {
                    <div class="form-group">
                        <label for="delivery-address">Adresse de livraison *</label>
                        <input type="text" id="delivery-address" @bind="_deliveryAddress" class="filter-input"
                               placeholder="Entrez votre adresse de livraison" />
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label for="guest-count">Nombre de convives</label>
                        <div class="guest-count-selector">
                            <button type="button" class="qty-btn" @onclick="DecrementGuests" disabled="@(_guestCount <= MinGuestAllowed)">−</button>
                            <span class="qty-value">@_guestCount</span>
                            <button type="button" class="qty-btn" @onclick="IncrementGuests" disabled="@(_guestCount >= MaxGuestAllowed)">+</button>
                        </div>
                        @if (_isEventBooking)
                        {
                            <p class="slots-empty">Mode événement: entre 1 et 500 convives.</p>
                        }
                        else
                        {
                            <p class="slots-empty">Minimum 2, maximum pour ce restaurant: @_maxGuestCount personne(s)</p>
                        }
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="_isEventBooking" @bind:after="HandleEventBookingToggle" />
                            Réservation d'événement (mariage, anniversaire, etc.)
                        </label>
                    </div>

                    @if (_isEventBooking)
                    {
                        <div class="form-group">
                            <label for="event-name">Nom de l'événement *</label>
                            <input type="text" id="event-name" @bind="_eventName" class="filter-input"
                                   placeholder="Ex: Mariage Léa et Samir" />
                        </div>

                        <div class="form-group">
                            <label for="event-description">Description</label>
                            <textarea id="event-description" @bind="_eventDescription" class="filter-input" rows="2"
                                      placeholder="Cocktail, dîner, contraintes spécifiques..."></textarea>
                        </div>

                        <div class="form-group">
                            <label for="event-starts-at">Début de l'événement *</label>
                            <input type="datetime-local" id="event-starts-at" value="@_eventStartsAtText" @oninput="OnEventStartsAtChanged" class="filter-input" />
                        </div>

                        <div class="form-group">
                            <label for="event-ends-at">Fin de l'événement *</label>
                            <input type="datetime-local" id="event-ends-at" value="@_eventEndsAtText" @oninput="OnEventEndsAtChanged" class="filter-input" />
                        </div>
                    }

                    <div class="dine-in-info">
                        <p>Vous mangerez directement au restaurant. Une table pour <strong>@_guestCount</strong> personne(s) sera préparée.</p>
                    </div>
                }

                <div class="form-group">
                    <label for="notes">Notes pour le restaurant</label>
                    <textarea id="notes" @bind="_notes" class="filter-input" rows="2"
                              placeholder="@(_orderType == "DineIn" ? "Préférences de table, allergies..." : "Instructions de livraison, étage, code...")"></textarea>
                </div>

                @if (!_isEventBooking)
                {
                <div class="form-group">
                    <label for="scheduled-date">
                        @(_orderType == "DineIn" ? "Date de la réservation" : "Date souhaitée")
                        <span class="optional-label">(optionnel)</span>
                    </label>
                    <input type="date" id="scheduled-date" value="@_scheduledDateText" class="filter-input"
                           @onchange="HandleScheduledDateChanged" />
                    <div class="slot-helper-row">
                        <span>Créneaux disponibles sur la date sélectionnée</span>
                        @if (_scheduledAt.HasValue)
                        {
                            <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="ClearSelectedSlot">
                                Retirer le créneau
                            </button>
                        }
                    </div>

                    @if (_loadingSlots)
                    {
                        <p class="slots-loading">Chargement des créneaux disponibles...</p>
                    }
                    else if (_slotsError is not null)
                    {
                        <p class="slots-error">@_slotsError</p>
                    }
                    else if (_availableSlots.Count == 0)
                    {
                        <p class="slots-empty">Aucun créneau disponible pour cette date.</p>
                    }
                    else
                    {
                        <div class="slot-selector-grid">
                            @foreach (var slot in _availableSlots)
                            {
                                var isSelected = _scheduledAt.HasValue && _scheduledAt.Value == slot.StartsAt;
                                <button type="button"
                                        class="slot-option @(isSelected ? "slot-option--selected" : string.Empty)"
                                        @onclick="() => SelectSlot(slot.StartsAt)">
                                    <span class="slot-option-time">@slot.StartsAt.ToString("HH:mm")</span>
                                    <span class="slot-option-end">@slot.EndsAt.ToString("HH:mm")</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_scheduledAt.HasValue)
                    {
                        <p class="slot-selection-summary">
                            Sélection actuelle : @_scheduledAt.Value.ToString("dd/MM/yyyy à HH:mm")
                        </p>
                    }
                </div>
                }
            </div>

            @* ── Discount codes ── *@
            <div class="discount-section">
                <h3>Codes promo</h3>

                @if (_appliedCodes.Count > 0)
                {
                    <div class="applied-codes">
                        @foreach (var dc in _appliedCodes)
                        {
                            <div class="applied-code">
                                <div class="applied-code-info">
                                    <strong>@dc.Code</strong>
                                    <span>@FormatDiscount(dc.DiscountType, dc.DiscountValue)</span>
                                </div>
                                <button type="button" class="app-btn app-btn--danger app-btn--sm" @onclick="() => RemoveCode(dc)">
                                    Retirer
                                </button>
                            </div>
                        }
                    </div>
                }

                <div class="discount-code-input">
                    <input type="text" @bind="_discountCodeInput" @bind:event="oninput" class="filter-input"
                           placeholder="Entrez un code promo" @onkeydown="HandleCodeKeyDown" />
                    <button type="button" class="app-btn app-btn--primary app-btn--sm" @onclick="ApplyCode"
                            disabled="@(_applyingCode || string.IsNullOrWhiteSpace(_discountCodeInput))">
                        @(_applyingCode ? "..." : "Appliquer")
                    </button>
                </div>
                @if (_codeError is not null)
                {
                    <p class="code-error">@_codeError</p>
                }
                @if (_codeSuccess is not null)
                {
                    <p class="code-success">@_codeSuccess</p>
                }
            </div>

            @* ── Loyalty points ── *@
            @if (_loyaltyAccount is not null && _loyaltyAccount.PointsBalance > 0)
            {
                <div class="discount-section">
                    <h3>Points de fidélité</h3>
                    <p class="loyalty-info">
                        Vous avez <strong>@_loyaltyAccount.PointsBalance points</strong>
                        (valeur : @_loyaltyAccount.EuroEquivalent.ToString("C", _frCulture))
                    </p>
                    <div class="loyalty-redeem">
                        <label for="loyalty-points">Points à utiliser</label>
                        <input type="number" id="loyalty-points" @bind="_loyaltyPointsToRedeem" @bind:event="oninput"
                               min="0" max="@_loyaltyAccount.PointsBalance" class="filter-input"
                               style="max-width: 150px;" />
                        @if (_loyaltyPointsToRedeem > 0 && _loyaltyAccount.EurosPerPoint > 0)
                        {
                            <span class="loyalty-value">
                                = @((_loyaltyPointsToRedeem * _loyaltyAccount.EurosPerPoint).ToString("C", _frCulture)) de réduction
                            </span>
                        }
                    </div>
                </div>
            }

            @* ── Order breakdown ── *@
            <div class="order-breakdown">
                <h3>Récapitulatif</h3>
                <div class="breakdown-lines">
                    @foreach (var item in _cart.Items)
                    {
                        <div class="breakdown-line">
                            <span>@item.DishName x @item.Quantity</span>
                            <span>@item.Subtotal.ToString("C", _frCulture)</span>
                        </div>
                    }

                    <div class="breakdown-line breakdown-subtotal">
                        <span>Sous-total</span>
                        <span>@_cart.TotalAmount.ToString("C", _frCulture)</span>
                    </div>

                    @if (_activePromotions is not null)
                    {
                        @foreach (var promo in _activePromotions)
                        {
                            var promoDiscount = EstimatePromotionDiscount(promo);
                            if (promoDiscount > 0)
                            {
                                <div class="breakdown-line breakdown-discount">
                                    <span>@promo.Name</span>
                                    <span>-@promoDiscount.ToString("C", _frCulture)</span>
                                </div>
                            }
                        }
                    }

                    @foreach (var appliedCode in _appliedCodes)
                    {
                        var discount = EstimateCodeDiscount(appliedCode);
                        if (discount > 0)
                        {
                            <div class="breakdown-line breakdown-discount">
                                <span>Code : @appliedCode.Code</span>
                                <span>-@(discount.ToString("C", _frCulture))</span>
                            </div>
                        }
                    }

                    @if (_loyaltyPointsToRedeem > 0 && _loyaltyAccount is not null)
                    {
                        <div class="breakdown-line breakdown-discount">
                            <span>Points de fidélité (@_loyaltyPointsToRedeem pts)</span>
                            <span>-@((_loyaltyPointsToRedeem * _loyaltyAccount.EurosPerPoint).ToString("C", _frCulture))</span>
                        </div>
                    }

                    <div class="breakdown-line breakdown-total">
                        <span>Total estimé</span>
                        <span>@EstimatedTotal.ToString("C", _frCulture)</span>
                    </div>
                </div>

                @if (EstimatedSavings > 0)
                {
                    <p class="savings-message">Vous économisez @EstimatedSavings.ToString("C", _frCulture) !</p>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_validationError))
            {
                <div class="error-message">
                    <p>@_validationError</p>
                </div>
            }

            <div class="cart-actions">
                <button type="button" class="app-btn app-btn--danger" @onclick="ClearCart">
                    Vider le panier
                </button>
                <button type="button" class="app-btn app-btn--primary app-btn--lg" @onclick="GoToCheckout">
                    <span>Commander — @EstimatedTotal.ToString("C", _frCulture)</span>
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private CartDto? _cart;
    private bool _loading = true;
    private string? _error;
    private string? _validationError;
    private static readonly System.Globalization.CultureInfo _frCulture =
        System.Globalization.CultureInfo.GetCultureInfo("fr-FR");

    private string _orderType = "Delivery";
    private int _guestCount = 1;
    private int _maxGuestCount = 50;
    private bool _isEventBooking;
    private string _eventName = string.Empty;
    private string _eventDescription = string.Empty;
    private string _eventStartsAtText = string.Empty;
    private string _eventEndsAtText = string.Empty;
    private string _deliveryAddress = string.Empty;
    private string _notes = string.Empty;
    private DateTime? _scheduledAt;
    private DateTime _scheduledDate = DateTime.Today.AddDays(1);
    private string _scheduledDateText = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd");
    private List<AvailableSlotDto> _availableSlots = [];
    private bool _loadingSlots;
    private string? _slotsError;
    private string _discountCodeInput = string.Empty;
    private List<DiscountCodeDto> _appliedCodes = [];
    private bool _applyingCode;
    private string? _codeError;
    private string? _codeSuccess;
    private int _loyaltyPointsToRedeemBacking;
    private int _loyaltyPointsToRedeem
    {
        get => _loyaltyPointsToRedeemBacking;
        set
        {
            var max = _loyaltyAccount?.PointsBalance ?? 0;
            _loyaltyPointsToRedeemBacking = Math.Clamp(value, 0, max);
        }
    }
    private LoyaltyAccountDto? _loyaltyAccount;
    private List<PromotionDto>? _activePromotions;

    private enum OrderTypeValue { Delivery, DineIn }

    private int MinGuestAllowed => _isEventBooking ? 1 : 2;

    private int MaxGuestAllowed => _isEventBooking ? 500 : _maxGuestCount;

    // ── Estimated totals (client-side preview) ──
    private decimal EstimatedPromotionDiscount => _activePromotions?.Sum(p => EstimatePromotionDiscount(p)) ?? 0;

    private decimal EstimatedCodeDiscount => _appliedCodes.Sum(c => EstimateCodeDiscount(c));

    private decimal EstimatedLoyaltyDiscount =>
        _loyaltyPointsToRedeem > 0 && _loyaltyAccount is not null
            ? _loyaltyPointsToRedeem * _loyaltyAccount.EurosPerPoint
            : 0;

    private decimal EstimatedSavings => Math.Min(
        EstimatedPromotionDiscount + EstimatedCodeDiscount + EstimatedLoyaltyDiscount,
        _cart?.TotalAmount ?? 0);

    private decimal EstimateCodeDiscount(DiscountCodeDto code)
    {
        var subtotal = _cart?.TotalAmount ?? 0;
        if (code.MinOrderAmount.HasValue && subtotal < code.MinOrderAmount.Value) return 0;
        return code.DiscountType == "Percentage"
            ? Math.Round(subtotal * code.DiscountValue / 100, 2)
            : Math.Min(code.DiscountValue, subtotal);
    }

    private decimal EstimatedTotal => Math.Max((_cart?.TotalAmount ?? 0) - EstimatedSavings, 0);

    private decimal EstimatePromotionDiscount(PromotionDto promo)
    {
        if (_cart is null) return 0;
        var subtotal = _cart.TotalAmount;

        if (promo.PromotionType == "Threshold" && promo.MinOrderAmount.HasValue && subtotal < promo.MinOrderAmount.Value)
            return 0;

        if (promo.PromotionType == "ItemBased" && promo.DishIds.Count > 0)
        {
            var matchingSubtotal = _cart.Items
                .Where(i => promo.DishIds.Contains(i.DishId))
                .Sum(i => i.Subtotal);
            if (matchingSubtotal == 0) return 0;

            return promo.DiscountType == "Percentage"
                ? Math.Round(matchingSubtotal * promo.DiscountValue / 100, 2)
                : Math.Min(promo.DiscountValue, matchingSubtotal);
        }

        // Automatic or Threshold (met)
        return promo.DiscountType == "Percentage"
            ? Math.Round(subtotal * promo.DiscountValue / 100, 2)
            : Math.Min(promo.DiscountValue, subtotal);
    }

    // ── Navigation ──
    private void GoToRestaurant() => Nav.NavigateTo($"/restaurant/{RestaurantId}");

    private async Task SelectOrderType(OrderTypeValue type)
    {
        _orderType = type.ToString();
        _validationError = null;

        if (type == OrderTypeValue.Delivery)
        {
            _guestCount = 1;
            _isEventBooking = false;
            ClearEventInputs();
        }
        else if (_guestCount < MinGuestAllowed)
            _guestCount = MinGuestAllowed;

        await MaybeLoadAvailableSlots();
    }

    private async Task IncrementGuests()
    {
        if (_guestCount < MaxGuestAllowed)
        {
            _guestCount++;
            await MaybeLoadAvailableSlots();
        }
    }

    private async Task DecrementGuests()
    {
        if (_guestCount > MinGuestAllowed)
        {
            _guestCount--;
            await MaybeLoadAvailableSlots();
        }
    }

    private async Task HandleEventBookingToggle()
    {
        _validationError = null;

        if (_isEventBooking)
        {
            _scheduledAt = null;
            _availableSlots = [];
            _slotsError = null;
            if (_orderType == "DineIn" && _guestCount < 1)
                _guestCount = 1;
        }
        else
        {
            if (_orderType == "DineIn" && _guestCount < 2)
                _guestCount = 2;
            await LoadAvailableSlots();
        }

        StateHasChanged();
    }

    private void OnEventStartsAtChanged(ChangeEventArgs e)
    {
        _eventStartsAtText = e.Value?.ToString() ?? string.Empty;
    }

    private void OnEventEndsAtChanged(ChangeEventArgs e)
    {
        _eventEndsAtText = e.Value?.ToString() ?? string.Empty;
    }

    private void ClearEventInputs()
    {
        _eventName = string.Empty;
        _eventDescription = string.Empty;
        _eventStartsAtText = string.Empty;
        _eventEndsAtText = string.Empty;
    }

    private async Task MaybeLoadAvailableSlots()
    {
        if (_orderType == "DineIn" && !_isEventBooking)
            await LoadAvailableSlots();
    }

    // ── Data loading ──
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCart(), LoadActivePromotions(), LoadLoyaltyAccount());
        await LoadGuestCapacityLimit();
        await LoadAvailableSlots();
    }

    private async Task LoadCart()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (cart, error) = await CartService.GetCartAsync(RestaurantId);
        if (error is not null)
            _error = error.Error;
        else
            _cart = cart;

        _loading = false;
        StateHasChanged();
    }

    private async Task LoadActivePromotions()
    {
        var (promotions, _) = await PromotionService.GetActiveByRestaurantAsync(RestaurantId);
        _activePromotions = promotions ?? [];
    }

    private async Task LoadLoyaltyAccount()
    {
        var (account, _) = await LoyaltyService.GetMyAccountAsync(RestaurantId);
        _loyaltyAccount = account;
    }

    private async Task LoadGuestCapacityLimit()
    {
        var (capacity, _) = await RestaurantOrderConfigService.GetTablesCapacityAsync(RestaurantId);
        var tablesPerSlot = capacity?.CapacityPerSlot ?? 0;
        _maxGuestCount = Math.Max(2, tablesPerSlot * 2);

        if (_guestCount > _maxGuestCount)
            _guestCount = _maxGuestCount;

        if (_orderType == "DineIn" && !_isEventBooking && _guestCount < 2)
            _guestCount = 2;

        if (_isEventBooking && _guestCount < 1)
            _guestCount = 1;
    }

    private async Task HandleScheduledDateChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsedDate))
            return;

        _scheduledDate = parsedDate.Date;
        _scheduledDateText = _scheduledDate.ToString("yyyy-MM-dd");
        _scheduledAt = null;
        await LoadAvailableSlots();
    }

    private void SelectSlot(DateTime slotStartsAt)
    {
        _scheduledAt = slotStartsAt;
        _validationError = null;
    }

    private void ClearSelectedSlot()
    {
        _scheduledAt = null;
    }

    private async Task LoadAvailableSlots()
    {
        _loadingSlots = true;
        _slotsError = null;
        StateHasChanged();

        var query = new RestaurantAvailableSlotsQuery
        {
            Date = _scheduledDate,
            GuestCount = _guestCount
        };

        var (response, error) = await RestaurantOrderConfigService.GetAvailableSlotsAsync(RestaurantId, query);
        if (error is not null)
        {
            _slotsError = error.Error;
            _availableSlots = [];
        }
        else
        {
            _availableSlots = response?.Slots ?? [];
            if (_scheduledAt.HasValue && !_availableSlots.Any(slot => slot.StartsAt == _scheduledAt.Value))
                _scheduledAt = null;
        }

        _loadingSlots = false;
        StateHasChanged();
    }

    // ── Cart actions ──
    private async Task UpdateQuantity(CartItemDto item, int newQuantity)
    {
        if (newQuantity < 1 || newQuantity > 99) return;

        var request = new UpdateCartItemRequest
        {
            Quantity = newQuantity,
            SpecialInstructions = item.SpecialInstructions
        };

        var (_, error) = await CartService.UpdateItemAsync(item.Id, request);
        if (error is null)
            await LoadCart();
        else
        {
            _error = error.Error;
            StateHasChanged();
        }
    }

    private async Task RemoveItem(int cartItemId)
    {
        var error = await CartService.RemoveItemAsync(cartItemId);
        if (error is null)
            await LoadCart();
        else
        {
            _error = error.Error;
            StateHasChanged();
        }
    }

    private async Task ClearCart()
    {
        var error = await CartService.ClearCartAsync(RestaurantId);
        if (error is null)
        {
            _cart = new CartDto { RestaurantId = RestaurantId };
            StateHasChanged();
        }
        else
        {
            _error = error.Error;
            StateHasChanged();
        }
    }

    // ── Discount codes ──
    private async Task ApplyCode()
    {
        if (string.IsNullOrWhiteSpace(_discountCodeInput)) return;

        var code = _discountCodeInput.Trim();
        _codeError = null;
        _codeSuccess = null;

        if (_appliedCodes.Any(c => c.Code.Equals(code, StringComparison.OrdinalIgnoreCase)))
        {
            _codeError = "Ce code est déjà appliqué.";
            return;
        }

        _applyingCode = true;
        StateHasChanged();

        var (result, error) = await DiscountCodeService.ValidateAsync(RestaurantId, code);
        if (error is not null)
        {
            _codeError = error.Error;
        }
        else if (result is not null)
        {
            _appliedCodes.Add(result);
            _codeSuccess = $"Code \"{result.Code}\" appliqué — {FormatDiscount(result.DiscountType, result.DiscountValue)}";
            _discountCodeInput = string.Empty;
        }

        _applyingCode = false;
        StateHasChanged();
    }

    private void RemoveCode(DiscountCodeDto code)
    {
        _appliedCodes.Remove(code);
        _codeError = null;
        _codeSuccess = null;
    }

    private async Task HandleCodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyCode();
    }

    // ── Checkout ──
    private void GoToCheckout()
    {
        _validationError = null;

        if (_orderType == "Delivery" && string.IsNullOrWhiteSpace(_deliveryAddress))
        {
            _validationError = "L'adresse de livraison est obligatoire pour une commande en livraison.";
            return;
        }

        if (_orderType == "DineIn" && (_guestCount < MinGuestAllowed || _guestCount > MaxGuestAllowed))
        {
            _validationError = _isEventBooking
                ? "Le nombre de convives doit être compris entre 1 et 500 pour un événement."
                : $"Le nombre de convives doit être compris entre 2 et {_maxGuestCount}.";
            return;
        }

        DateTime? eventStartsAt = null;
        DateTime? eventEndsAt = null;

        if (_isEventBooking)
        {
            if (string.IsNullOrWhiteSpace(_eventName))
            {
                _validationError = "Le nom de l'événement est obligatoire.";
                return;
            }

            if (!DateTime.TryParse(_eventStartsAtText, out var parsedStartsAt)
                || !DateTime.TryParse(_eventEndsAtText, out var parsedEndsAt))
            {
                _validationError = "Les dates de début et de fin de l'événement sont obligatoires.";
                return;
            }

            if (parsedEndsAt <= parsedStartsAt)
            {
                _validationError = "La date de fin de l'événement doit être postérieure à la date de début.";
                return;
            }

            eventStartsAt = parsedStartsAt;
            eventEndsAt = parsedEndsAt;
        }

        if (!_isEventBooking && _scheduledAt.HasValue && !_availableSlots.Any(slot => slot.StartsAt == _scheduledAt.Value))
        {
            _validationError = "Le créneau sélectionné n'est plus disponible.";
            return;
        }

        CheckoutState.RestaurantId = RestaurantId;
        CheckoutState.OrderType = _orderType;
        CheckoutState.GuestCount = _guestCount;
        CheckoutState.DeliveryAddress = _deliveryAddress;
        CheckoutState.Notes = _notes;
        CheckoutState.ScheduledAt = _isEventBooking ? null : _scheduledAt;
        CheckoutState.IsEventBooking = _isEventBooking;
        CheckoutState.EventName = _isEventBooking ? _eventName.Trim() : string.Empty;
        CheckoutState.EventDescription = _isEventBooking ? _eventDescription.Trim() : string.Empty;
        CheckoutState.EventStartsAt = eventStartsAt;
        CheckoutState.EventEndsAt = eventEndsAt;
        CheckoutState.AppliedCodes = [.. _appliedCodes];
        CheckoutState.LoyaltyPointsToRedeem = _loyaltyPointsToRedeem;
        CheckoutState.LoyaltyAccount = _loyaltyAccount;

        Nav.NavigateTo($"/paiement?restaurantId={RestaurantId}");
    }

    // ── Helpers ──
    private static string FormatDiscount(string discountType, decimal value) => discountType switch
    {
        "Percentage" => $"{value}%",
        "FixedAmount" => $"{value:0.00} €",
        _ => $"{value}"
    };

    private static string FormatPromoDescription(PromotionDto promo) => promo.PromotionType switch
    {
        "Automatic" => "Appliquée automatiquement",
        "Threshold" => $"Dès {promo.MinOrderAmount:0.00} € de commande",
        "ItemBased" => "Sur articles sélectionnés",
        _ => ""
    };
}
