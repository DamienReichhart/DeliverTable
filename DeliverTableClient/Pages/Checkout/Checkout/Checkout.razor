@page "/paiement"
@attribute [Authorize(Roles = nameof(UserRole.Customer))]
@using DeliverTableClient.Services.Payment
@using DeliverTableClient.State
@using DeliverTableSharedLibrary.Dtos.Order
@using DeliverTableSharedLibrary.Dtos.Promotion
@using DeliverTableSharedLibrary.Dtos.DiscountCode
@using DeliverTableSharedLibrary.Dtos.Loyalty
@inject IPaymentApiClient PaymentApi
@inject IStripeJsInterop StripeJs
@inject ICartService CartService
@inject IPromotionService PromotionService
@inject NavigationManager Nav
@inject CheckoutState CheckoutState
@implements IAsyncDisposable

<PageTitle>Paiement — DeliverTable</PageTitle>

<div class="checkout-page">
    <h1>Paiement</h1>

    @if (_loading)
    {
        <p class="checkout-page__loading">Préparation du paiement...</p>
    }
    else if (_error is not null)
    {
        <div class="error-message">
            <p>@_error</p>
        </div>
        <div class="checkout-page__back">
            @if (_isBillingIncomplete)
            {
                <a class="app-btn app-btn--primary" href="/profil">
                    Compléter mon profil
                </a>
            }
            <button type="button" class="app-btn app-btn--secondary" @onclick="GoBack">
                Retour au panier
            </button>
        </div>
    }
    else if (_cart is not null)
    {
        <div class="checkout-layout">

            @* ── Read-only order summary ── *@
            <div class="checkout-form">
                <h2>Votre commande</h2>
                <p class="checkout-restaurant">@_cart.RestaurantName</p>

                <dl class="checkout-readonly">
                    <div class="checkout-readonly__row">
                        <dt>Type de commande</dt>
                        <dd>@(CheckoutState.OrderType == "Delivery" ? "Livraison" : "Sur place")</dd>
                    </div>

                    @if (CheckoutState.OrderType == "Delivery")
                    {
                        <div class="checkout-readonly__row">
                            <dt>Adresse de livraison</dt>
                            <dd>@CheckoutState.DeliveryAddress</dd>
                        </div>
                    }
                    else
                    {
                        <div class="checkout-readonly__row">
                            <dt>Nombre de convives</dt>
                            <dd>@CheckoutState.GuestCount</dd>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(CheckoutState.Notes))
                    {
                        <div class="checkout-readonly__row">
                            <dt>Notes</dt>
                            <dd>@CheckoutState.Notes</dd>
                        </div>
                    }

                    @if (CheckoutState.ScheduledAt.HasValue)
                    {
                        <div class="checkout-readonly__row">
                            <dt>@(CheckoutState.OrderType == "DineIn" ? "Date de réservation" : "Date de livraison")</dt>
                            <dd>@CheckoutState.ScheduledAt.Value.ToString("dddd d MMMM yyyy HH:mm", _frCulture)</dd>
                        </div>
                    }

                    @if (CheckoutState.IsEventBooking)
                    {
                        <div class="checkout-readonly__row">
                            <dt>Réservation événement</dt>
                            <dd>Oui</dd>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(CheckoutState.EventName))
                        {
                            <div class="checkout-readonly__row">
                                <dt>Nom de l'événement</dt>
                                <dd>@CheckoutState.EventName</dd>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(CheckoutState.EventDescription))
                        {
                            <div class="checkout-readonly__row">
                                <dt>Description événement</dt>
                                <dd>@CheckoutState.EventDescription</dd>
                            </div>
                        }

                        @if (CheckoutState.EventStartsAt.HasValue)
                        {
                            <div class="checkout-readonly__row">
                                <dt>Début événement</dt>
                                <dd>@CheckoutState.EventStartsAt.Value.ToString("dddd d MMMM yyyy HH:mm", _frCulture)</dd>
                            </div>
                        }

                        @if (CheckoutState.EventEndsAt.HasValue)
                        {
                            <div class="checkout-readonly__row">
                                <dt>Fin événement</dt>
                                <dd>@CheckoutState.EventEndsAt.Value.ToString("dddd d MMMM yyyy HH:mm", _frCulture)</dd>
                            </div>
                        }
                    }
                </dl>

                <div class="checkout-edit-link">
                    <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="GoBack" disabled="@_paymentReady">
                        Modifier la commande
                    </button>
                </div>
            </div>

            @* ── Payment panel ── *@
            <div class="checkout-payment-panel">
                @* ── Order breakdown with all reductions ── *@
                <div class="checkout-summary">
                    <h3>Récapitulatif</h3>

                    @foreach (var item in _cart.Items)
                    {
                        <div class="summary-line">
                            <span>@item.DishName × @item.Quantity</span>
                            <span>@item.Subtotal.ToString("C", _frCulture)</span>
                        </div>
                    }

                    <div class="summary-line summary-line--subtotal">
                        <span>Sous-total</span>
                        <span>@_cart.TotalAmount.ToString("C", _frCulture)</span>
                    </div>

                    @if (_activePromotions is not null)
                    {
                        @foreach (var promo in _activePromotions)
                        {
                            var promoDiscount = EstimatePromotionDiscount(promo);
                            if (promoDiscount > 0)
                            {
                                <div class="summary-line summary-line--discount">
                                    <span>@promo.Name</span>
                                    <span>-@promoDiscount.ToString("C", _frCulture)</span>
                                </div>
                            }
                        }
                    }

                    @foreach (var appliedCode in CheckoutState.AppliedCodes)
                    {
                        var discount = EstimateCodeDiscount(appliedCode);
                        if (discount > 0)
                        {
                            <div class="summary-line summary-line--discount">
                                <span>Code : @appliedCode.Code</span>
                                <span>-@discount.ToString("C", _frCulture)</span>
                            </div>
                        }
                    }

                    @if (CheckoutState.LoyaltyPointsToRedeem > 0 && CheckoutState.LoyaltyAccount is not null)
                    {
                        <div class="summary-line summary-line--discount">
                            <span>Points de fidélité (@CheckoutState.LoyaltyPointsToRedeem pts)</span>
                            <span>-@((CheckoutState.LoyaltyPointsToRedeem * CheckoutState.LoyaltyAccount.EurosPerPoint).ToString("C", _frCulture))</span>
                        </div>
                    }

                    <div class="summary-line summary-line--total">
                        <span>Total estimé</span>
                        <strong>@EstimatedTotal.ToString("C", _frCulture)</strong>
                    </div>

                    @if (EstimatedSavings > 0)
                    {
                        <p class="savings-message">Vous économisez @EstimatedSavings.ToString("C", _frCulture) !</p>
                    }
                </div>

                @if (!_paymentReady)
                {
                    <div class="checkout-pay-actions">
                        @if (!string.IsNullOrWhiteSpace(_validationError))
                        {
                            <div class="error-message"><p>@_validationError</p></div>
                        }
                        <button type="button" class="app-btn app-btn--primary app-btn--lg checkout-pay-btn"
                                @onclick="StartPaymentAsync" disabled="@_initializing">
                            @(_initializing ? "Initialisation..." : $"Procéder au paiement — {EstimatedTotal.ToString("C", _frCulture)}")
                        </button>
                    </div>
                }
                else
                {
                    @* ── Stripe Payment Element ── *@
                    <div id="payment-element" class="payment-element"></div>

                    @if (!string.IsNullOrWhiteSpace(_paymentError))
                    {
                        <div class="error-message"><p>@_paymentError</p></div>
                    }

                    <div class="checkout-pay-actions">
                        <button type="button" class="app-btn app-btn--primary app-btn--lg checkout-pay-btn"
                                @onclick="ConfirmAsync" disabled="@_submitting">
                            @(_submitting ? "Traitement..." : $"Payer — {_amount.ToString("C", _frCulture)}")
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "restaurantId")]
    public int RestaurantId { get; set; }

    private static readonly System.Globalization.CultureInfo _frCulture =
        System.Globalization.CultureInfo.GetCultureInfo("fr-FR");

    private const string BillingIncompleteMessage =
        "Veuillez compléter votre adresse de facturation dans votre profil avant de commander.";

    private CartDto? _cart;
    private bool _loading = true;
    private bool _initializing;
    private bool _submitting;
    private bool _paymentReady;
    private string? _error;
    private bool _isBillingIncomplete;
    private string? _validationError;
    private string? _paymentError;
    private int _orderId;
    private decimal _amount;
    private List<PromotionDto>? _activePromotions;

    private decimal EstimatedPromotionDiscount => _activePromotions?.Sum(p => EstimatePromotionDiscount(p)) ?? 0;
    private decimal EstimatedCodeDiscount => CheckoutState.AppliedCodes.Sum(c => EstimateCodeDiscount(c));
    private decimal EstimatedLoyaltyDiscount =>
        CheckoutState.LoyaltyPointsToRedeem > 0 && CheckoutState.LoyaltyAccount is not null
            ? CheckoutState.LoyaltyPointsToRedeem * CheckoutState.LoyaltyAccount.EurosPerPoint
            : 0;
    private decimal EstimatedSavings => Math.Min(
        EstimatedPromotionDiscount + EstimatedCodeDiscount + EstimatedLoyaltyDiscount,
        _cart?.TotalAmount ?? 0);
    private decimal EstimatedTotal => Math.Max((_cart?.TotalAmount ?? 0) - EstimatedSavings, 0);

    protected override async Task OnInitializedAsync()
    {
        if (RestaurantId <= 0)
        {
            _error = "Aucun restaurant sélectionné.";
            _loading = false;
            return;
        }

        if (!CheckoutState.IsReady || CheckoutState.RestaurantId != RestaurantId)
        {
            Nav.NavigateTo($"/panier/{RestaurantId}");
            return;
        }

        await Task.WhenAll(LoadCart(), LoadActivePromotions());
        _loading = false;
    }

    private async Task LoadCart()
    {
        var (cart, error) = await CartService.GetCartAsync(RestaurantId);
        if (error is not null)
            _error = error.Error;
        else if (cart is null || cart.Items.Count == 0)
            _error = "Votre panier est vide.";
        else
            _cart = cart;
    }

    private async Task LoadActivePromotions()
    {
        if (RestaurantId <= 0) return;
        var (promotions, _) = await PromotionService.GetActiveByRestaurantAsync(RestaurantId);
        _activePromotions = promotions ?? [];
    }

    // ── Stripe initialisation ──

    private async Task StartPaymentAsync()
    {
        _validationError = null;
        _isBillingIncomplete = false;
        _initializing = true;
        StateHasChanged();

        var request = BuildOrderRequest();
        var (response, errorResponse) = await PaymentApi.CreateOrderAsync(request);
        if (response is null)
        {
            _error = errorResponse?.Error ?? "Impossible de démarrer le paiement.";
            _isBillingIncomplete = _error == BillingIncompleteMessage;
            _initializing = false;
            StateHasChanged();
            return;
        }

        _orderId = response.OrderId;
        _amount = response.Amount;
        await StripeJs.InitializeAsync(response.PublishableKey);
        _paymentReady = true;
        _initializing = false;
        StateHasChanged();
        await StripeJs.MountPaymentElementAsync(response.ClientSecret, "payment-element");
    }

    private async Task ConfirmAsync()
    {
        _paymentError = null;
        _submitting = true;
        StateHasChanged();

        var baseUri = Nav.BaseUri.TrimEnd('/');
        var result = await StripeJs.ConfirmPaymentAsync($"{baseUri}/paiement/resultat?orderId={_orderId}");

        if (result.Succeeded)
        {
            CheckoutState.Clear();
            Nav.NavigateTo($"/paiement/resultat?orderId={_orderId}");
        }
        else
        {
            _paymentError = result.ErrorMessage ?? "Échec du paiement.";
            _submitting = false;
            StateHasChanged();
        }
    }

    private CreateOrderRequest BuildOrderRequest() => new()
    {
        RestaurantId = RestaurantId,
        OrderType = CheckoutState.OrderType,
        GuestCount = CheckoutState.GuestCount,
        DeliveryAddress = CheckoutState.DeliveryAddress,
        Notes = CheckoutState.Notes,
        ScheduledAt = CheckoutState.ScheduledAt.HasValue ? CheckoutState.ScheduledAt.Value.ToUniversalTime() : null,
        IsEventBooking = CheckoutState.IsEventBooking,
        EventName = CheckoutState.EventName,
        EventDescription = CheckoutState.EventDescription,
        EventStartsAt = CheckoutState.EventStartsAt.HasValue ? CheckoutState.EventStartsAt.Value.ToUniversalTime() : null,
        EventEndsAt = CheckoutState.EventEndsAt.HasValue ? CheckoutState.EventEndsAt.Value.ToUniversalTime() : null,
        DiscountCodes = CheckoutState.AppliedCodes.Select(c => c.Code).ToList(),
        LoyaltyPointsToRedeem = CheckoutState.LoyaltyPointsToRedeem
    };

    // ── Discount estimation ──
    private decimal EstimateCodeDiscount(DiscountCodeDto c)
    {
        var subtotal = _cart?.TotalAmount ?? 0;
        if (c.MinOrderAmount.HasValue && subtotal < c.MinOrderAmount.Value) return 0;
        return c.DiscountType == "Percentage"
            ? Math.Round(subtotal * c.DiscountValue / 100, 2)
            : Math.Min(c.DiscountValue, subtotal);
    }

    private decimal EstimatePromotionDiscount(PromotionDto promo)
    {
        if (_cart is null) return 0;
        var subtotal = _cart.TotalAmount;

        if (promo.PromotionType == "Threshold" && promo.MinOrderAmount.HasValue && subtotal < promo.MinOrderAmount.Value)
            return 0;

        if (promo.PromotionType == "ItemBased" && promo.DishIds.Count > 0)
        {
            var matchingSubtotal = _cart.Items
                .Where(i => promo.DishIds.Contains(i.DishId))
                .Sum(i => i.Subtotal);
            if (matchingSubtotal == 0) return 0;
            return promo.DiscountType == "Percentage"
                ? Math.Round(matchingSubtotal * promo.DiscountValue / 100, 2)
                : Math.Min(promo.DiscountValue, matchingSubtotal);
        }

        return promo.DiscountType == "Percentage"
            ? Math.Round(subtotal * promo.DiscountValue / 100, 2)
            : Math.Min(promo.DiscountValue, subtotal);
    }

    // ── Navigation ──
    private void GoBack() => Nav.NavigateTo(RestaurantId > 0 ? $"/panier/{RestaurantId}" : "/restaurants");

    public async ValueTask DisposeAsync() => await StripeJs.UnmountAsync();
}
