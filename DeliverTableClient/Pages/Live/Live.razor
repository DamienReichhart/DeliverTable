@page "/live"
@layout LiveLayout
@inherits ComponentBase
@using DeliverTableClient.Components.Order
@attribute [Authorize(Roles = nameof(UserRole.RestaurantOwner))]

<PageTitle>Service en direct — DeliverTable</PageTitle>

<div class="live-page">
    <header class="live-header">
        <div class="live-header__title-container">
            <h1 class="live-header__title">
                <Blazicon Svg="Lucide.Radio" class="live-header__icon" />
                Service en direct
            </h1>
            <p class="live-header__subtitle">Gérez vos commandes en temps réel</p>
        </div>

        <div class="live-header__actions">
            <div class="mode-toggle">
                <button class="mode-toggle__btn @(CurrentMode == LiveViewMode.Restaurant ? "mode-toggle__btn--active" : "")"
                        @onclick="() => CurrentMode = LiveViewMode.Restaurant">
                    <Blazicon Svg="Lucide.ChefHat" class="mode-toggle__icon" />
                    Restaurant
                </button>
                <button class="mode-toggle__btn @(CurrentMode == LiveViewMode.Client ? "mode-toggle__btn--active" : "")"
                        @onclick="() => CurrentMode = LiveViewMode.Client">
                    <Blazicon Svg="Lucide.Users" class="mode-toggle__icon" />
                    Client
                </button>
            </div>

            @if (restaurants.Length > 0)
            {
                <div class="restaurant-selector">
                    <Blazicon Svg="Lucide.Store" class="restaurant-selector__icon" />
                    <select class="restaurant-selector__select"
                            value="@SelectedRestaurant"
                            @onchange="@(async (e) => await OnRestaurantSelected(int.Parse(e.Value?.ToString() ?? "0")))">
                        @foreach (var restaurant in restaurants)
                        {
                            <option value="@restaurant.Id">@restaurant.Name</option>
                        }
                    </select>
                </div>
            }
        </div>
    </header>

    @if (SelectedRestaurant == null)
    {
        <div class="live-empty">
            <div class="live-empty__card">
                <Blazicon Svg="Lucide.Store" class="live-empty__icon" />
                <h2 class="live-empty__title">Aucun restaurant sélectionné</h2>
                <p class="live-empty__text">Sélectionnez un restaurant pour commencer à recevoir les commandes en direct.</p>
            </div>
        </div>
    }
    else
    {
        <div class="live-content @(CurrentMode == LiveViewMode.Client ? "live-content--client" : "")">
            <main class="live-main">
                @if (CurrentMode == LiveViewMode.Restaurant)
                {
                    @if (orders.Length == 0 && finishedOrders.Count(o => o.Status == nameof(OrderStatus.Ready)) == 0)
                    {
                        <div class="live-empty live-empty--inline">
                            <div class="live-empty__card">
                                <Blazicon Svg="Lucide.ChefHat" class="live-empty__icon" />
                                <h2 class="live-empty__title">Prêt pour le service !</h2>
                                <p class="live-empty__text">Les commandes apparaîtront ici dès qu'elles seront passées.</p>
                                <button class="app-btn app-btn--secondary mt-4" @onclick="LoadOrders">
                                    <Blazicon Svg="Lucide.RefreshCcw" class="app-btn__icon" />
                                    Actualiser
                                </button>
                            </div>
                        </div>
                    } else {
                        <div class="live-columns">
                            <div class="live-column">
                                <div class="live-column__header">
                                    <h2 class="live-column__title">À préparer</h2>
                                    <span class="live-column__count">@orders.Count(o => o.Status == nameof(OrderStatus.Pending) || o.Status == nameof(OrderStatus.Confirmed))</span>
                                </div>
                                <div class="live-column__grid">
                                    @foreach (var order in orders.Where(o => o.Status == nameof(OrderStatus.Pending) || o.Status == nameof(OrderStatus.Confirmed)))
                                    {
                                        <OrderLiveCard Order="order"
                                                       OnOrderReady="MarkAsReady"
                                                       OnOrderConfirmed="MarkAsConfirmed"
                                                       OnOrderPreparing="MarkAsPreparing" />
                                    }
                                </div>
                            </div>
                            <div class="live-column">
                                <div class="live-column__header">
                                    <h2 class="live-column__title">En cours</h2>
                                    <span class="live-column__count">@orders.Count(o => o.Status == nameof(OrderStatus.Preparing))</span>
                                </div>
                                <div class="live-column__grid">
                                    @foreach (var order in orders.Where(o => o.Status == nameof(OrderStatus.Preparing)))
                                    {
                                        <OrderLiveCard Order="order"
                                                       OnOrderReady="MarkAsReady"
                                                       OnOrderConfirmed="MarkAsConfirmed"
                                                       OnOrderPreparing="MarkAsPreparing" />
                                    }
                                </div>
                            </div>
                        </div>
                        }
                    }
                    else
                    {
                        <div class="live-columns live-columns--client">
                            <div class="live-column live-column--preparing">
                                <div class="live-column__header">
                                    <h2 class="live-column__title">En préparation</h2>
                                </div>
                                <div class="live-column__grid live-column__grid--client">
                                    @foreach (var order in orders.Where(o => o.Status == nameof(OrderStatus.Confirmed) || o.Status == nameof(OrderStatus.Preparing)))
                                    {
                                        <div class="client-order-id">#@order.Id</div>
                                    }
                                </div>
                            </div>
                            <div class="live-column live-column--ready">
                                <div class="live-column__header">
                                    <h2 class="live-column__title">À emporter</h2>
                                </div>
                                <div class="live-column__grid live-column__grid--client">
                                    @foreach (var order in finishedOrders.Where(o => o.Status == nameof(OrderStatus.Ready) && o.OrderType == nameof(OrderType.Delivery) && o.UpdatedAt >= DateTime.UtcNow.AddMinutes(-20)))
                                    {
                                        <div class="client-order-id client-order-id--ready">#@order.Id</div>
                                    }
                                </div>
                            </div>
                            <div class="live-column live-column--dinein">
                                <div class="live-column__header">
                                    <h2 class="live-column__title">Sur place</h2>
                                </div>
                                <div class="live-column__grid live-column__grid--client">
                                    @foreach (var order in finishedOrders.Where(o => o.Status == nameof(OrderStatus.Ready) && o.OrderType == nameof(OrderType.DineIn) && o.UpdatedAt >= DateTime.UtcNow.AddMinutes(-20)))
                                    {
                                        <div class="client-order-id client-order-id--ready">#@order.Id</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
            </main>

            @if (CurrentMode == LiveViewMode.Restaurant)
            {
                <aside class="live-sidebar">
                    <OrderSessionSummary Orders="finishedOrders" />
                </aside>
            }
        </div>
    }
</div>
