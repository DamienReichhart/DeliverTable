@page "/live"
@inherits ComponentBase
@attribute [Authorize(Roles = nameof(UserRole.RestaurantOwner))]

<PageTitle>Service en direct — DeliverTable</PageTitle>

<div class="live-page">
    <header class="live-header">
        <div class="live-header__title-container">
            <h1 class="live-header__title">
                <Blazicon Svg="Lucide.Radio" class="live-header__icon" />
                Service en direct
            </h1>
            <p class="live-header__subtitle">Gérez vos commandes en temps réel</p>
        </div>

        <div class="live-header__actions">
            @if (restaurants.Length > 0)
            {
                <div class="restaurant-selector">
                    <Blazicon Svg="Lucide.Store" class="restaurant-selector__icon" />
                    <select class="restaurant-selector__select" 
                            value="@SelectedRestaurant" 
                            @onchange="@(async (e) => await OnRestaurantSelected(int.Parse(e.Value?.ToString() ?? "0")))">
                        @foreach (var restaurant in restaurants)
                        {
                            <option value="@restaurant.Id">@restaurant.Name</option>
                        }
                    </select>
                </div>
            }
        </div>
    </header>

    @if (SelectedRestaurant == null)
    {
        <div class="live-empty">
            <div class="live-empty__card">
                <Blazicon Svg="Lucide.Store" class="live-empty__icon" />
                <h2 class="live-empty__title">Aucun restaurant sélectionné</h2>
                <p class="live-empty__text">Sélectionnez un restaurant pour commencer à recevoir les commandes en direct.</p>
            </div>
        </div>
    }
    else if (orders.Length == 0)
    {
        <div class="live-empty">
            <div class="live-empty__card">
                <Blazicon Svg="Lucide.ChefHat" class="live-empty__icon" />
                <h2 class="live-empty__title">Prêt pour le service !</h2>
                <p class="live-empty__text">Les commandes apparaîtront ici dès qu'elles seront passées.</p>
                <button class="app-btn app-btn--secondary mt-4" @onclick="LoadOrders">
                    <Blazicon Svg="Lucide.RefreshCcw" class="app-btn__icon" />
                    Actualiser
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="live-grid">
            @foreach (var order in orders)
            {
                <article class="order-card">
                    <header class="order-card__header">
                        <div class="order-card__id">
                            <span class="order-card__label">Commande</span>
                            <span class="order-card__number">#@order.Id</span>
                        </div>
                        <div class="order-card__status order-card__status--@order.Status.ToString().ToLower()">
                            @Translate(order.Status)
                        </div>
                    </header>

                    <div class="order-card__body">
                        @if (!string.IsNullOrWhiteSpace(order.DeliveryAddress))
                        {
                            <div class="order-card__info-item">
                                <Blazicon Svg="Lucide.MapPin" class="order-card__info-icon" />
                                <span class="order-card__info-text-sm">@order.DeliveryAddress</span>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(order.Notes))
                        {
                            <div class="order-card__info-item order-card__info-item--note">
                                <Blazicon Svg="Lucide.MessageSquare" class="order-card__info-icon" />
                                <span class="order-card__info-text">@order.Notes</span>
                            </div>
                        }

                        <div class="order-items">
                            <h3 class="order-items__title">Plats à préparer</h3>
                            <ul class="order-items__list">
                                @foreach (var item in order.Items)
                                {
                                    <li class="order-item">
                                        <div class="order-item__main">
                                            <span class="order-item__quantity">@item.Quantity ×</span>
                                            <span class="order-item__name">@item.DishName</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.SpecialInstructions))
                                        {
                                            <div class="order-item__instructions">
                                                <Blazicon Svg="Lucide.Info" class="order-item__instruction-icon" />
                                                @item.SpecialInstructions
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>

                    <footer class="order-card__footer">
                        <button class="app-btn app-btn--primary w-100" @onclick="() => MarkAsReady(order.Id)">
                            Prêt à livrer
                        </button>
                    </footer>
                </article>
            }
        </div>
    }
</div>