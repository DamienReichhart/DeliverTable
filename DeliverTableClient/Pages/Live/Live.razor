@page "/live"
@layout LiveLayout
@inherits ComponentBase
@using DeliverTableClient.Components.Order
@attribute [Authorize(Roles = nameof(UserRole.RestaurantOwner))]

<PageTitle>Service en direct — DeliverTable</PageTitle>

<div class="live-page">
    <header class="live-header">
        <div class="live-header__title-container">
            <h1 class="live-header__title">
                <Blazicon Svg="Lucide.Radio" class="live-header__icon" />
                Service en direct
            </h1>
            <p class="live-header__subtitle">Gérez vos commandes en temps réel</p>
        </div>

        <div class="live-header__actions">
            @if (restaurants.Length > 0)
            {
                <div class="restaurant-selector">
                    <Blazicon Svg="Lucide.Store" class="restaurant-selector__icon" />
                    <select class="restaurant-selector__select" 
                            value="@SelectedRestaurant" 
                            @onchange="@(async (e) => await OnRestaurantSelected(int.Parse(e.Value?.ToString() ?? "0")))">
                        @foreach (var restaurant in restaurants)
                        {
                            <option value="@restaurant.Id">@restaurant.Name</option>
                        }
                    </select>
                </div>
            }
        </div>
    </header>

    @if (SelectedRestaurant == null)
    {
        <div class="live-empty">
            <div class="live-empty__card">
                <Blazicon Svg="Lucide.Store" class="live-empty__icon" />
                <h2 class="live-empty__title">Aucun restaurant sélectionné</h2>
                <p class="live-empty__text">Sélectionnez un restaurant pour commencer à recevoir les commandes en direct.</p>
            </div>
        </div>
    }
    else
    {
        <div class="live-content">
            <main class="live-main">
                @if (orders.Length == 0)
                {
                    <div class="live-empty live-empty--inline">
                        <div class="live-empty__card">
                            <Blazicon Svg="Lucide.ChefHat" class="live-empty__icon" />
                            <h2 class="live-empty__title">Prêt pour le service !</h2>
                            <p class="live-empty__text">Les commandes apparaîtront ici dès qu'elles seront passées.</p>
                            <button class="app-btn app-btn--secondary mt-4" @onclick="LoadOrders">
                                <Blazicon Svg="Lucide.RefreshCcw" class="app-btn__icon" />
                                Actualiser
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="live-grid">
                        @foreach (var order in orders)
                        {
                            if (order.Status == nameof(OrderStatus.Pending) || order.Status == nameof(OrderStatus.Confirmed) || order.Status == nameof(OrderStatus.Preparing))
                            {
                                <OrderLiveCard Order="order" 
                                               OnOrderReady="MarkAsReady" 
                                               OnOrderConfirmed="MarkAsConfirmed" 
                                               OnOrderPreparing="MarkAsPreparing" />
                            }                        }
                    </div>
                }
            </main>
            
            <aside class="live-sidebar">
                <OrderSessionSummary Orders="finishedOrders" />
            </aside>
        </div>
    }
</div>