@page "/profil"
@using System.Security.Claims
@using DeliverTableClient.Services.Auth
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Auth

@inject IUserService UserService
@inject AuthService AuthService
@inject ApiAuthStateProvider AuthStateProvider
@inject IJSRuntime Js

<PageTitle>Mon Profil</PageTitle>

<AuthorizeView Context="auth">
    <Authorized >
        @if (_isLoading)
        {
            <div class="profile-loading centered">
                <div class="profile-spinner"></div>
                <p>Chargement du profil...</p>
            </div>
        }
        else if (_loadError != null)
        {
            <div class="container">
                <div class="alert alert-danger">@_loadError</div>
                <button class="app-btn" @onclick="LoadProfile">Réessayer</button>
            </div>
        }
        else
        {
            <div class="profile-page">
                @* ── Header ── *@
                <section class="profile-header">
                    <div class="profile-avatar">
                        <span>@_initials</span>
                    </div>
                    <div class="profile-header-info">
                        <h2 class="profile-name">@_profileModel.FirstName @_profileModel.LastName</h2>
                        <span class="profile-role">@auth.User.FindFirst(ClaimTypes.Role)?.Value</span>
                    </div>
                </section>

                @* ── Personal information card ── *@
                <section class="profile-card">
                    <div class="profile-card-header">
                        <h3>Informations personnelles</h3>
                        @if (!_isEditingProfile)
                        {
                            <button class="profile-card-action" @onclick="StartEditProfile">Modifier</button>
                        }
                    </div>

                    @if (_profileSuccess != null)
                    {
                        <div class="alert alert-success">@_profileSuccess</div>
                    }

                    @if (!_isEditingProfile)
                    {
                        <div class="profile-fields">
                            <div class="profile-field">
                                <span class="profile-field-label">Prénom</span>
                                <span class="profile-field-value">@_profileModel.FirstName</span>
                            </div>
                            <div class="profile-field">
                                <span class="profile-field-label">Nom</span>
                                <span class="profile-field-value">@_profileModel.LastName</span>
                            </div>
                            <div class="profile-field">
                                <span class="profile-field-label">Email</span>
                                <span class="profile-field-value">@_profileModel.Email</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@_profileModel" OnValidSubmit="HandleUpdateProfile">
                            <DataAnnotationsValidator />

                            <div class="profile-form-grid">
                                <div class="col">
                                    <label class="form-label" for="firstName">Prénom</label>
                                    <InputText id="firstName"
                                               @bind-Value="_profileModel.FirstName"
                                               class="form-control app-input"
                                               placeholder="Votre prénom" />
                                    <ValidationMessage For="@(() => _profileModel.FirstName)" class="validation-message" />
                                </div>

                                <div class="col">
                                    <label class="form-label" for="lastName">Nom</label>
                                    <InputText id="lastName"
                                               @bind-Value="_profileModel.LastName"
                                               class="form-control app-input"
                                               placeholder="Votre nom" />
                                    <ValidationMessage For="@(() => _profileModel.LastName)" class="validation-message" />
                                </div>
                            </div>

                            <div class="col mt-1">
                                <label class="form-label" for="email">Email</label>
                                <InputText id="email"
                                           @bind-Value="_profileModel.Email"
                                           class="form-control app-input"
                                           placeholder="votre@email.com" />
                                <ValidationMessage For="@(() => _profileModel.Email)" class="validation-message" />
                            </div>

                            <div class="profile-billing-section">
                                <h4 class="profile-billing-title">Adresse de facturation</h4>
                                <p class="profile-billing-help">
                                    Ces informations apparaissent sur vos factures et sont requises pour passer commande.
                                </p>

                                <div class="col mb-1">
                                    <label class="form-label" for="billing-line1">Adresse</label>
                                    <InputText id="billing-line1"
                                               @bind-Value="_profileModel.BillingAddressLine1"
                                               class="form-control app-input"
                                               placeholder="12 rue de la Paix" />
                                    <ValidationMessage For="@(() => _profileModel.BillingAddressLine1)" class="validation-message" />
                                </div>

                                <div class="col mb-1">
                                    <label class="form-label" for="billing-line2">Complément d'adresse (optionnel)</label>
                                    <InputText id="billing-line2"
                                               @bind-Value="_profileModel.BillingAddressLine2"
                                               class="form-control app-input"
                                               placeholder="Bât. B, 3ᵉ étage" />
                                    <ValidationMessage For="@(() => _profileModel.BillingAddressLine2)" class="validation-message" />
                                </div>

                                <div class="profile-form-grid">
                                    <div class="col">
                                        <label class="form-label" for="billing-postal">Code postal</label>
                                        <InputText id="billing-postal"
                                                   @bind-Value="_profileModel.BillingPostalCode"
                                                   class="form-control app-input"
                                                   placeholder="75002" />
                                        <ValidationMessage For="@(() => _profileModel.BillingPostalCode)" class="validation-message" />
                                    </div>

                                    <div class="col">
                                        <label class="form-label" for="billing-city">Ville</label>
                                        <InputText id="billing-city"
                                                   @bind-Value="_profileModel.BillingCity"
                                                   class="form-control app-input"
                                                   placeholder="Paris" />
                                        <ValidationMessage For="@(() => _profileModel.BillingCity)" class="validation-message" />
                                    </div>
                                </div>

                                <div class="col mt-1">
                                    <label class="form-label" for="billing-country">Pays</label>
                                    <InputText id="billing-country"
                                               @bind-Value="_profileModel.BillingCountry"
                                               class="form-control app-input"
                                               placeholder="France" />
                                    <ValidationMessage For="@(() => _profileModel.BillingCountry)" class="validation-message" />
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(_profileError))
                            {
                                <div class="alert alert-danger mt-1">@_profileError</div>
                            }

                            <div class="profile-form-actions">
                                <button type="button"
                                        class="app-btn profile-btn-cancel"
                                        @onclick="CancelEditProfile"
                                        disabled="@_isSavingProfile">
                                    Annuler
                                </button>
                                <button type="submit"
                                        class="app-btn"
                                        disabled="@_isSavingProfile">
                                    @if (_isSavingProfile)
                                    {
                                        <span class="profile-spinner-sm"></span>
                                        <span>Enregistrement...</span>
                                    }
                                    else
                                    {
                                        <span>Enregistrer</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    }
                </section>

                @* ── Password card ── *@
                <section class="profile-card">
                    <div class="profile-card-header">
                        <h3>Mot de passe</h3>
                        @if (!_isEditingPassword)
                        {
                            <button class="profile-card-action" @onclick="StartEditPassword">Modifier</button>
                        }
                    </div>

                    @if (_passwordSuccess != null)
                    {
                        <div class="alert alert-success">@_passwordSuccess</div>
                    }

                    @if (!_isEditingPassword)
                    {
                        <div class="profile-fields">
                            <div class="profile-field">
                                <span class="profile-field-label">Mot de passe</span>
                                <span class="profile-field-value profile-field-password">••••••••••••</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@_passwordModel" OnValidSubmit="HandleChangePassword">
                            <DataAnnotationsValidator />

                            <div class="col mb-1">
                                <label class="form-label" for="currentPassword">Mot de passe actuel</label>
                                <InputText id="currentPassword"
                                           @bind-Value="_passwordModel.CurrentPassword"
                                           type="password"
                                           class="form-control app-input"
                                           placeholder="••••••••••••" />
                                <ValidationMessage For="@(() => _passwordModel.CurrentPassword)" class="validation-message" />
                            </div>

                            <div class="col mb-1">
                                <label class="form-label" for="newPassword">Nouveau mot de passe (12 caractères min.)</label>
                                <InputText id="newPassword"
                                           @bind-Value="_passwordModel.NewPassword"
                                           type="password"
                                           class="form-control app-input"
                                           placeholder="••••••••••••" />
                                <ValidationMessage For="@(() => _passwordModel.NewPassword)" class="validation-message" />
                            </div>

                            <div class="col mb-1">
                                <label class="form-label" for="confirmNewPassword">Confirmer le nouveau mot de passe</label>
                                <InputText id="confirmNewPassword"
                                           @bind-Value="_passwordModel.ConfirmNewPassword"
                                           type="password"
                                           class="form-control app-input"
                                           placeholder="••••••••••••" />
                                <ValidationMessage For="@(() => _passwordModel.ConfirmNewPassword)" class="validation-message" />
                            </div>

                            @if (!string.IsNullOrEmpty(_passwordError))
                            {
                                <div class="alert alert-danger">@_passwordError</div>
                            }

                            <div class="profile-form-actions">
                                <button type="button"
                                        class="app-btn profile-btn-cancel"
                                        @onclick="CancelEditPassword"
                                        disabled="@_isSavingPassword">
                                    Annuler
                                </button>
                                <button type="submit"
                                        class="app-btn"
                                        disabled="@_isSavingPassword">
                                    @if (_isSavingPassword)
                                    {
                                        <span class="profile-spinner-sm"></span>
                                        <span>Modification...</span>
                                    }
                                    else
                                    {
                                        <span>Modifier le mot de passe</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    }
                </section>

                @* ── Quick link to restaurant management (RestaurantOwner only) ── *@
                <AuthorizeView Roles="@nameof(UserRole.RestaurantOwner)" Context="ownerCtx">
                    <section class="profile-card">
                        <div class="profile-card-header">
                            <h3>Mes restaurants</h3>
                            <NavLink href="/mes-restaurants" class="profile-card-action">
                                Gérer
                            </NavLink>
                        </div>
                        <p class="profile-field-label" style="padding: 0.25rem 0;">
                            Accédez à la gestion de vos restaurants pour ajouter, modifier ou supprimer vos établissements.
                        </p>
                    </section>
                </AuthorizeView>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container centered" style="min-height: 60vh;">
            <div class="profile-card" style="max-width: 400px; text-align: center;">
                <h3>Accès refusé</h3>
                <p class="mt-1">Vous devez être connecté pour accéder à votre profil.</p>
                <NavLink href="/login" class="app-btn mt-1">Se connecter</NavLink>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
