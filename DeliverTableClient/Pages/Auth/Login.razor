@page "/login"
@using DeliverTableSharedLibrary.Dtos.Auth
@inject AuthService AuthService
@inject NavigationManager Nav   

<div class="container mt-5 centered screen-h-70">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="col p-4">
                    <h3 class="card-title text-center mb-2">Connexion</h3>

                    <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
                        <DataAnnotationsValidator />

                        <div class="mb-1 col">
                            <label class="form-label fw-bold">Email</label>
                            @* On applique la classe .app-input de ton CSS *@
                            <InputText @bind-Value="_loginModel.Email" 
                                       class="form-control app-input" 
                                       placeholder="votre@email.com" />
                            @* Blazor générera automatiquement .validation-message s'il y a une erreur *@
                            <ValidationMessage For="@(() => _loginModel.Email)" class="validation-message" />
                        </div>

                        <div class="mb-1 col">
                            <label class="form-label fw-bold">Mot de passe</label>
                            <InputText @bind-Value="_loginModel.Password" 
                                       type="password" 
                                       class="form-control app-input" 
                                       placeholder="••••••••••••" />
                            <ValidationMessage For="@(() => _loginModel.Password)" class="validation-message" />
                        </div>
                        
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            @* On utilise ici aussi la classe invalid pour la cohérence visuelle *@
                            <div class="alert alert-danger invalid-feedback d-block mb-3">
                                <span class="app-icon">⚠️</span> @_errorMessage
                            </div>
                        }

                        <button type="submit" class="app-btn w-full" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span class="ms-2">Chargement...</span>
                            }
                            else
                            {
                                <span>Se connecter</span>
                            }
                        </button>
                    </EditForm>
                    
                    <div class="mt-4 text-center">
                        <p class="text-muted small">
                            Pas encore de compte ? <a href="/register" class="text-primary text-decoration-none fw-bold">S'inscrire</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Instance du DTO servant de modèle au formulaire
    private LoginRequest _loginModel = new LoginRequest();
    private string? _errorMessage;
    private bool _isSubmitting = false;

    private async Task HandleLogin()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var success = await AuthService.Login(_loginModel);

            if (success.Success)
            {
                // Redirige vers l'accueil ou la page précédente après succès
                Nav.NavigateTo("/");
            }
            else
            {
                _errorMessage = "Email ou mot de passe incorrect.";
            }
        }
        catch
        {
            _errorMessage = "Une erreur est survenue lors de la connexion.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}