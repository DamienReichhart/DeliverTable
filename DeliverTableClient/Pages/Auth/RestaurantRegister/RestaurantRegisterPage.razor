@page "/owner/register"
@layout AuthLayout
@using DeliverTableSharedLibrary.Dtos.Auth
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Inscription Gérant — DeliverTable</PageTitle>

<div class="auth-split">
    <section class="auth-showcase">
        <div class="showcase-cards">
            <div class="showcase-card showcase-card--1">
                <div class="showcase-card-icon showcase-card-icon--coral">
                    <Blazicon Svg="Lucide.UtensilsCrossed" />
                </div>
                <div>
                    <p class="showcase-card-name">Truffle Tagliatelle</p>
                    <p class="showcase-card-meta">La Bottega · Italian</p>
                    <p class="showcase-card-price">€24.00</p>
                    <p class="showcase-card-rating">★ 4.9</p>
                </div>
            </div>

            <div class="showcase-card showcase-card--2">
                <div class="showcase-card-icon showcase-card-icon--sage">
                    <Blazicon Svg="Lucide.Flame" />
                </div>
                <div>
                    <p class="showcase-card-name">Wagyu Steak</p>
                    <p class="showcase-card-meta">Le Boeuf · Steakhouse</p>
                    <p class="showcase-card-price">€42.00</p>
                </div>
            </div>

            <div class="showcase-card showcase-card--3">
                <div class="showcase-card-icon showcase-card-icon--gold">
                    <Blazicon Svg="Lucide.Globe" />
                </div>
                <div>
                    <p class="showcase-card-name">Omakase Set</p>
                    <p class="showcase-card-meta">Sakura · Japanese</p>
                    <p class="showcase-card-price">€38.00</p>
                    <p class="showcase-card-rating">★ 5.0</p>
                </div>
            </div>
        </div>

        <div class="showcase-content">
            <h1 class="showcase-tagline">
                Every meal<br/>
                deserves a <span class="text-accent">proper<br/>table.</span>
            </h1>
            <p class="showcase-description">
                Discover restaurants, book your table, pre-order your meal
                — all in one place. From intimate dinners to grand events.
            </p>
            <div class="showcase-stats">
                <div class="showcase-stat">
                    <span class="showcase-stat-value">2,400+</span>
                    <span class="showcase-stat-label">Restaurants</span>
                </div>
                <div class="showcase-stat">
                    <span class="showcase-stat-value">180k+</span>
                    <span class="showcase-stat-label">Bookings</span>
                </div>
                <div class="showcase-stat">
                    <span class="showcase-stat-value">4.8</span>
                    <span class="showcase-stat-label">Avg Rating</span>
                </div>
            </div>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-panel-content">
            <div class="auth-brand">
                <svg class="auth-brand-logo" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 4L25 22H3L14 4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                    <line x1="7" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span class="auth-brand-text">Deliver<em>Table</em></span>
            </div>

            <h2 class="auth-heading">Espace gérant</h2>
            <p class="auth-subheading">Référencez votre restaurant et touchez de nouveaux clients</p>

            <EditForm Model="@_restaurantRegisterModel" OnValidSubmit="HandleRestaurantOwnerRegister" class="auth-form">
                <DataAnnotationsValidator />

                <div class="auth-field">
                    <label class="auth-label">Prénom</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.User" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.FirstName"
                                   class="auth-input"
                                   placeholder="Votre prénom" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.FirstName)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Nom</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.User" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.LastName"
                                   class="auth-input"
                                   placeholder="Votre nom" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.LastName)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Adresse email</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Mail" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.Email"
                                   class="auth-input"
                                   placeholder="votre@email.com" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.Email)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Nom de l'enseigne</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Store" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.CompanyName"
                                   class="auth-input"
                                   placeholder="Nom du restaurant" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.CompanyName)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">N° de téléphone</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Phone" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.ContactPhoneNumber"
                                   class="auth-input"
                                   placeholder="+33 6 00 00 00 00" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.ContactPhoneNumber)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">N° de SIRET</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.FileText" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.VatNumber"
                                   class="auth-input"
                                   placeholder="N° de SIRET" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.VatNumber)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Mot de passe (12 caractères min.)</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Lock" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.Password"
                                   type="password"
                                   class="auth-input"
                                   placeholder="••••••••••••" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.Password)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Confirmer le mot de passe</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Lock" class="auth-input-icon" />
                        <InputText @bind-Value="_restaurantRegisterModel.ConfirmPassword"
                                   type="password"
                                   class="auth-input"
                                   placeholder="••••••••••••" />
                    </div>
                    <ValidationMessage For="@(() => _restaurantRegisterModel.ConfirmPassword)" class="validation-message" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger">@_errorMessage</div>
                }

                <button type="submit" class="auth-submit" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="auth-spinner"></span>
                        <span>Création du compte...</span>
                    }
                    else
                    {
                        <span>Créer mon compte gérant</span>
                    }
                </button>
            </EditForm>

            <p class="auth-footer">
                Déjà un compte ? <a href="/login">Connectez-vous</a>
            </p>
        </div>
    </section>
</div>

@code {
    private RestaurantRegister _restaurantRegisterModel = new RestaurantRegister();
    private bool _isSubmitting = false;
    private string? _errorMessage;

    private async Task HandleRestaurantOwnerRegister()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            AuthResponse? response = await AuthService.RegisterRestaurant(_restaurantRegisterModel);

            if (response.Success)
            {
                Nav.NavigateTo("/");
                return;
            }
            _errorMessage = response.Error;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
