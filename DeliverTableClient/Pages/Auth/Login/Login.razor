@page "/login"
@layout AuthLayout
@using DeliverTableSharedLibrary.Dtos.Auth
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Connexion — DeliverTable</PageTitle>

<div class="auth-split">
    <section class="auth-showcase">
        <div class="showcase-cards">
            <div class="showcase-card showcase-card--1">
                <div class="showcase-card-icon showcase-card-icon--coral">
                    <Blazicon Svg="Lucide.UtensilsCrossed" />
                </div>
                <div>
                    <p class="showcase-card-name">Truffle Tagliatelle</p>
                    <p class="showcase-card-meta">La Bottega · Italian</p>
                    <p class="showcase-card-price">€24.00</p>
                    <p class="showcase-card-rating">★ 4.9</p>
                </div>
            </div>

            <div class="showcase-card showcase-card--2">
                <div class="showcase-card-icon showcase-card-icon--sage">
                    <Blazicon Svg="Lucide.Flame" />
                </div>
                <div>
                    <p class="showcase-card-name">Wagyu Steak</p>
                    <p class="showcase-card-meta">Le Boeuf · Steakhouse</p>
                    <p class="showcase-card-price">€42.00</p>
                </div>
            </div>

            <div class="showcase-card showcase-card--3">
                <div class="showcase-card-icon showcase-card-icon--gold">
                    <Blazicon Svg="Lucide.Globe" />
                </div>
                <div>
                    <p class="showcase-card-name">Omakase Set</p>
                    <p class="showcase-card-meta">Sakura · Japanese</p>
                    <p class="showcase-card-price">€38.00</p>
                    <p class="showcase-card-rating">★ 5.0</p>
                </div>
            </div>
        </div>

        <div class="showcase-content">
            <h1 class="showcase-tagline">
                Every meal<br/>
                deserves a <span class="text-accent">proper<br/>table.</span>
            </h1>
            <p class="showcase-description">
                Discover restaurants, book your table, pre-order your meal
                — all in one place. From intimate dinners to grand events.
            </p>
            <div class="showcase-stats">
                <div class="showcase-stat">
                    <span class="showcase-stat-value">2,400+</span>
                    <span class="showcase-stat-label">Restaurants</span>
                </div>
                <div class="showcase-stat">
                    <span class="showcase-stat-value">180k+</span>
                    <span class="showcase-stat-label">Bookings</span>
                </div>
                <div class="showcase-stat">
                    <span class="showcase-stat-value">4.8</span>
                    <span class="showcase-stat-label">Avg Rating</span>
                </div>
            </div>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-panel-content">
            <div class="auth-brand">
                <svg class="auth-brand-logo" viewBox="0 0 53 53" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path opacity="0.15" d="M26.4 48.3999C38.5503 48.3999 48.4 38.5502 48.4 26.3999C48.4 14.2496 38.5503 4.3999 26.4 4.3999C14.2498 4.3999 4.40002 14.2496 4.40002 26.3999C4.40002 38.5502 14.2498 48.3999 26.4 48.3999Z" stroke="#1A1A2E" stroke-width="0.88"/>
                    <path d="M15.3998 29.9201C15.3998 21.1201 19.0665 15.8401 26.3998 14.0801C33.7332 15.8401 37.3998 21.1201 37.3998 29.9201" stroke="#E85D3A" stroke-width="1.1" stroke-linecap="round"/>
                    <path d="M13.2 29.9199H39.6" stroke="#E85D3A" stroke-width="1.1" stroke-linecap="round"/>
                    <path opacity="0.4" d="M21.9999 12.32C22.5865 10.56 22.5865 8.80004 21.9999 7.04004" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
                    <path opacity="0.4" d="M26.4 11.4397C26.9866 9.67967 26.9866 7.91967 26.4 6.15967" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
                    <path opacity="0.4" d="M30.8 12.32C31.3867 10.56 31.3867 8.80004 30.8 7.04004" stroke="#E85D3A" stroke-width="0.66" stroke-linecap="round"/>
                    <path opacity="0.6" d="M26.4001 36.9599C27.3721 36.9599 28.1601 36.172 28.1601 35.1999C28.1601 34.2279 27.3721 33.4399 26.4001 33.4399C25.4281 33.4399 24.6401 34.2279 24.6401 35.1999C24.6401 36.172 25.4281 36.9599 26.4001 36.9599Z" fill="#E85D3A"/>
                </svg>
                <span class="auth-brand-text">Deliver<em>Table</em></span>
            </div>

            <div class="auth-tabs">
                <a href="/login" class="auth-tab auth-tab--active">Se connecter</a>
                <a href="/register" class="auth-tab">Créer un compte</a>
            </div>

            <h2 class="auth-heading">Bon retour</h2>
            <p class="auth-subheading">Connectez-vous pour accéder à votre compte</p>

            <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin" class="auth-form">
                <DataAnnotationsValidator />

                <div class="auth-field">
                    <label class="auth-label">Adresse email</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Mail" class="auth-input-icon" />
                        <InputText @bind-Value="_loginModel.Email"
                                   class="auth-input"
                                   placeholder="votre@email.com" />
                    </div>
                    <ValidationMessage For="@(() => _loginModel.Email)" class="validation-message" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">Mot de passe</label>
                    <div class="auth-input-wrapper">
                        <Blazicon Svg="Lucide.Lock" class="auth-input-icon" />
                        <InputText @bind-Value="_loginModel.Password"
                                   type="password"
                                   class="auth-input"
                                   placeholder="••••••••••" />
                    </div>
                    <ValidationMessage For="@(() => _loginModel.Password)" class="validation-message" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <AppAlert>@_errorMessage</AppAlert>
                }

                <button type="submit" class="auth-submit" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="auth-spinner"></span>
                        <span>Chargement...</span>
                    }
                    else
                    {
                        <span>Se connecter</span>
                    }
                </button>
            </EditForm>

            <p class="auth-footer">
                Pas encore de compte ? <a href="/register">Créer un compte gratuitement</a>
            </p>
        </div>
    </section>
</div>

@code {
    private LoginRequest _loginModel = new LoginRequest();
    private string? _errorMessage;
    private bool _isSubmitting = false;

    private async Task HandleLogin()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            AuthResponse? response = await AuthService.Login(_loginModel);

            if (response?.Success ?? false)
            {
                Nav.NavigateTo(uri: "/");
            }
            else
            {
                _errorMessage = "Email ou mot de passe incorrect.";
            }
        }
        catch
        {
            _errorMessage = "Une erreur est survenue lors de la connexion.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
