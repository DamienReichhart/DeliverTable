@page "/restaurant/update/{Id:int}"
@using DeliverTableClient.Components.Dish
@using DeliverTableSharedLibrary.Dtos.Restaurant
@using DeliverTableSharedLibrary.Validation
@inject IRestaurantService RestaurantService
@inject NavigationManager NavigationManager

<div class="form-container">
    @if (loading)
    {
        <p>Loading...</p>
    }
    else if (error != null)
    {
        <div class="alert alert-danger">@error</div>
    }
    else
    {
        <h2>Mettre à jour @form.Name</h2>
        <div class="form-group">
            <label>Nom du restaurant</label>
            <input class="form-control" placeholder="Nom du restaurant" @bind="form.Name" />
        </div>
        <div class="form-group">
            <label>Adresse de l'établissement</label>
            <input class="form-control" placeholder="Adresse de l'établissement" @bind="form.AdressLine1" />
        </div>
        <div class="form-group">
            <label>Complément d'adresse</label>
            <input class="form-control" placeholder="Complément d'adresse" @bind="form.AdressLine2" />
        </div>
        <div class="form-group">
            <label>Ville</label>
            <input class="form-control" placeholder="Ville" @bind="form.City" />
        </div>
        <div class="form-group">
            <label>Code Postal</label>
            <input class="form-control" placeholder="Code Postal" @bind="form.ZipCode" />
        </div>
        <div class="form-group">
            <label>Numéro SIRET</label>
            <input class="form-control" placeholder="14 chiffres" maxlength="14" @bind="form.Siret" />
            @if (siretError != null)
            {
                <span class="text-danger">@siretError</span>
            }
        </div>
        <div class="form-group">
            <label>Raison sociale</label>
            <input class="form-control" placeholder="Raison sociale" @bind="form.LegalName" />
        </div>
        <div class="form-group">
            <label>Adresse légale</label>
            <input class="form-control" placeholder="Adresse légale" @bind="form.LegalAddress" />
        </div>
        <div class="form-group">
            <label>Forme juridique</label>
            <select class="form-control" @bind="form.LegalForm">
                <option value="">-- Sélectionnez une forme juridique --</option>
                <option value="SAS">SAS</option>
                <option value="SARL">SARL</option>
                <option value="EURL">EURL</option>
                <option value="EI">EI</option>
                <option value="SA">SA</option>
            </select>
        </div>
        <div class="form-group">
            <label>
                <input type="checkbox" @bind="form.IsVatRegistered" />
                TVA applicable
            </label>
        </div>
        @if (submitError != null)
        {
            <div class="alert alert-danger">@submitError</div>
        }
        @if (error != null)
        {
            <div class="alert alert-danger">@error</div>
        }
        <div class="form-controls">
            <button class="app-btn my-2 mx-auto" @onclick="HandleSubmit" disabled="@submitting">
                @(submitting ? "Vérification..." : "Enregistrer")
            </button>
            <NavLink href="/mes-restaurants" class="app-btn bg-secondary">Revenir en arrière</NavLink>
        </div>

        <hr class="my-5" />

        <DishManagement RestaurantId="Id" />
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private DetailedRestaurantDto form = new();
    private bool loading = true;
    private bool submitting = false;
    private string? error = null;
    private string? submitError = null;
    private string? siretError = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            (DetailedRestaurantDto? dto, ErrorResponse? error) result = await RestaurantService.GetRestaurantById(Id);

            if (result.dto != null)
            {
                form = result.dto;
            }
        }
        catch (Exception)
        {
            error = "Une erreur est survenue";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        submitting = true;
        submitError = null;
        siretError = null;

        if (!SiretValidator.IsValid(form.Siret))
        {
            siretError = "Le numéro SIRET est invalide.";
            submitting = false;
            return;
        }

        try
        {
            UpdateRestaurantDto updateDto = new()
            {
                Name = form.Name,
                AdressLine1 = form.AdressLine1,
                AdressLine2 = form.AdressLine2,
                City = form.City,
                Country = form.Country,
                ZipCode = form.ZipCode,
                Description = form.Description,
                Siret = form.Siret,
                LegalName = form.LegalName,
                LegalAddress = form.LegalAddress,
                LegalForm = form.LegalForm,
                IsVatRegistered = form.IsVatRegistered,
            };
            (DetailedRestaurantDto? result, ErrorResponse? errorObject) = await RestaurantService.UpdateRestaurant(updateDto, Id);

            if (errorObject?.Error?.Contains("SIRET") == true)
            {
                siretError = "Le numéro SIRET est invalide.";
            }

            if (errorObject != null)
            {
                submitError = errorObject.Error;
            }
            else
            {
                NavigationManager.NavigateTo("/mes-restaurants");
            }
        }
        catch (Exception)
        {
            submitError = "Une erreur est survenue";
        }
        finally
        {
            submitting = false;
        }
    }
}