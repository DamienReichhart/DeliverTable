@page "/restaurant/{RestaurantId:int}/creneau"
@inject IRestaurantOrderConfigClientService OrderConfigService
@inject IRestaurantService RestaurantService
@inject NavigationManager Nav
@using DeliverTableSharedLibrary.Dtos.Admin
@using DeliverTableSharedLibrary.Dtos.Restaurant
@attribute [Authorize(Roles = nameof(UserRole.RestaurantOwner))]

<PageTitle>Créneaux bloqués — @(_restaurantName ?? "Restaurant") — DeliverTable</PageTitle>

<div class="restaurant-blocked-slots-page">
    <div class="page-header">
        <div>
            <h1>Créneaux bloqués</h1>
            @if (_restaurantName is not null)
            {
                <p class="page-subtitle">@_restaurantName</p>
            }
        </div>
        <div class="page-header-actions">
            <button type="button" class="app-btn app-btn--primary" @onclick="OpenCreateForm">
                Bloquer un créneau
            </button>
            <button type="button" class="app-btn app-btn--secondary" @onclick="GoBack">
                Retour
            </button>
        </div>
    </div>

    <div class="capacity-settings-card">
        <h2>Capacité de tables</h2>
        <p class="capacity-settings-hint">
            Définissez le nombre maximum de tables réservables par créneau.
            Une table compte automatiquement pour 2 personnes.
            Valeur de référence (tables actives): @Math.Max(1, _activeTablesFallback)
        </p>
        <div class="capacity-settings-controls">
            <InputNumber @bind-Value="_tablesCapacityPerSlot" class="form-control capacity-input" />
            <button type="button" class="app-btn app-btn--primary" @onclick="SaveTablesCapacity" disabled="@_savingCapacity">
                Enregistrer
            </button>
        </div>
    </div>

    <div class="opening-hours-card">
        <h2>Horaires d'ouverture</h2>
        <p class="capacity-settings-hint">
            Définissez les horaires hebdomadaires. Vous pouvez ajouter plusieurs créneaux par jour.
        </p>

        <div class="opening-hours-top-controls">
            <label for="slot-duration">Durée d'un créneau (minutes)</label>
            <InputNumber id="slot-duration" @bind-Value="_openingSlotDurationMinutes" class="form-control capacity-input" />
        </div>

        <div class="opening-days-list">
            @for (var dayIndex = 0; dayIndex < _openingHoursDays.Count; dayIndex++)
            {
                var currentDayIndex = dayIndex;
                var day = _openingHoursDays[currentDayIndex];
                <div class="opening-day-card">
                    <div class="opening-day-header">
                        <h3>@GetDayLabel(day.DayOfWeek)</h3>
                        <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="() => AddOpeningSlot(currentDayIndex)">
                            Ajouter un créneau
                        </button>
                    </div>

                    @if (day.Slots.Count == 0)
                    {
                        <p class="opening-day-empty">Fermé</p>
                    }
                    else
                    {
                        @for (var slotIndex = 0; slotIndex < day.Slots.Count; slotIndex++)
                        {
                            var currentSlotIndex = slotIndex;
                            var slot = day.Slots[currentSlotIndex];

                            <div class="opening-slot-row">
                                <input type="time"
                                       class="form-control"
                                       value="@slot.StartTime"
                                       @oninput="e => UpdateOpeningSlotStart(currentDayIndex, currentSlotIndex, e.Value?.ToString())" />
                                <span>à</span>
                                <input type="time"
                                       class="form-control"
                                       value="@slot.EndTime"
                                       @oninput="e => UpdateOpeningSlotEnd(currentDayIndex, currentSlotIndex, e.Value?.ToString())" />
                                <button type="button" class="app-btn app-btn--danger app-btn--sm opening-slot-remove" title="Supprimer" @onclick="() => RemoveOpeningSlot(currentDayIndex, currentSlotIndex)">
                                    <Blazicon Svg="Lucide.Trash2" class="app-icon" />
                                </button>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <div class="capacity-settings-controls">
            <button type="button" class="app-btn app-btn--primary" @onclick="SaveOpeningHours" disabled="@_savingOpeningHours">
                Enregistrer les horaires
            </button>
        </div>
    </div>

    @* ── Bloquer un créneau (modal) ── *@
    <AdminFormModal IsVisible="@_showCreateForm" Title="Bloquer un créneau" OnClose="CloseCreateForm">
        <ChildContent>
            <EditForm Model="_createRequest" OnValidSubmit="CreateBlockedSlot">
                <DataAnnotationsValidator />
                <div class="adm-form-row">
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="slot-start">Date de début</label>
                        <InputDate id="slot-start" @bind-Value="_createRequest.StartsAt"
                                   Type="InputDateType.DateTimeLocal" class="adm-form-input" />
                        <ValidationMessage For="@(() => _createRequest.StartsAt)" class="adm-form-error" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="slot-end">Date de fin</label>
                        <InputDate id="slot-end" @bind-Value="_createRequest.EndsAt"
                                   Type="InputDateType.DateTimeLocal" class="adm-form-input" />
                        <ValidationMessage For="@(() => _createRequest.EndsAt)" class="adm-form-error" />
                    </div>
                </div>
                <div class="adm-form-group">
                    <label class="adm-form-label" for="slot-reason">Raison</label>
                    <InputTextArea id="slot-reason" @bind-Value="_createRequest.Reason"
                                   class="adm-form-input" placeholder="Raison du blocage" rows="2" />
                </div>
                @if (_error is not null)
                {
                    <div class="adm-form-error">@_error</div>
                }
                <div class="adm-form-actions">
                    <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseCreateForm" disabled="@_saving">
                        Annuler
                    </button>
                    <button type="submit" class="app-btn app-btn--sm" disabled="@_saving">
                        @(_saving ? "Création..." : "Bloquer")
                    </button>
                </div>
            </EditForm>
        </ChildContent>
    </AdminFormModal>

    @if (_loading)
    {
        <p>Chargement des créneaux bloqués...</p>
    }
    else if (_error is not null)
    {
        <div class="error-message">
            <p>@_error</p>
        </div>
    }
    else if (_blockedSlots is null || _blockedSlots.Count == 0)
    {
        <div class="empty-state">
            <p>Aucun créneau bloqué pour le moment.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Début</th>
                        <th>Fin</th>
                        <th>Raison</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var slot in _blockedSlots)
                    {
                        <tr>
                            <td>@slot.StartsAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@slot.EndsAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(slot.Reason) ? "—" : slot.Reason)</td>
                            <td class="actions-cell">
                                <button type="button" class="app-btn app-btn--danger app-btn--sm" @onclick="() => DeleteBlockedSlot(slot.Id)">
                                    Supprimer
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private List<AdminBlockedSlotResponse>? _blockedSlots;
    private string? _restaurantName;
    private string? _error;
    private bool _loading = true;
    private bool _showCreateForm;
    private bool _saving;
    private bool _savingCapacity;
    private bool _savingOpeningHours;
    private int _tablesCapacityPerSlot;
    private int _activeTablesFallback;
    private int _openingSlotDurationMinutes = 60;
    private List<OpeningDayScheduleDto> _openingHoursDays = BuildDefaultOpeningDays();

    private AdminCreateBlockedSlotRequest _createRequest = new();

    protected override async Task OnInitializedAsync()
    {
        var (restaurant, _) = await RestaurantService.GetRestaurantById(RestaurantId);
        _restaurantName = restaurant?.Name;

        await LoadOpeningHours();
        await LoadTablesCapacity();
        await LoadBlockedSlots();
    }

    private async Task LoadOpeningHours()
    {
        var (openingHours, error) = await OrderConfigService.GetOpeningHoursAsync(RestaurantId);
        if (error is not null)
        {
            _error = error.Error;
            return;
        }

        if (openingHours is null)
            return;

        _openingSlotDurationMinutes = openingHours.SlotDurationMinutes;
        _openingHoursDays = openingHours.Days.Count > 0
            ? openingHours.Days.OrderBy(d => d.DayOfWeek).ToList()
            : BuildDefaultOpeningDays();
    }

    private async Task LoadTablesCapacity()
    {
        var (capacity, error) = await OrderConfigService.GetTablesCapacityAsync(RestaurantId);
        if (error is not null)
        {
            _error = error.Error;
            return;
        }

        if (capacity is null)
            return;

        _tablesCapacityPerSlot = capacity.CapacityPerSlot;
        _activeTablesFallback = capacity.ActiveTablesFallback;
    }

    private async Task LoadBlockedSlots()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (slots, error) = await OrderConfigService.GetBlockedSlotsAsync(RestaurantId);

        if (error is not null)
            _error = error.Error;
        else
            _blockedSlots = slots ?? [];

        _loading = false;
        StateHasChanged();
    }

    private void OpenCreateForm()
    {
        var start = DateTime.Today.AddHours(12);
        _createRequest = new AdminCreateBlockedSlotRequest
        {
            RestaurantId = RestaurantId,
            StartsAt = start,
            EndsAt = start.AddHours(1)
        };
        _showCreateForm = true;
        _error = null;
    }

    private void CloseCreateForm()
    {
        _showCreateForm = false;
        _error = null;
    }

    private async Task CreateBlockedSlot()
    {
        _saving = true;
        _error = null;

        var request = new AdminCreateBlockedSlotRequest
        {
            RestaurantId = RestaurantId,
            StartsAt = DateTime.SpecifyKind(_createRequest.StartsAt, DateTimeKind.Local).ToUniversalTime(),
            EndsAt = DateTime.SpecifyKind(_createRequest.EndsAt, DateTimeKind.Local).ToUniversalTime(),
            Reason = _createRequest.Reason
        };

        var (created, error) = await OrderConfigService.CreateBlockedSlotAsync(RestaurantId, request);

        if (created is null)
        {
            _error = error?.Error ?? "Erreur lors de la création du créneau bloqué.";
            _saving = false;
            return;
        }

        _showCreateForm = false;
        _saving = false;
        await LoadBlockedSlots();
    }

    private async Task DeleteBlockedSlot(int slotId)
    {
        var (success, error) = await OrderConfigService.DeleteBlockedSlotAsync(RestaurantId, slotId);

        if (!success)
        {
            _error = error?.Error ?? "Erreur lors de la suppression du créneau bloqué.";
            StateHasChanged();
            return;
        }

        await LoadBlockedSlots();
    }

    private async Task SaveTablesCapacity()
    {
        _savingCapacity = true;
        _error = null;

        var request = new UpdateTablesCapacityRequest
        {
            CapacityPerSlot = _tablesCapacityPerSlot
        };

        var (capacity, error) = await OrderConfigService.UpdateTablesCapacityAsync(RestaurantId, request);
        if (error is not null || capacity is null)
        {
            _error = error?.Error ?? "Erreur lors de la mise à jour de la capacité.";
            _savingCapacity = false;
            return;
        }

        _tablesCapacityPerSlot = capacity.CapacityPerSlot;
        _activeTablesFallback = capacity.ActiveTablesFallback;
        _savingCapacity = false;
    }

    private async Task SaveOpeningHours()
    {
        _savingOpeningHours = true;
        _error = null;

        var request = new UpdateRestaurantOpeningHoursRequest
        {
            SlotDurationMinutes = _openingSlotDurationMinutes,
            Days = _openingHoursDays
                .OrderBy(d => d.DayOfWeek)
                .Select(d => new OpeningDayScheduleDto
                {
                    DayOfWeek = d.DayOfWeek,
                    Slots = d.Slots.Select(s => new OpeningHourSlotDto
                    {
                        StartTime = s.StartTime,
                        EndTime = s.EndTime
                    }).ToList()
                }).ToList()
        };

        var (_, error) = await OrderConfigService.UpdateOpeningHoursAsync(RestaurantId, request);
        if (error is not null)
        {
            _error = error.Error;
            _savingOpeningHours = false;
            return;
        }

        _savingOpeningHours = false;
    }

    private void AddOpeningSlot(int dayIndex)
    {
        _openingHoursDays[dayIndex].Slots.Add(new OpeningHourSlotDto
        {
            StartTime = "12:00",
            EndTime = "13:00"
        });
    }

    private void RemoveOpeningSlot(int dayIndex, int slotIndex)
    {
        if (slotIndex < 0 || slotIndex >= _openingHoursDays[dayIndex].Slots.Count)
            return;

        _openingHoursDays[dayIndex].Slots.RemoveAt(slotIndex);
    }

    private void UpdateOpeningSlotStart(int dayIndex, int slotIndex, string? value)
    {
        _openingHoursDays[dayIndex].Slots[slotIndex].StartTime = value ?? "00:00";
    }

    private void UpdateOpeningSlotEnd(int dayIndex, int slotIndex, string? value)
    {
        _openingHoursDays[dayIndex].Slots[slotIndex].EndTime = value ?? "00:00";
    }

    private static string GetDayLabel(int dayOfWeek)
    {
        return dayOfWeek switch
        {
            0 => "Lundi",
            1 => "Mardi",
            2 => "Mercredi",
            3 => "Jeudi",
            4 => "Vendredi",
            5 => "Samedi",
            6 => "Dimanche",
            _ => "Jour"
        };
    }

    private static List<OpeningDayScheduleDto> BuildDefaultOpeningDays()
    {
        var list = new List<OpeningDayScheduleDto>();
        for (var day = 0; day <= 6; day++)
        {
            list.Add(new OpeningDayScheduleDto
            {
                DayOfWeek = day,
                Slots = []
            });
        }

        return list;
    }

    private void GoBack() => Nav.NavigateTo("/mes-restaurants");
}