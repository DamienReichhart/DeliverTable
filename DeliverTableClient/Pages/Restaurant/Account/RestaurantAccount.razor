@page "/restaurant/{RestaurantId:int}/compte"
@inject IRestaurantAccountService AccountService
@inject IRestaurantService RestaurantService
@inject IDishService DishService
@inject NavigationManager Nav
@attribute [Authorize(Roles = nameof(UserRole.RestaurantOwner))]
@using DeliverTableClient.Services.CommissionStatement
@using DeliverTableClient.Services.Dispute
@using DeliverTableSharedLibrary.Dtos.CommissionStatement
@using DeliverTableClient.Services.Invoice
@using DeliverTableSharedLibrary.Dtos.Dish
@using DeliverTableSharedLibrary.Dtos.Dispute
@using DeliverTableSharedLibrary.Dtos.Restaurant
@using DeliverTableSharedLibrary.Enums
@inject ICommissionStatementApiClient CommissionStatementApi
@inject IDisputeApiClient DisputeApi

<PageTitle>Compte — @(_restaurantName ?? "Restaurant") — DeliverTable</PageTitle>

<div class="restaurant-account-page">
    <div class="page-header">
        <div>
            <h1>Compte</h1>
            @if (_restaurantName is not null)
            {
                <p class="page-subtitle">@_restaurantName</p>
            }
        </div>
        <button type="button" class="app-btn app-btn--secondary" @onclick="GoBack">
            Retour
        </button>
    </div>

    @if (_loading)
    {
        <p>Chargement du compte...</p>
    }
    else if (_error is not null)
    {
        <div class="error-message">
            <p>@_error</p>
        </div>
    }
    else if (_account is not null)
    {
        <div class="balance-card">
            <span class="balance-label">Solde disponible</span>
            <span class="balance-amount">@_account.Balance.ToString("C", _frCulture)</span>
            <button type="button" class="app-btn app-btn--primary" @onclick="ShowWithdrawForm">
                Retirer des fonds
            </button>
        </div>

        <div class="special-dish-card">
            <div class="special-dish-card__header">
                <div>
                    <h2>Plat spécial</h2>
                    <p>Choisissez le plat à mettre en avant sur la page du restaurant.</p>
                </div>
            </div>

            @if (_dishesLoading)
            {
                <p>Chargement des plats...</p>
            }
            else if (_dishes is null || _dishes.Count == 0)
            {
                <p>Aucun plat disponible pour le moment.</p>
            }
            else
            {
                <div class="special-dish-card__body">
                    <label for="special-dish">Plat mis en avant</label>
                    <select id="special-dish" class="form-input" @bind="_selectedSpecialDishId">
                        <option value="">-- Aucun --</option>
                        @foreach (var dish in _dishes)
                        {
                            <option value="@dish.Id">@dish.Name</option>
                        }
                    </select>

                    <div class="special-dish-card__current">
                        @if (_currentSpecialDish is not null)
                        {
                            <strong>Actuellement mis en avant :</strong>
                            <span>@_currentSpecialDish.Name</span>
                        }
                        else
                        {
                            <span>Aucun plat spécial n'est sélectionné.</span>
                        }
                    </div>

                    @if (_specialDishError is not null)
                    {
                        <p class="field-error">@_specialDishError</p>
                    }
                    @if (_specialDishSuccess)
                    {
                        <p class="field-success">Le plat spécial a été mis à jour.</p>
                    }

                    <div class="special-dish-card__actions">
                        <button type="button" class="app-btn app-btn--primary" @onclick="SaveSpecialDish" disabled="@_savingSpecialDish">
                            @(_savingSpecialDish ? "Enregistrement..." : "Enregistrer le plat spécial")
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (_showWithdraw)
        {
            <div class="withdraw-card">
                <h3>Retrait</h3>
                <EditForm Model="_withdrawRequest" OnValidSubmit="HandleWithdraw">
                    <DataAnnotationsValidator />
                    <div class="withdraw-form">
                        <div class="form-field">
                            <label for="amount">Montant (€)</label>
                            <InputNumber id="amount" @bind-Value="_withdrawRequest.Amount" class="form-input" />
                            <ValidationMessage For="() => _withdrawRequest.Amount" />
                        </div>
                        <div class="withdraw-actions">
                            <button type="submit" class="app-btn app-btn--primary" disabled="@_withdrawing">
                                @(_withdrawing ? "Traitement..." : "Confirmer le retrait")
                            </button>
                            <button type="button" class="app-btn app-btn--secondary" @onclick="HideWithdrawForm">
                                Annuler
                            </button>
                        </div>
                        @if (_withdrawError is not null)
                        {
                            <p class="field-error">@_withdrawError</p>
                        }
                        @if (_withdrawSuccess)
                        {
                            <p class="field-success">Retrait effectué avec succès.</p>
                        }
                    </div>
                </EditForm>
            </div>
        }

        <div class="transactions-section">
            <h2>Relevés de commissions</h2>

            @if (_statementsLoading)
            {
                <p>Chargement des relevés...</p>
            }
            else if (_statements is null || _statements.Count == 0)
            {
                <div class="empty-state">
                    <p>Aucun relevé de commissions pour le moment.</p>
                </div>
            }
            else
            {
                <div class="transactions-table-container">
                    <table class="transactions-table">
                        <thead>
                            <tr>
                                <th>Période</th>
                                <th>Numéro</th>
                                <th>Type</th>
                                <th>Date d'émission</th>
                                <th>Total TTC</th>
                                <th>Statut</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _statements)
                            {
                                <tr>
                                    <td>@s.PeriodYear-@s.PeriodMonth.ToString("D2")</td>
                                    <td>@s.Number</td>
                                    <td>
                                        @(s.Kind == CommissionStatementKind.Invoice ? "Relevé" : "Avoir")
                                    </td>
                                    <td>@s.IssuedAt.ToString("dd/MM/yyyy")</td>
                                    <td>@s.TotalTtc.ToString("C", _frCulture)</td>
                                    <td>@s.Status</td>
                                    <td>
                                        @if (s.HasPdf && s.Status == CommissionStatementStatus.Generated)
                                        {
                                            <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="() => DownloadStatement(s.Id)">Télécharger</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="transactions-section">
            <h2>Litiges</h2>

            @if (_disputesLoading)
            {
                <p>Chargement des litiges...</p>
            }
            else if (_disputes is null || _disputes.Count == 0)
            {
                <div class="empty-state">
                    <p>Aucun litige à ce jour.</p>
                </div>
            }
            else
            {
                <div class="info-banner">
                    Nous gérons la défense du litige avec Stripe. Vous serez notifié du résultat.
                </div>
                <div class="transactions-table-container">
                    <table class="transactions-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Commande</th>
                                <th>Montant</th>
                                <th>Motif</th>
                                <th>État</th>
                                <th>Échéance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _disputes)
                            {
                                <tr>
                                    <td>@d.OpenedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>#@d.OrderId</td>
                                    <td>@d.Amount.ToString("C", _frCulture)</td>
                                    <td>@d.ReasonCode</td>
                                    <td><span class="tx-type-badge tx-type--@d.State.ToString().ToLower()">@TranslateDisputeState(d.State)</span></td>
                                    <td>@(d.DueBy?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="transactions-section">
            <h2>Historique des transactions</h2>

            @if (_account.Transactions.Items.Count == 0)
            {
                <div class="empty-state">
                    <p>Aucune transaction pour le moment.</p>
                </div>
            }
            else
            {
                <div class="transactions-table-container">
                    <table class="transactions-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Commande</th>
                                <th>Montant brut</th>
                                <th>Commission</th>
                                <th>Montant net</th>
                                <th>Solde après</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in _account.Transactions.Items)
                            {
                                <tr class="tx-row tx-row--@tx.Type.ToLower()">
                                    <td>@tx.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="tx-type-badge tx-type--@tx.Type.ToLower()">
                                            @TranslateType(tx.Type)
                                        </span>
                                    </td>
                                    <td>@(tx.OrderId.HasValue ? $"#{tx.OrderId}" : "—")</td>
                                    <td>@tx.GrossAmount.ToString("C", _frCulture)</td>
                                    <td>@(tx.CommissionAmount > 0 ? tx.CommissionAmount.ToString("C", _frCulture) : "—")</td>
                                    <td><strong>@FormatSignedAmount(tx)</strong></td>
                                    <td>@tx.BalanceAfter.ToString("C", _frCulture)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (_account.Transactions.HasNextPage || _query.PageNumber > 1)
                {
                    <div class="pagination">
                        @if (_query.PageNumber > 1)
                        {
                            <button type="button" class="app-btn app-btn--secondary" @onclick="PreviousPage">Précédent</button>
                        }
                        <span class="page-info">Page @_query.PageNumber / @((_account.Transactions.TotalCount + _query.PageSize - 1) / _query.PageSize)</span>
                        @if (_account.Transactions.HasNextPage)
                        {
                            <button type="button" class="app-btn app-btn--secondary" @onclick="NextPage">Suivant</button>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int RestaurantId { get; set; }

    private static readonly System.Globalization.CultureInfo _frCulture =
        System.Globalization.CultureInfo.GetCultureInfo("fr-FR");

    private RestaurantAccountDto? _account;
    private TransactionQuery _query = new() { PageSize = 20 };
    private string? _restaurantName;
    private bool _loading = true;
    private string? _error;

    private List<AdminCommissionStatementRowDto>? _statements;
    private bool _statementsLoading = true;
    private List<DishDto>? _dishes;
    private bool _dishesLoading = true;
    private int? _selectedSpecialDishId;
    private DishDto? _currentSpecialDish;
    private bool _savingSpecialDish;
    private string? _specialDishError;
    private bool _specialDishSuccess;

    private List<InvoiceListItemDto>? _invoices;
    private bool _invoicesLoading = true;

    private List<DisputeRowDto>? _disputes;
    private bool _disputesLoading = true;

    private bool _showWithdraw;
    private bool _withdrawing;
    private string? _withdrawError;
    private bool _withdrawSuccess;
    private WithdrawRequest _withdrawRequest = new();

    protected override async Task OnInitializedAsync()
    {
        var (restaurant, _) = await RestaurantService.GetRestaurantById(RestaurantId);
        _restaurantName = restaurant?.Name;
        await Task.WhenAll(LoadAccount(), LoadStatements(), LoadDisputes());
        await Task.WhenAll(LoadAccount(), LoadInvoices(), LoadDisputes(), LoadDishes());
    }

    private async Task LoadDishes()
    {
        _dishesLoading = true;

        var (result, _) = await DishService.GetDishesByRestaurantId(
            RestaurantId,
            new DishQuery { PageSize = 500, PageNumber = 1 });

        _dishes = result?.Items.ToList() ?? [];
        _currentSpecialDish = _dishes.FirstOrDefault(d => d.IsDishOfTheDay);
        _selectedSpecialDishId = _currentSpecialDish?.Id;
        _dishesLoading = false;
        StateHasChanged();
    }

    private async Task LoadStatements()
    {
        _statementsLoading = true;
        var result = await CommissionStatementApi.GetForRestaurantAsync(RestaurantId, 1, 50);
        _statements = result?.Items.ToList() ?? new();
        _statementsLoading = false;
    }

    private async Task LoadDisputes()
    {
        _disputesLoading = true;
        var result = await DisputeApi.GetForRestaurantAsync(RestaurantId, 1, 50);
        _disputes = result?.Items.ToList() ?? new();
        _disputesLoading = false;
    }

    private Task DownloadStatement(int id) => CommissionStatementApi.DownloadOwnerPdfAsync(id);

    private async Task LoadAccount()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (result, error) = await AccountService.GetAccountAsync(RestaurantId, _query);
        if (error is not null)
            _error = error.Error;
        else
            _account = result;

        _loading = false;
        StateHasChanged();
    }

    private async Task SaveSpecialDish()
    {
        _specialDishError = null;
        _specialDishSuccess = false;

        if (_dishes is null || _dishes.Count == 0)
        {
            _specialDishError = "Aucun plat disponible.";
            return;
        }

        _savingSpecialDish = true;

        try
        {
            foreach (var dish in _dishes)
            {
                var shouldBeFeatured = _selectedSpecialDishId.HasValue && dish.Id == _selectedSpecialDishId.Value;
                if (dish.IsDishOfTheDay == shouldBeFeatured)
                    continue;

                var updateDto = new CreateDishDto
                {
                    Name = dish.Name,
                    Description = dish.Description,
                    BasePrice = dish.BasePrice,
                    IsVegetarian = dish.IsVegetarian,
                    IsVegan = dish.IsVegan,
                    IsGlutenFree = dish.IsGlutenFree,
                    IsAllergenHazard = dish.IsAllergenHazard,
                    IsDishOfTheDay = shouldBeFeatured,
                    IsActive = dish.IsActive,
                    VatRate = dish.VatRate
                };

                var (_, error) = await DishService.UpdateDish(dish.Id, updateDto, null);
                if (error is not null)
                {
                    _specialDishError = error.Error;
                    return;
                }

                dish.IsDishOfTheDay = shouldBeFeatured;
            }

            _currentSpecialDish = _selectedSpecialDishId.HasValue
                ? _dishes.FirstOrDefault(d => d.Id == _selectedSpecialDishId.Value)
                : null;
            _specialDishSuccess = true;
        }
        finally
        {
            _savingSpecialDish = false;
        }
    }

    private void ShowWithdrawForm()
    {
        _showWithdraw = true;
        _withdrawRequest = new WithdrawRequest();
        _withdrawError = null;
        _withdrawSuccess = false;
    }

    private void HideWithdrawForm()
    {
        _showWithdraw = false;
        _withdrawError = null;
        _withdrawSuccess = false;
    }

    private async Task HandleWithdraw()
    {
        _withdrawing = true;
        _withdrawError = null;
        _withdrawSuccess = false;
        StateHasChanged();

        var (result, error) = await AccountService.WithdrawAsync(RestaurantId, _withdrawRequest);
        if (error is not null)
        {
            _withdrawError = error.Error;
        }
        else
        {
            _account = result;
            _withdrawSuccess = true;
            _withdrawRequest = new WithdrawRequest();
        }

        _withdrawing = false;
        StateHasChanged();
    }

    private async Task NextPage()
    {
        _query.PageNumber++;
        await LoadAccount();
    }

    private async Task PreviousPage()
    {
        if (_query.PageNumber > 1)
        {
            _query.PageNumber--;
            await LoadAccount();
        }
    }

    private void GoBack() => Nav.NavigateTo("/mes-restaurants");

    private static string TranslateType(string type) => type switch
    {
        "Refund" => "Remboursement",
        "Credit" => "Crédit",
        "Withdrawal" => "Retrait",
        "DisputeReversal" => "Débit litige",
        "DisputeRestored" => "Crédit litige gagné",
        _ => type
    };

    private static string TranslateDisputeState(DisputeState state) => state switch
    {
        DisputeState.Open => "Ouvert",
        DisputeState.Won => "Gagné",
        DisputeState.Lost => "Perdu",
        _ => state.ToString()
    };

    private string FormatSignedAmount(RestaurantTransactionDto tx) => tx.Type switch
    {
        "Credit" => $"+{tx.NetAmount.ToString("C", _frCulture)}",
        "Withdrawal" => $"-{tx.NetAmount.ToString("C", _frCulture)}",
        _ => tx.NetAmount.ToString("C", _frCulture)
    };
}
