@page "/restaurant/create"
@using DeliverTableClient.Components.Forms.RestaurantCreation
@using DeliverTableClient.Components.Redirect

<PageTitle>Ajouter un restaurant</PageTitle>

<AuthorizeView Roles="RestaurantOwner">
    <NotAuthorized>
        <RedirectToHomePage/>
    </NotAuthorized>
    <Authorized>
        <div class="container">
        <h1>
            Ajouter un restaurant
        </h1>
        <RestaurantCreationForm/>
        </div>
    </Authorized>
</AuthorizeView>    