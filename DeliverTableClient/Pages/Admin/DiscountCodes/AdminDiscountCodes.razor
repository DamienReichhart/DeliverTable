@page "/admin/discount-codes"
@attribute [Authorize(Roles = nameof(UserRole.Administrator))]
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Admin
@using Microsoft.AspNetCore.Authorization
@inject IAdminDiscountCodeClientService DiscountCodeService

<PageTitle>Codes promo — Administration</PageTitle>

<AdminLayout Title="Codes promo" Subtitle="@($"{(_discountCodes?.Count ?? 0)} codes promo")">
    <ActionsContent>
        <button class="app-btn app-btn--sm" @onclick="OpenCreateModal">
            <Blazicon Svg="Lucide.Plus" />
            Créer un code promo
        </button>
    </ActionsContent>
    <ChildContent>
        <AdminBreadcrumbs Items="@_breadcrumbs" />

        @if (!string.IsNullOrEmpty(_actionSuccess))
        {
            <div class="alert alert-success">@_actionSuccess</div>
        }
        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="alert alert-danger">@_actionError</div>
        }

        <AdminDataTable TItem="AdminDiscountCodeResponse"
                         Items="FilteredDiscountCodes"
                         TotalCount="@(FilteredDiscountCodes.Count())"
                         IsLoading="@_isLoading"
                         SearchPlaceholder="Rechercher par code..."
                         SearchText="@_searchQuery"
                         SearchTextChanged="@(q => { _searchQuery = q; StateHasChanged(); })">
            <HeaderContent>
                <th>Code</th>
                <th>Description</th>
                <th>Type</th>
                <th>Valeur</th>
                <th>Restaurant</th>
                <th>Utilisations</th>
                <th>Active</th>
                <th>Validité</th>
                <th>Actions</th>
            </HeaderContent>
            <RowContent Context="dc">
                <tr>
                    <td class="adm-cell-mono">@dc.Code</td>
                    <td>@dc.Description</td>
                    <td>
                        <AdminBadge Text="@TranslateDiscountType(dc.DiscountType)" Variant="info" />
                    </td>
                    <td class="adm-cell-mono">@FormatDiscount(dc.DiscountType, dc.DiscountValue)</td>
                    <td>@dc.RestaurantName</td>
                    <td class="adm-cell-mono">@dc.CurrentRedemptions / @(dc.MaxRedemptions?.ToString() ?? "∞")</td>
                    <td>
                        <AdminBadge Text="@(dc.IsActive ? "Actif" : "Inactif")"
                                    Variant="@(dc.IsActive ? "success" : "danger")" ShowDot />
                    </td>
                    <td class="adm-cell-mono">@dc.ValidFrom.ToString("dd/MM/yyyy") — @dc.ValidUntil.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="adm-cell-actions">
                            <button class="app-btn app-btn--link app-btn--sm" @onclick="() => OpenEditModal(dc)">
                                Modifier
                            </button>
                            <button class="app-btn app-btn--link app-btn--sm" style="color: var(--color-error, #C0392B);"
                                    @onclick="() => OpenDeleteConfirm(dc)">
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
            </RowContent>
            <EmptyContent>
                <AdminEmptyState Title="Aucun code promo trouvé"
                                 Message="@($"Aucun résultat pour « {_searchQuery} »")">
                    <IconContent><Blazicon Svg="Lucide.Ticket" /></IconContent>
                </AdminEmptyState>
            </EmptyContent>
        </AdminDataTable>

        @* ── Create modal ── *@
        <AdminFormModal IsVisible="@_showCreateModal" Title="Créer un code promo" OnClose="CloseCreateModal" Wide>
            <ChildContent>
                <EditForm Model="@_createModel" OnValidSubmit="HandleCreate">
                    <DataAnnotationsValidator />
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-code">Code</label>
                            <InputText id="create-code" @bind-Value="_createModel.Code"
                                       class="adm-form-input" placeholder="CODE2024" />
                            <ValidationMessage For="@(() => _createModel.Code)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-restaurant">ID Restaurant</label>
                            <InputNumber id="create-restaurant" @bind-Value="_createModel.RestaurantId"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.RestaurantId)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="create-desc">Description</label>
                        <InputText id="create-desc" @bind-Value="_createModel.Description"
                                   class="adm-form-input" placeholder="Description (optionnelle)" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-discount-type">Type de réduction</label>
                            <InputSelect id="create-discount-type" @bind-Value="_createModel.DiscountType" class="adm-form-select">
                                @foreach (var dt in Enum.GetValues<DiscountType>())
                                {
                                    <option value="@dt">@TranslateDiscountType(dt)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-discount-value">Valeur de réduction</label>
                            <InputNumber id="create-discount-value" @bind-Value="_createModel.DiscountValue"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.DiscountValue)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="create-min-order">Montant minimum de commande (optionnel)</label>
                        <InputNumber id="create-min-order" @bind-Value="_createModel.MinOrderAmount"
                                     class="adm-form-input" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-valid-from">Valide du</label>
                            <InputDate id="create-valid-from" @bind-Value="_createModel.ValidFrom" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.ValidFrom)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-valid-until">Valide jusqu'au</label>
                            <InputDate id="create-valid-until" @bind-Value="_createModel.ValidUntil" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.ValidUntil)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-max-redemptions">Utilisations max. (optionnel)</label>
                            <InputNumber id="create-max-redemptions" @bind-Value="_createModel.MaxRedemptions"
                                         class="adm-form-input" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-per-user-limit">Limite par utilisateur</label>
                            <InputNumber id="create-per-user-limit" @bind-Value="_createModel.PerUserLimit"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.PerUserLimit)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label">Actif</label>
                        <div style="padding-top: 0.5rem;">
                            <InputCheckbox @bind-Value="_createModel.IsActive" />
                            <span>@(_createModel.IsActive ? "Oui" : "Non")</span>
                        </div>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem;">
                        <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseCreateModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button type="submit" class="app-btn app-btn--sm" disabled="@_isSaving">
                            @(_isSaving ? "Création..." : "Créer")
                        </button>
                    </div>
                </EditForm>
            </ChildContent>
        </AdminFormModal>

        @* ── Edit modal ── *@
        <AdminFormModal IsVisible="@(_editingCode is not null)" Title="Modifier le code promo" OnClose="CloseEditModal" Wide>
            <ChildContent>
                @if (_editingCode is not null)
                {
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label">Code</label>
                        <input class="adm-form-input" value="@_editingCode.Code" disabled />
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="edit-desc">Description</label>
                        <input id="edit-desc" class="adm-form-input" @bind="_editModel.Description" placeholder="Description" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-discount-type">Type de réduction</label>
                            <select id="edit-discount-type" class="adm-form-select" @bind="_editModel.DiscountType">
                                @foreach (var dt in Enum.GetValues<DiscountType>())
                                {
                                    <option value="@dt">@TranslateDiscountType(dt)</option>
                                }
                            </select>
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-discount-value">Valeur de réduction</label>
                            <input id="edit-discount-value" type="number" class="adm-form-input" @bind="_editModel.DiscountValue" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="edit-min-order">Montant minimum de commande</label>
                        <input id="edit-min-order" type="number" class="adm-form-input" @bind="_editModel.MinOrderAmount" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-valid-from">Valide du</label>
                            <input id="edit-valid-from" type="date" class="adm-form-input" @bind="_editModel.ValidFrom" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-valid-until">Valide jusqu'au</label>
                            <input id="edit-valid-until" type="date" class="adm-form-input" @bind="_editModel.ValidUntil" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-max-redemptions">Utilisations max.</label>
                            <input id="edit-max-redemptions" type="number" class="adm-form-input" @bind="_editModel.MaxRedemptions" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-per-user-limit">Limite par utilisateur</label>
                            <input id="edit-per-user-limit" type="number" class="adm-form-input" @bind="_editModel.PerUserLimit" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label">Actif</label>
                        <div style="padding-top: 0.5rem;">
                            <input type="checkbox" @bind="_editModel.IsActive" />
                            <span>@(_editModel.IsActive ? "Oui" : "Non")</span>
                        </div>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem;">
                        <button class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseEditModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button class="app-btn app-btn--sm" @onclick="HandleUpdate" disabled="@_isSaving">
                            @(_isSaving ? "Sauvegarde..." : "Sauvegarder")
                        </button>
                    </div>
                }
            </ChildContent>
        </AdminFormModal>

        @* ── Delete confirmation ── *@
        <AdminConfirmDialog IsVisible="@(_deletingCode is not null)"
                            Title="Supprimer le code promo"
                            Message="@($"Voulez-vous vraiment supprimer le code « {_deletingCode?.Code} » ? Cette action est irréversible.")"
                            ConfirmText="Supprimer"
                            Variant="danger"
                            IsProcessing="@_isSaving"
                            OnConfirm="HandleDelete"
                            OnCancel="CloseDeleteConfirm" />
    </ChildContent>
</AdminLayout>

@code {
    private List<AdminDiscountCodeResponse>? _discountCodes;
    private bool _isLoading = true;
    private string _searchQuery = "";

    private bool _showCreateModal;
    private AdminCreateDiscountCodeRequest _createModel = new();

    private AdminDiscountCodeResponse? _editingCode;
    private AdminUpdateDiscountCodeRequest _editModel = new();

    private AdminDiscountCodeResponse? _deletingCode;
    private bool _isSaving;
    private string? _actionSuccess;
    private string? _actionError;

    private readonly List<AdminBreadcrumbs.BreadcrumbItem> _breadcrumbs =
    [
        new() { Label = "Administration", Href = "/admin" },
        new() { Label = "Codes promo", Href = "/admin/discount-codes" }
    ];

    private IEnumerable<AdminDiscountCodeResponse> FilteredDiscountCodes =>
        _discountCodes?.Where(c =>
            string.IsNullOrWhiteSpace(_searchQuery)
            || c.Code.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDiscountCodes();
    }

    private async Task LoadDiscountCodes()
    {
        _isLoading = true;
        StateHasChanged();

        var (codes, error) = await DiscountCodeService.GetAllAsync();
        _discountCodes = codes;
        if (error is not null)
            _actionError = error.Error;
        _isLoading = false;
    }

    // ── Create ──

    private void OpenCreateModal()
    {
        ClearMessages();
        _createModel = new AdminCreateDiscountCodeRequest
        {
            ValidFrom = DateTime.Today,
            ValidUntil = DateTime.Today.AddDays(30),
            PerUserLimit = 1
        };
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _createModel = new AdminCreateDiscountCodeRequest();
    }

    private async Task HandleCreate()
    {
        _isSaving = true;
        ClearMessages();

        var (created, error) = await DiscountCodeService.CreateAsync(_createModel);
        if (created is not null)
        {
            _discountCodes?.Add(created);
            _actionSuccess = $"Code promo « {created.Code} » créé avec succès";
            CloseCreateModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la création du code promo";
        }

        _isSaving = false;
    }

    // ── Edit ──

    private void OpenEditModal(AdminDiscountCodeResponse code)
    {
        ClearMessages();
        _deletingCode = null;
        _editingCode = code;
        _editModel = new AdminUpdateDiscountCodeRequest
        {
            Description = code.Description,
            DiscountType = code.DiscountType,
            DiscountValue = code.DiscountValue,
            MinOrderAmount = code.MinOrderAmount,
            ValidFrom = code.ValidFrom,
            ValidUntil = code.ValidUntil,
            MaxRedemptions = code.MaxRedemptions,
            PerUserLimit = code.PerUserLimit,
            IsActive = code.IsActive
        };
    }

    private void CloseEditModal()
    {
        _editingCode = null;
        _editModel = new AdminUpdateDiscountCodeRequest();
    }

    private async Task HandleUpdate()
    {
        if (_editingCode is null) return;
        _isSaving = true;
        ClearMessages();

        var (updated, error) = await DiscountCodeService.UpdateAsync(_editingCode.Id, _editModel);
        if (updated is not null)
        {
            ReplaceDiscountCode(updated);
            _actionSuccess = $"Code promo « {updated.Code} » mis à jour";
            CloseEditModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la mise à jour du code promo";
        }

        _isSaving = false;
    }

    // ── Delete ──

    private void OpenDeleteConfirm(AdminDiscountCodeResponse code)
    {
        ClearMessages();
        _editingCode = null;
        _deletingCode = code;
    }

    private void CloseDeleteConfirm()
    {
        _deletingCode = null;
    }

    private async Task HandleDelete()
    {
        if (_deletingCode is null) return;
        _isSaving = true;
        ClearMessages();

        var codeId = _deletingCode.Id;
        var (success, error) = await DiscountCodeService.DeleteAsync(codeId);
        if (success)
        {
            var removed = _deletingCode;
            _discountCodes?.RemoveAll(c => c.Id == codeId);
            _actionSuccess = $"Code promo « {removed.Code} » supprimé";
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la suppression du code promo";
        }

        _deletingCode = null;
        _isSaving = false;
    }

    // ── Helpers ──

    private void ReplaceDiscountCode(AdminDiscountCodeResponse updated)
    {
        if (_discountCodes is null) return;
        var idx = _discountCodes.FindIndex(c => c.Id == updated.Id);
        if (idx >= 0) _discountCodes[idx] = updated;
    }

    private void ClearMessages()
    {
        _actionSuccess = null;
        _actionError = null;
    }

    private static string TranslateDiscountType(DiscountType type) => type switch
    {
        DiscountType.Percentage => "Pourcentage",
        DiscountType.FixedAmount => "Montant fixe",
        _ => type.ToString()
    };

    private static string FormatDiscount(DiscountType type, decimal value) => type switch
    {
        DiscountType.Percentage => $"{value} %",
        DiscountType.FixedAmount => $"{value:0.00} \u20ac",
        _ => value.ToString("0.00")
    };
}
