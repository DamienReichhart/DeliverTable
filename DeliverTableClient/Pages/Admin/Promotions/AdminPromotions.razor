@page "/admin/promotions"
@attribute [Authorize(Roles = nameof(UserRole.Administrator))]
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Admin
@using Microsoft.AspNetCore.Authorization
@inject IAdminPromotionClientService PromotionService

<PageTitle>Promotions — Administration</PageTitle>

<AdminLayout Title="Promotions" Subtitle="@($"{(_promotions?.Count ?? 0)} promotions")">
    <ActionsContent>
        <button class="app-btn app-btn--sm" @onclick="OpenCreateModal">
            <Blazicon Svg="Lucide.Plus" />
            Créer une promotion
        </button>
    </ActionsContent>
    <ChildContent>
        <AdminBreadcrumbs Items="@_breadcrumbs" />

        @if (!string.IsNullOrEmpty(_actionSuccess))
        {
            <div class="adm-alert adm-alert--success">@_actionSuccess</div>
        }
        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="adm-alert adm-alert--danger">@_actionError</div>
        }

        <AdminDataTable TItem="AdminPromotionResponse"
                         Items="FilteredPromotions"
                         TotalCount="@(FilteredPromotions.Count())"
                         IsLoading="@_isLoading"
                         SearchPlaceholder="Rechercher par nom ou restaurant..."
                         SearchText="@_searchQuery"
                         SearchTextChanged="@(q => { _searchQuery = q; StateHasChanged(); })">
            <HeaderContent>
                <th>Nom</th>
                <th>Restaurant</th>
                <th>Type</th>
                <th>Réduction</th>
                <th>Dates</th>
                <th>Active</th>
                <th>Créée le</th>
                <th>Actions</th>
            </HeaderContent>
            <RowContent Context="promo">
                <tr>
                    <td>@promo.Name</td>
                    <td>@promo.RestaurantName</td>
                    <td>
                        <AdminBadge Text="@TranslatePromotionType(promo.PromotionType)" Variant="info" />
                    </td>
                    <td class="adm-cell-mono">@FormatDiscount(promo.DiscountType, promo.DiscountValue)</td>
                    <td class="adm-cell-mono">@promo.StartsAt.ToString("dd/MM/yyyy") — @promo.EndsAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <AdminBadge Text="@(promo.IsActive ? "Active" : "Inactive")"
                                    Variant="@(promo.IsActive ? "success" : "danger")" ShowDot />
                    </td>
                    <td class="adm-cell-mono">@promo.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="adm-cell-actions">
                            <button class="adm-ghost-btn adm-ghost-btn--primary" @onclick="() => OpenEditModal(promo)">
                                Modifier
                            </button>
                            <button class="adm-ghost-btn adm-ghost-btn--danger"
                                    @onclick="() => OpenDeleteConfirm(promo)">
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
            </RowContent>
            <EmptyContent>
                <AdminEmptyState Title="Aucune promotion trouvée"
                                 Message="@($"Aucun résultat pour « {_searchQuery} »")">
                    <IconContent><Blazicon Svg="Lucide.Tag" /></IconContent>
                </AdminEmptyState>
            </EmptyContent>
        </AdminDataTable>

        @* ── Create modal ── *@
        <AdminFormModal IsVisible="@_showCreateModal" Title="Créer une promotion" OnClose="CloseCreateModal" Wide>
            <ChildContent>
                <EditForm Model="@_createModel" OnValidSubmit="HandleCreate">
                    <DataAnnotationsValidator />
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="create-name">Nom</label>
                        <InputText id="create-name" @bind-Value="_createModel.Name"
                                   class="adm-form-input" placeholder="Nom de la promotion" />
                        <ValidationMessage For="@(() => _createModel.Name)" class="adm-form-error" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="create-desc">Description</label>
                        <InputText id="create-desc" @bind-Value="_createModel.Description"
                                   class="adm-form-input" placeholder="Description (optionnelle)" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-promo-type">Type de promotion</label>
                            <InputSelect id="create-promo-type" @bind-Value="_createModel.PromotionType" class="adm-form-select">
                                @foreach (var pt in Enum.GetValues<PromotionType>())
                                {
                                    <option value="@pt">@TranslatePromotionType(pt)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-discount-type">Type de réduction</label>
                            <InputSelect id="create-discount-type" @bind-Value="_createModel.DiscountType" class="adm-form-select">
                                @foreach (var dt in Enum.GetValues<DiscountType>())
                                {
                                    <option value="@dt">@TranslateDiscountType(dt)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-discount-value">Valeur de réduction</label>
                            <InputNumber id="create-discount-value" @bind-Value="_createModel.DiscountValue"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.DiscountValue)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-min-order">Montant minimum (optionnel)</label>
                            <InputNumber id="create-min-order" @bind-Value="_createModel.MinOrderAmount"
                                         class="adm-form-input" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-starts">Date de début</label>
                            <InputDate id="create-starts" @bind-Value="_createModel.StartsAt" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.StartsAt)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-ends">Date de fin</label>
                            <InputDate id="create-ends" @bind-Value="_createModel.EndsAt" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.EndsAt)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-restaurant">ID Restaurant</label>
                            <InputNumber id="create-restaurant" @bind-Value="_createModel.RestaurantId"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.RestaurantId)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label">Active</label>
                            <div>
                                <InputCheckbox @bind-Value="_createModel.IsActive" />
                                <span>@(_createModel.IsActive ? "Oui" : "Non")</span>
                            </div>
                        </div>
                    </div>
                    <div class="adm-form-actions">
                        <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseCreateModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button type="submit" class="app-btn app-btn--sm" disabled="@_isSaving">
                            @(_isSaving ? "Création..." : "Créer")
                        </button>
                    </div>
                </EditForm>
            </ChildContent>
        </AdminFormModal>

        @* ── Edit modal ── *@
        <AdminFormModal IsVisible="@(_editingPromo is not null)" Title="Modifier la promotion" OnClose="CloseEditModal" Wide>
            <ChildContent>
                @if (_editingPromo is not null)
                {
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="edit-name">Nom</label>
                        <input id="edit-name" class="adm-form-input" @bind="_editModel.Name" placeholder="Nom" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="edit-desc">Description</label>
                        <input id="edit-desc" class="adm-form-input" @bind="_editModel.Description" placeholder="Description" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-promo-type">Type de promotion</label>
                            <select id="edit-promo-type" class="adm-form-select" @bind="_editModel.PromotionType">
                                @foreach (var pt in Enum.GetValues<PromotionType>())
                                {
                                    <option value="@pt">@TranslatePromotionType(pt)</option>
                                }
                            </select>
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-discount-type">Type de réduction</label>
                            <select id="edit-discount-type" class="adm-form-select" @bind="_editModel.DiscountType">
                                @foreach (var dt in Enum.GetValues<DiscountType>())
                                {
                                    <option value="@dt">@TranslateDiscountType(dt)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-discount-value">Valeur de réduction</label>
                            <input id="edit-discount-value" type="number" class="adm-form-input" @bind="_editModel.DiscountValue" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-min-order">Montant minimum</label>
                            <input id="edit-min-order" type="number" class="adm-form-input" @bind="_editModel.MinOrderAmount" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-starts">Date de début</label>
                            <input id="edit-starts" type="date" class="adm-form-input" @bind="_editModel.StartsAt" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="edit-ends">Date de fin</label>
                            <input id="edit-ends" type="date" class="adm-form-input" @bind="_editModel.EndsAt" />
                        </div>
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label">Active</label>
                        <div>
                            <input type="checkbox" @bind="_editModel.IsActive" />
                            <span>@(_editModel.IsActive ? "Oui" : "Non")</span>
                        </div>
                    </div>
                    <div class="adm-form-actions">
                        <button class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseEditModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button class="app-btn app-btn--sm" @onclick="HandleUpdate" disabled="@_isSaving">
                            @(_isSaving ? "Sauvegarde..." : "Sauvegarder")
                        </button>
                    </div>
                }
            </ChildContent>
        </AdminFormModal>

        @* ── Delete confirmation ── *@
        <AdminConfirmDialog IsVisible="@(_deletingPromo is not null)"
                            Title="Supprimer la promotion"
                            Message="@($"Voulez-vous vraiment supprimer la promotion « {_deletingPromo?.Name} » ? Cette action est irréversible.")"
                            ConfirmText="Supprimer"
                            Variant="danger"
                            IsProcessing="@_isSaving"
                            OnConfirm="HandleDelete"
                            OnCancel="CloseDeleteConfirm" />
    </ChildContent>
</AdminLayout>

@code {
    private List<AdminPromotionResponse>? _promotions;
    private bool _isLoading = true;
    private string _searchQuery = "";

    private bool _showCreateModal;
    private AdminCreatePromotionRequest _createModel = new();

    private AdminPromotionResponse? _editingPromo;
    private AdminUpdatePromotionRequest _editModel = new();

    private AdminPromotionResponse? _deletingPromo;
    private bool _isSaving;
    private string? _actionSuccess;
    private string? _actionError;

    private readonly List<AdminBreadcrumbs.BreadcrumbItem> _breadcrumbs =
    [
        new() { Label = "Administration", Href = "/admin" },
        new() { Label = "Promotions", Href = "/admin/promotions" }
    ];

    private IEnumerable<AdminPromotionResponse> FilteredPromotions =>
        _promotions?.Where(p =>
            string.IsNullOrWhiteSpace(_searchQuery)
            || p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || p.RestaurantName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadPromotions();
    }

    private async Task LoadPromotions()
    {
        _isLoading = true;
        StateHasChanged();

        var (promotions, error) = await PromotionService.GetAllAsync();
        _promotions = promotions;
        if (error is not null)
            _actionError = error.Error;
        _isLoading = false;
    }

    // ── Create ──

    private void OpenCreateModal()
    {
        ClearMessages();
        _createModel = new AdminCreatePromotionRequest
        {
            StartsAt = DateTime.Today,
            EndsAt = DateTime.Today.AddDays(30)
        };
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _createModel = new AdminCreatePromotionRequest();
    }

    private async Task HandleCreate()
    {
        _isSaving = true;
        ClearMessages();

        var (created, error) = await PromotionService.CreateAsync(_createModel);
        if (created is not null)
        {
            _promotions?.Add(created);
            _actionSuccess = $"Promotion « {created.Name} » créée avec succès";
            CloseCreateModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la création de la promotion";
        }

        _isSaving = false;
    }

    // ── Edit ──

    private void OpenEditModal(AdminPromotionResponse promo)
    {
        ClearMessages();
        _deletingPromo = null;
        _editingPromo = promo;
        _editModel = new AdminUpdatePromotionRequest
        {
            Name = promo.Name,
            Description = promo.Description,
            PromotionType = promo.PromotionType,
            DiscountType = promo.DiscountType,
            DiscountValue = promo.DiscountValue,
            MinOrderAmount = promo.MinOrderAmount,
            StartsAt = promo.StartsAt,
            EndsAt = promo.EndsAt,
            IsActive = promo.IsActive
        };
    }

    private void CloseEditModal()
    {
        _editingPromo = null;
        _editModel = new AdminUpdatePromotionRequest();
    }

    private async Task HandleUpdate()
    {
        if (_editingPromo is null) return;
        _isSaving = true;
        ClearMessages();

        var (updated, error) = await PromotionService.UpdateAsync(_editingPromo.Id, _editModel);
        if (updated is not null)
        {
            ReplacePromotion(updated);
            _actionSuccess = $"Promotion « {updated.Name} » mise à jour";
            CloseEditModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la mise à jour de la promotion";
        }

        _isSaving = false;
    }

    // ── Delete ──

    private void OpenDeleteConfirm(AdminPromotionResponse promo)
    {
        ClearMessages();
        _editingPromo = null;
        _deletingPromo = promo;
    }

    private void CloseDeleteConfirm()
    {
        _deletingPromo = null;
    }

    private async Task HandleDelete()
    {
        if (_deletingPromo is null) return;
        _isSaving = true;
        ClearMessages();

        var promoId = _deletingPromo.Id;
        var (success, error) = await PromotionService.DeleteAsync(promoId);
        if (success)
        {
            var removed = _deletingPromo;
            _promotions?.RemoveAll(p => p.Id == promoId);
            _actionSuccess = $"Promotion « {removed.Name} » supprimée";
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la suppression de la promotion";
        }

        _deletingPromo = null;
        _isSaving = false;
    }

    // ── Helpers ──

    private void ReplacePromotion(AdminPromotionResponse updated)
    {
        if (_promotions is null) return;
        var idx = _promotions.FindIndex(p => p.Id == updated.Id);
        if (idx >= 0) _promotions[idx] = updated;
    }

    private void ClearMessages()
    {
        _actionSuccess = null;
        _actionError = null;
    }

    private static string TranslatePromotionType(PromotionType type) => type switch
    {
        PromotionType.Automatic => "Automatique",
        PromotionType.ItemBased => "Sur plats",
        PromotionType.Threshold => "Sur seuil",
        _ => type.ToString()
    };

    private static string TranslateDiscountType(DiscountType type) => type switch
    {
        DiscountType.Percentage => "Pourcentage",
        DiscountType.FixedAmount => "Montant fixe",
        _ => type.ToString()
    };

    private static string FormatDiscount(DiscountType type, decimal value) => type switch
    {
        DiscountType.Percentage => $"{value} %",
        DiscountType.FixedAmount => $"{value:0.00} \u20ac",
        _ => value.ToString("0.00")
    };
}
