@page "/admin/ratings"
@attribute [Authorize(Roles = nameof(UserRole.Administrator))]
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Admin
@using Microsoft.AspNetCore.Authorization
@inject IAdminRatingClientService RatingService

<PageTitle>Avis — Administration</PageTitle>

<AdminLayout Title="Avis" Subtitle="@GetSubtitle()">
    <ChildContent>
        <AdminBreadcrumbs Items="@_breadcrumbs" />

        @if (!string.IsNullOrEmpty(_actionSuccess))
        {
            <div class="adm-alert adm-alert--success">@_actionSuccess</div>
        }
        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="adm-alert adm-alert--danger">@_actionError</div>
        }

        <AdminDataTable TItem="AdminRestaurantRatingResponse"
                         Items="FilteredRestaurantRatings"
                         TotalCount="@(FilteredRestaurantRatings.Count())"
                         IsLoading="@_isLoading"
                         SearchPlaceholder="Rechercher par restaurant ou client..."
                         SearchText="@_searchQuery"
                         SearchTextChanged="@(q => { _searchQuery = q; StateHasChanged(); })">
            <HeaderContent>
                <th>Note</th>
                <th>Commentaire</th>
                <th>Restaurant</th>
                <th>Client</th>
                <th>Date</th>
                <th>Actions</th>
            </HeaderContent>
            <RowContent Context="rating">
                <tr>
                    <td class="adm-cell-mono">@RenderStars(rating.Rating)</td>
                    <td>@Truncate(rating.Comment, 60)</td>
                    <td>@rating.RestaurantName</td>
                    <td>@rating.CustomerName</td>
                    <td class="adm-cell-mono">@rating.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <button class="adm-ghost-btn adm-ghost-btn--danger"
                                @onclick="@(() => OpenDeleteConfirm(rating.Id, "l\u0027avis de " + rating.CustomerName))">
                            Supprimer
                        </button>
                    </td>
                </tr>
            </RowContent>
            <EmptyContent>
                <AdminEmptyState Title="Aucun avis restaurant trouvé"
                                 Message="@($"Aucun résultat pour « {_searchQuery} »")">
                    <IconContent><Blazicon Svg="Lucide.Star" /></IconContent>
                </AdminEmptyState>
            </EmptyContent>
        </AdminDataTable>

        @* ── Delete confirmation ── *@
        <AdminConfirmDialog IsVisible="@(_deletingId is not null)"
                            Title="Supprimer l'avis"
                            Message="@($"Voulez-vous vraiment supprimer {_deletingLabel} ? Cette action est irréversible.")"
                            ConfirmText="Supprimer"
                            Variant="danger"
                            IsProcessing="@_isSaving"
                            OnConfirm="HandleDelete"
                            OnCancel="CloseDeleteConfirm" />
    </ChildContent>
</AdminLayout>

@code {
    private List<AdminRestaurantRatingResponse>? _restaurantRatings;
    private bool _isLoading = true;
    private string _searchQuery = "";

    private int? _deletingId;
    private string _deletingLabel = "";
    private bool _isSaving;
    private string? _actionSuccess;
    private string? _actionError;

    private readonly List<AdminBreadcrumbs.BreadcrumbItem> _breadcrumbs =
    [
        new() { Label = "Administration", Href = "/admin" },
        new() { Label = "Avis", Href = "/admin/ratings" }
    ];

    private IEnumerable<AdminRestaurantRatingResponse> FilteredRestaurantRatings =>
        _restaurantRatings?.Where(r =>
            string.IsNullOrWhiteSpace(_searchQuery)
            || r.RestaurantName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || r.CustomerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || r.Comment.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? [];

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var (restaurantRatings, restaurantError) = await RatingService.GetRestaurantRatingsAsync();

        _restaurantRatings = restaurantRatings;
        _actionError = restaurantError?.Error;
        _isLoading = false;
    }

    private string GetSubtitle()
    {
        var restaurantCount = _restaurantRatings?.Count ?? 0;
        return $"{restaurantCount} avis restaurants";
    }

    // ── Delete ──

    private void OpenDeleteConfirm(int id, string label)
    {
        ClearMessages();
        _deletingId = id;
        _deletingLabel = label;
    }

    private void CloseDeleteConfirm()
    {
        _deletingId = null;
        _deletingLabel = "";
    }

    private async Task HandleDelete()
    {
        if (_deletingId is null) return;
        _isSaving = true;
        ClearMessages();

        var id = _deletingId.Value;
        var (success, error) = await RatingService.DeleteAsync(id);
        if (success)
        {
            _restaurantRatings?.RemoveAll(r => r.Id == id);
            _actionSuccess = "Avis supprimé avec succès";
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la suppression de l'avis";
        }

        _deletingId = null;
        _deletingLabel = "";
        _isSaving = false;
    }

    // ── Helpers ──

    private void ClearMessages()
    {
        _actionSuccess = null;
        _actionError = null;
    }

    private static string RenderStars(int rating)
    {
        return new string('*', rating) + new string('-', Math.Max(0, 5 - rating));
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "—";
        return text.Length <= maxLength ? text : text[..maxLength] + "...";
    }
}
