@page "/admin/users"
@attribute [Authorize(Roles = nameof(UserRole.Administrator))]
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Admin
@using Microsoft.AspNetCore.Authorization
@inject IAdminService AdminService

<PageTitle>Utilisateurs — Administration</PageTitle>

<AdminLayout Title="Utilisateurs" Subtitle="@($"{(_users?.Count ?? 0)} utilisateurs enregistrés")">
    <ActionsContent>
        <button class="app-btn app-btn--sm" @onclick="OpenCreateModal">
            <Blazicon Svg="Lucide.Plus" />
            Créer un utilisateur
        </button>
    </ActionsContent>
    <ChildContent>
        <AdminBreadcrumbs Items="@_breadcrumbs" />

        @if (!string.IsNullOrEmpty(_actionSuccess))
        {
            <div class="alert alert-success">@_actionSuccess</div>
        }
        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="alert alert-danger">@_actionError</div>
        }

        <AdminDataTable TItem="AdminUserResponse"
                         Items="FilteredUsers"
                         TotalCount="@(FilteredUsers.Count())"
                         IsLoading="@_isLoading"
                         SearchPlaceholder="Rechercher par nom ou email..."
                         SearchText="@_searchQuery"
                         SearchTextChanged="@(q => { _searchQuery = q; StateHasChanged(); })">
            <HeaderContent>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Inscrit le</th>
                <th>Actions</th>
            </HeaderContent>
            <RowContent Context="user">
                <tr class="@(user.Status != nameof(UserStatus.Active) ? "adm-table-row--muted" : "")">
                    <td>
                        <div class="adm-cell-name">
                            <div class="adm-avatar">@GetInitials(user.FirstName, user.LastName)</div>
                            <span>@user.FirstName @user.LastName</span>
                        </div>
                    </td>
                    <td>@user.Email</td>
                    <td>
                        <AdminBadge Text="@TranslateRole(user.Role)" Variant="@RoleBadgeVariant(user.Role)" />
                    </td>
                    <td>
                        <AdminBadge Text="@TranslateStatus(user.Status)" Variant="@StatusBadgeVariant(user.Status)" ShowDot />
                    </td>
                    <td class="adm-cell-mono">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="adm-cell-actions">
                            <button class="app-btn app-btn--link app-btn--sm" @onclick="() => OpenEditModal(user)">
                                Modifier
                            </button>
                            <button class="app-btn app-btn--link app-btn--sm" style="color: var(--color-error, #C0392B);"
                                    @onclick="() => OpenDeleteConfirm(user)">
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
            </RowContent>
            <EmptyContent>
                <AdminEmptyState Title="Aucun utilisateur trouvé"
                                 Message="@($"Aucun résultat pour « {_searchQuery} »")">
                    <IconContent><Blazicon Svg="Lucide.Users" /></IconContent>
                </AdminEmptyState>
            </EmptyContent>
        </AdminDataTable>

        @* ── Create modal ── *@
        <AdminFormModal IsVisible="@_showCreateModal" Title="Créer un utilisateur" OnClose="CloseCreateModal">
            <ChildContent>
                <EditForm Model="@_createModel" OnValidSubmit="HandleCreate">
                    <DataAnnotationsValidator />
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-fn">Prénom</label>
                            <InputText id="create-fn" @bind-Value="_createModel.FirstName"
                                       class="adm-form-input" placeholder="Prénom" />
                            <ValidationMessage For="@(() => _createModel.FirstName)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-ln">Nom</label>
                            <InputText id="create-ln" @bind-Value="_createModel.LastName"
                                       class="adm-form-input" placeholder="Nom" />
                            <ValidationMessage For="@(() => _createModel.LastName)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="create-email">Email</label>
                        <InputText id="create-email" @bind-Value="_createModel.Email"
                                   class="adm-form-input" placeholder="email@exemple.com" />
                        <ValidationMessage For="@(() => _createModel.Email)" class="adm-form-error" />
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="create-pw">Mot de passe (12 caractères min.)</label>
                        <InputText id="create-pw" @bind-Value="_createModel.Password" type="password"
                                   class="adm-form-input" placeholder="••••••••••••" />
                        <ValidationMessage For="@(() => _createModel.Password)" class="adm-form-error" />
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label" for="create-role">Rôle</label>
                        <InputSelect id="create-role" @bind-Value="_createModel.Role" class="adm-form-select">
                            @foreach (var role in AvailableRoles)
                            {
                                <option value="@role">@TranslateRole(role)</option>
                            }
                        </InputSelect>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem;">
                        <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseCreateModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button type="submit" class="app-btn app-btn--sm" disabled="@_isSaving">
                            @(_isSaving ? "Création..." : "Créer")
                        </button>
                    </div>
                </EditForm>
            </ChildContent>
        </AdminFormModal>

        @* ── Edit modal ── *@
        <AdminFormModal IsVisible="@(_editingUser is not null)" Title="Modifier l'utilisateur" OnClose="CloseEditModal">
            <ChildContent>
                @if (_editingUser is not null)
                {
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label">Prénom</label>
                            <input class="adm-form-input" @bind="_editModel.FirstName" placeholder="Prénom" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label">Nom</label>
                            <input class="adm-form-input" @bind="_editModel.LastName" placeholder="Nom" />
                        </div>
                    </div>
                    <div class="adm-form-group" style="margin-bottom: 1rem;">
                        <label class="adm-form-label">Email</label>
                        <input class="adm-form-input" @bind="_editModel.Email" placeholder="Email" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label">Rôle</label>
                            <select class="adm-form-select" @bind="_editModel.Role">
                                @foreach (var role in AvailableRoles)
                                {
                                    <option value="@role">@TranslateRole(role)</option>
                                }
                            </select>
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label">Statut</label>
                            <select class="adm-form-select" @bind="_editModel.Status">
                                @foreach (var status in AvailableStatuses)
                                {
                                    <option value="@status">@TranslateStatus(status)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div style="display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem;">
                        <button class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseEditModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button class="app-btn app-btn--sm" @onclick="HandleUpdate" disabled="@_isSaving">
                            @(_isSaving ? "Sauvegarde..." : "Sauvegarder")
                        </button>
                    </div>
                }
            </ChildContent>
        </AdminFormModal>

        @* ── Delete confirmation ── *@
        <AdminConfirmDialog IsVisible="@(_deletingUser is not null)"
                            Title="Supprimer l'utilisateur"
                            Message="@($"Voulez-vous vraiment supprimer {_deletingUser?.FirstName} {_deletingUser?.LastName} ? Cette action est irréversible.")"
                            ConfirmText="Supprimer"
                            Variant="danger"
                            IsProcessing="@_isSaving"
                            OnConfirm="HandleDelete"
                            OnCancel="CloseDeleteConfirm" />
    </ChildContent>
</AdminLayout>

@code {
    private List<AdminUserResponse>? _users;
    private bool _isLoading = true;
    private string? _loadError;
    private string _searchQuery = "";

    private bool _showCreateModal;
    private AdminCreateUserRequest _createModel = new();

    private AdminUserResponse? _editingUser;
    private AdminUpdateUserRequest _editModel = new();

    private AdminUserResponse? _deletingUser;
    private bool _isSaving;
    private string? _actionSuccess;
    private string? _actionError;

    private static readonly string[] AvailableRoles = Enum.GetNames<UserRole>();
    private static readonly string[] AvailableStatuses = Enum.GetNames<UserStatus>();

    private readonly List<AdminBreadcrumbs.BreadcrumbItem> _breadcrumbs =
    [
        new() { Label = "Administration", Href = "/admin" },
        new() { Label = "Utilisateurs", Href = "/admin/users" }
    ];

    private IEnumerable<AdminUserResponse> FilteredUsers =>
        _users?.Where(u =>
            string.IsNullOrWhiteSpace(_searchQuery)
            || u.FirstName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || u.LastName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || u.Email.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _isLoading = true;
        _loadError = null;
        StateHasChanged();

        var (users, error) = await AdminService.GetAllUsersAsync();
        _users = users;
        _loadError = error?.Error;
        _isLoading = false;
    }

    // ── Create ──

    private void OpenCreateModal()
    {
        ClearMessages();
        _createModel = new AdminCreateUserRequest();
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _createModel = new AdminCreateUserRequest();
    }

    private async Task HandleCreate()
    {
        _isSaving = true;
        ClearMessages();

        var (created, error) = await AdminService.CreateUserAsync(_createModel);
        if (created is not null)
        {
            _users?.Add(created);
            _actionSuccess = $"Utilisateur {created.FirstName} {created.LastName} créé avec succès";
            CloseCreateModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la création de l'utilisateur";
        }

        _isSaving = false;
    }

    // ── Edit ──

    private void OpenEditModal(AdminUserResponse user)
    {
        ClearMessages();
        _deletingUser = null;
        _editingUser = user;
        _editModel = new AdminUpdateUserRequest
        {
            FirstName = user.FirstName,
            LastName = user.LastName,
            Email = user.Email,
            Role = user.Role,
            Status = user.Status
        };
    }

    private void CloseEditModal()
    {
        _editingUser = null;
        _editModel = new AdminUpdateUserRequest();
    }

    private async Task HandleUpdate()
    {
        if (_editingUser is null) return;
        _isSaving = true;
        ClearMessages();

        var (updated, error) = await AdminService.UpdateUserAsync(_editingUser.Id, _editModel);
        if (updated is not null)
        {
            ReplaceUser(updated);
            _actionSuccess = $"Utilisateur {updated.FirstName} {updated.LastName} mis à jour";
            CloseEditModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la mise à jour de l'utilisateur";
        }

        _isSaving = false;
    }

    // ── Delete ──

    private void OpenDeleteConfirm(AdminUserResponse user)
    {
        ClearMessages();
        _editingUser = null;
        _deletingUser = user;
    }

    private void CloseDeleteConfirm()
    {
        _deletingUser = null;
    }

    private async Task HandleDelete()
    {
        if (_deletingUser is null) return;
        _isSaving = true;
        ClearMessages();

        var userId = _deletingUser.Id;
        var (success, error) = await AdminService.DeleteUserAsync(userId);
        if (success)
        {
            var removed = _deletingUser;
            _users?.RemoveAll(u => u.Id == userId);
            _actionSuccess = $"Utilisateur {removed.FirstName} {removed.LastName} supprimé";
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la suppression de l'utilisateur";
        }

        _deletingUser = null;
        _isSaving = false;
    }

    // ── Helpers ──

    private void ReplaceUser(AdminUserResponse updated)
    {
        if (_users is null) return;
        var idx = _users.FindIndex(u => u.Id == updated.Id);
        if (idx >= 0) _users[idx] = updated;
    }

    private void ClearMessages()
    {
        _actionSuccess = null;
        _actionError = null;
    }

    private static string GetInitials(string firstName, string lastName)
    {
        var f = string.IsNullOrEmpty(firstName) ? "" : firstName[..1].ToUpperInvariant();
        var l = string.IsNullOrEmpty(lastName) ? "" : lastName[..1].ToUpperInvariant();
        return $"{f}{l}";
    }

    private static string RoleBadgeVariant(string role) => role switch
    {
        nameof(UserRole.Administrator) => "admin",
        nameof(UserRole.RestaurantOwner) => "owner",
        _ => "customer"
    };

    private static string StatusBadgeVariant(string status) => status switch
    {
        nameof(UserStatus.Active) => "active",
        nameof(UserStatus.Suspended) => "warning",
        nameof(UserStatus.Banned) => "danger",
        _ => "active"
    };

    private static string TranslateRole(string role) => role switch
    {
        nameof(UserRole.Administrator) => "Administrateur",
        nameof(UserRole.RestaurantOwner) => "Restaurateur",
        nameof(UserRole.Customer) => "Client",
        _ => role
    };

    private static string TranslateStatus(string status) => status switch
    {
        nameof(UserStatus.Active) => "Actif",
        nameof(UserStatus.Suspended) => "Suspendu",
        nameof(UserStatus.Banned) => "Banni",
        _ => status
    };
}
