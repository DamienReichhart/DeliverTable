@page "/admin/events"
@attribute [Authorize(Roles = nameof(UserRole.Administrator))]
@using DeliverTableClient.Services.Interfaces
@using DeliverTableSharedLibrary.Dtos.Admin
@using DeliverTableSharedLibrary.Enums
@using Microsoft.AspNetCore.Authorization
@inject IAdminEventClientService EventService

<PageTitle>Événements — Administration</PageTitle>

<AdminLayout Title="Événements" Subtitle="@($"{(_events?.Count ?? 0)} événements")">
    <ActionsContent>
        <button class="app-btn app-btn--sm" @onclick="OpenCreateModal">
            <Blazicon Svg="Lucide.Plus" />
            Créer un événement
        </button>
    </ActionsContent>
    <ChildContent>
        <AdminBreadcrumbs Items="@_breadcrumbs" />

        @if (!string.IsNullOrEmpty(_actionSuccess))
        {
            <div class="adm-alert adm-alert--success">@_actionSuccess</div>
        }
        @if (!string.IsNullOrEmpty(_actionError))
        {
            <div class="adm-alert adm-alert--danger">@_actionError</div>
        }

        <AdminDataTable TItem="AdminEventResponse"
                         Items="FilteredEvents"
                         TotalCount="@(FilteredEvents.Count())"
                         IsLoading="@_isLoading"
                         SearchPlaceholder="Rechercher par nom ou restaurant..."
                         SearchText="@_searchQuery"
                         SearchTextChanged="@(q => { _searchQuery = q; StateHasChanged(); })">
            <HeaderContent>
                <th>Nom</th>
                <th>Restaurant</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Max. invités</th>
                <th>Visibilité</th>
                <th>Actif</th>
                <th>Actions</th>
            </HeaderContent>
            <RowContent Context="evt">
                <tr>
                    <td>@evt.Name</td>
                    <td>@evt.RestaurantName</td>
                    <td class="adm-cell-mono">@evt.StartsAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="adm-cell-mono">@evt.EndsAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="adm-cell-mono">@(evt.MaxGuests?.ToString() ?? "—")</td>
                    <td>
                        <AdminBadge Text="@TranslateVisibility(evt.Visibility)" Variant="@VisibilityBadgeVariant(evt.Visibility)" />
                    </td>
                    <td>
                        <AdminBadge Text="@(evt.IsActive ? "Actif" : "Inactif")"
                                    Variant="@(evt.IsActive ? "active" : "warning")" ShowDot />
                    </td>
                    <td>
                        <div class="adm-cell-actions">
                            <button class="adm-ghost-btn adm-ghost-btn--primary" @onclick="() => OpenEditModal(evt)">
                                Modifier
                            </button>
                            <button class="adm-ghost-btn adm-ghost-btn--danger"
                                    @onclick="() => OpenDeleteConfirm(evt)">
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
            </RowContent>
            <EmptyContent>
                <AdminEmptyState Title="Aucun événement trouvé"
                                 Message="@($"Aucun résultat pour « {_searchQuery} »")">
                    <IconContent><Blazicon Svg="Lucide.Calendar" /></IconContent>
                </AdminEmptyState>
            </EmptyContent>
        </AdminDataTable>

        @* ── Create modal ── *@
        <AdminFormModal IsVisible="@_showCreateModal" Title="Créer un événement" OnClose="CloseCreateModal">
            <ChildContent>
                <EditForm Model="@_createModel" OnValidSubmit="HandleCreate">
                    <DataAnnotationsValidator />
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="create-name">Nom</label>
                        <InputText id="create-name" @bind-Value="_createModel.Name"
                                   class="adm-form-input" placeholder="Nom de l'événement" />
                        <ValidationMessage For="@(() => _createModel.Name)" class="adm-form-error" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label" for="create-desc">Description</label>
                        <InputTextArea id="create-desc" @bind-Value="_createModel.Description"
                                       class="adm-form-input" placeholder="Description" rows="3" />
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-start">Date de début</label>
                            <InputDate id="create-start" @bind-Value="_createModel.StartsAt"
                                       Type="InputDateType.DateTimeLocal" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.StartsAt)" class="adm-form-error" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-end">Date de fin</label>
                            <InputDate id="create-end" @bind-Value="_createModel.EndsAt"
                                       Type="InputDateType.DateTimeLocal" class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.EndsAt)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-guests">Max. invités</label>
                            <InputNumber id="create-guests" @bind-Value="_createModel.MaxGuests"
                                         class="adm-form-input" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-visibility">Visibilité</label>
                            <InputSelect id="create-visibility" @bind-Value="_createModel.Visibility" class="adm-form-select">
                                <option value="@EventVisibility.Public">Public</option>
                                <option value="@EventVisibility.Private">Privé</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-restaurant">Restaurant (ID)</label>
                            <InputNumber id="create-restaurant" @bind-Value="_createModel.RestaurantId"
                                         class="adm-form-input" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label" for="create-user">Créateur (ID utilisateur)</label>
                            <InputNumber id="create-user" @bind-Value="_createModel.CreatedByUserId"
                                         class="adm-form-input" />
                            <ValidationMessage For="@(() => _createModel.CreatedByUserId)" class="adm-form-error" />
                        </div>
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label">
                            <InputCheckbox @bind-Value="_createModel.IsActive" />
                            Actif
                        </label>
                    </div>
                    <div class="adm-form-actions">
                        <button type="button" class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseCreateModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button type="submit" class="app-btn app-btn--sm" disabled="@_isSaving">
                            @(_isSaving ? "Création..." : "Créer")
                        </button>
                    </div>
                </EditForm>
            </ChildContent>
        </AdminFormModal>

        @* ── Edit modal ── *@
        <AdminFormModal IsVisible="@(_editingEvent is not null)" Title="Modifier l'événement" OnClose="CloseEditModal">
            <ChildContent>
                @if (_editingEvent is not null)
                {
                    <div class="adm-form-group">
                        <label class="adm-form-label">Nom</label>
                        <input class="adm-form-input" @bind="_editModel.Name" placeholder="Nom" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label">Description</label>
                        <textarea class="adm-form-input" @bind="_editModel.Description" rows="3"></textarea>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label">Date de début</label>
                            <input type="datetime-local" class="adm-form-input" @bind="_editModel.StartsAt" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label">Date de fin</label>
                            <input type="datetime-local" class="adm-form-input" @bind="_editModel.EndsAt" />
                        </div>
                    </div>
                    <div class="adm-form-row">
                        <div class="adm-form-group">
                            <label class="adm-form-label">Max. invités</label>
                            <input type="number" class="adm-form-input" @bind="_editModel.MaxGuests" />
                        </div>
                        <div class="adm-form-group">
                            <label class="adm-form-label">Visibilité</label>
                            <select class="adm-form-select" @bind="_editModel.Visibility">
                                <option value="@EventVisibility.Public">Public</option>
                                <option value="@EventVisibility.Private">Privé</option>
                            </select>
                        </div>
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label">Restaurant (ID)</label>
                        <input type="number" class="adm-form-input" @bind="_editModel.RestaurantId" />
                    </div>
                    <div class="adm-form-group">
                        <label class="adm-form-label">
                            <input type="checkbox" @bind="_editModel.IsActive" />
                            Actif
                        </label>
                    </div>
                    <div class="adm-form-actions">
                        <button class="app-btn app-btn--secondary app-btn--sm" @onclick="CloseEditModal" disabled="@_isSaving">
                            Annuler
                        </button>
                        <button class="app-btn app-btn--sm" @onclick="HandleUpdate" disabled="@_isSaving">
                            @(_isSaving ? "Sauvegarde..." : "Sauvegarder")
                        </button>
                    </div>
                }
            </ChildContent>
        </AdminFormModal>

        @* ── Delete confirmation ── *@
        <AdminConfirmDialog IsVisible="@(_deletingEvent is not null)"
                            Title="Supprimer l'événement"
                            Message="@($"Voulez-vous vraiment supprimer « {_deletingEvent?.Name} » ? Cette action est irréversible.")"
                            ConfirmText="Supprimer"
                            Variant="danger"
                            IsProcessing="@_isSaving"
                            OnConfirm="HandleDelete"
                            OnCancel="CloseDeleteConfirm" />
    </ChildContent>
</AdminLayout>

@code {
    private List<AdminEventResponse>? _events;
    private bool _isLoading = true;
    private string _searchQuery = "";

    private bool _showCreateModal;
    private AdminCreateEventRequest _createModel = new();

    private AdminEventResponse? _editingEvent;
    private AdminUpdateEventRequest _editModel = new();

    private AdminEventResponse? _deletingEvent;
    private bool _isSaving;
    private string? _actionSuccess;
    private string? _actionError;

    private readonly List<AdminBreadcrumbs.BreadcrumbItem> _breadcrumbs =
    [
        new() { Label = "Administration", Href = "/admin" },
        new() { Label = "Événements", Href = "/admin/events" }
    ];

    private IEnumerable<AdminEventResponse> FilteredEvents =>
        _events?.Where(e =>
            string.IsNullOrWhiteSpace(_searchQuery)
            || e.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
            || e.RestaurantName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? [];

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        _isLoading = true;
        StateHasChanged();

        var (events, error) = await EventService.GetAllAsync();
        _events = events;
        _actionError = error?.Error;
        _isLoading = false;
    }

    // ── Create ──

    private void OpenCreateModal()
    {
        ClearMessages();
        _createModel = new AdminCreateEventRequest();
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
        _createModel = new AdminCreateEventRequest();
    }

    private async Task HandleCreate()
    {
        _isSaving = true;
        ClearMessages();

        var (created, error) = await EventService.CreateAsync(_createModel);
        if (created is not null)
        {
            _events?.Add(created);
            _actionSuccess = $"Événement « {created.Name} » créé avec succès";
            CloseCreateModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la création de l'événement";
        }

        _isSaving = false;
    }

    // ── Edit ──

    private void OpenEditModal(AdminEventResponse evt)
    {
        ClearMessages();
        _deletingEvent = null;
        _editingEvent = evt;
        _editModel = new AdminUpdateEventRequest
        {
            Name = evt.Name,
            Description = evt.Description,
            StartsAt = evt.StartsAt,
            EndsAt = evt.EndsAt,
            MaxGuests = evt.MaxGuests,
            Visibility = evt.Visibility,
            IsActive = evt.IsActive,
            RestaurantId = evt.RestaurantId
        };
    }

    private void CloseEditModal()
    {
        _editingEvent = null;
        _editModel = new AdminUpdateEventRequest();
    }

    private async Task HandleUpdate()
    {
        if (_editingEvent is null) return;
        _isSaving = true;
        ClearMessages();

        var (updated, error) = await EventService.UpdateAsync(_editingEvent.Id, _editModel);
        if (updated is not null)
        {
            ReplaceEvent(updated);
            _actionSuccess = $"Événement « {updated.Name} » mis à jour";
            CloseEditModal();
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la mise à jour de l'événement";
        }

        _isSaving = false;
    }

    // ── Delete ──

    private void OpenDeleteConfirm(AdminEventResponse evt)
    {
        ClearMessages();
        _editingEvent = null;
        _deletingEvent = evt;
    }

    private void CloseDeleteConfirm()
    {
        _deletingEvent = null;
    }

    private async Task HandleDelete()
    {
        if (_deletingEvent is null) return;
        _isSaving = true;
        ClearMessages();

        var eventId = _deletingEvent.Id;
        var (success, error) = await EventService.DeleteAsync(eventId);
        if (success)
        {
            var removed = _deletingEvent;
            _events?.RemoveAll(e => e.Id == eventId);
            _actionSuccess = $"Événement « {removed.Name} » supprimé";
        }
        else
        {
            _actionError = error?.Error ?? "Échec de la suppression de l'événement";
        }

        _deletingEvent = null;
        _isSaving = false;
    }

    // ── Helpers ──

    private void ReplaceEvent(AdminEventResponse updated)
    {
        if (_events is null) return;
        var idx = _events.FindIndex(e => e.Id == updated.Id);
        if (idx >= 0) _events[idx] = updated;
    }

    private void ClearMessages()
    {
        _actionSuccess = null;
        _actionError = null;
    }

    private static string TranslateVisibility(EventVisibility visibility) => visibility switch
    {
        EventVisibility.Public => "Public",
        EventVisibility.Private => "Privé",
        _ => visibility.ToString()
    };

    private static string VisibilityBadgeVariant(EventVisibility visibility) => visibility switch
    {
        EventVisibility.Public => "active",
        EventVisibility.Private => "warning",
        _ => "active"
    };
}
